									"flex items-center gap-2 px-3 py-2.5 rounded-lg whitespace-nowrap text-sm font-medium transition-colors",
									item.section === activeSection
										? "text-premium-accent bg-premium-accent/10"
										: "text-text-secondary hover:bg-premium-accent/10 hover:text-premium-accent",
								]}
								aria-current={item.section === activeSection ? "page" : undefined}
							>
								<svg
									class="w-4 h-4 flex-shrink-0"
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
