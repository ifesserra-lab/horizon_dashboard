					<Breadcrumbs replacements={breadcrumbReplacements} />
					<slot />
				</div>
			</main>
		</div>

		<script is:inline define:vars={{ baseUrlValue }}>
			// Menu horizontal: navegação e sincronização por campus.
			const CAMPUS_STORAGE_KEY = "preferred-campus";
			const baseUrl = baseUrlValue;
			const campusRuntime = window.__HORIZON_CAMPUS__ || {};

			function normalizePath(pathname) {
				const normalizedBase = baseUrl.endsWith("/")
					? baseUrl.slice(0, -1)
					: baseUrl;
				if (normalizedBase && pathname.startsWith(normalizedBase)) {
					const stripped = pathname.slice(normalizedBase.length);
					return stripped.startsWith("/") ? stripped : `/${stripped}`;
				}
				return pathname;
			}

			function detectSection(pathname) {
				const parts = normalizePath(pathname).split("/").filter(Boolean);
				return parts[0] || "overview";
			}

			function buildInstitutionalHref(section) {
				return section === "overview" ? baseUrl : `${baseUrl}${section}`;
			}

			function getCampusRecord(value) {
				return campusRuntime.resolveCampus
					? campusRuntime.resolveCampus(value)
					: null;
			}

			function applyCampusLinks(selectedCampus) {
				const sectionLinks = document.querySelectorAll("[data-nav-section]");
				sectionLinks.forEach((link) => {
					const section = link.getAttribute("data-nav-section") || "overview";
					link.setAttribute("href", buildInstitutionalHref(section));
				});
			}

			function syncCampusSelectors(selectedCampus) {
				const selectors = document.querySelectorAll("[data-campus-switcher]");
				selectors.forEach((select) => {
					select.value = selectedCampus || "";
				});
			}

			function announceCampusChange(selectedCampus) {
				const campus = getCampusRecord(selectedCampus);
				if (campusRuntime.syncDocumentCampus) {
					campusRuntime.syncDocumentCampus(campus);
				}
				window.dispatchEvent(
					new CustomEvent("campus-filter-change", {
						detail: {
							campusId: campus?.id || "",
							campusSlug: campus?.slug || "",
							campusName: campus?.name || "",
							campus: campus?.id || "",
						},
					}),
				);
			}

			const currentPath = normalizePath(window.location.pathname);
			const currentParts = currentPath.split("/").filter(Boolean);
			const campusFromPath =
				currentParts[0] === "campus"
					? getCampusRecord(currentParts[1] || "")?.id || ""
					: "";
			const storedCampus =
				getCampusRecord(localStorage.getItem(CAMPUS_STORAGE_KEY) || "")?.id ||
				"";
			const activeCampus = campusFromPath || storedCampus;

			if (campusFromPath) {
				localStorage.setItem(CAMPUS_STORAGE_KEY, campusFromPath);
			}

			applyCampusLinks(activeCampus);
			syncCampusSelectors(activeCampus);
			announceCampusChange(activeCampus);

			const selectors = document.querySelectorAll("[data-campus-switcher]");
			selectors.forEach((select) => {
				select.addEventListener("change", (event) => {
					const target = event.currentTarget;
					const nextCampus = getCampusRecord(target.value)?.id || "";

					if (nextCampus) {
						localStorage.setItem(CAMPUS_STORAGE_KEY, nextCampus);
						announceCampusChange(nextCampus);
						return;
					}

					localStorage.removeItem(CAMPUS_STORAGE_KEY);
					announceCampusChange("");
				});
			});
		</script>
	</body>
