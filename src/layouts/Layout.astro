interface Props {
	title: string;
	breadcrumbReplacements?: Record<string, string>;
}

const { title, breadcrumbReplacements } = Astro.props;
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import BrandStripe from "../components/BrandStripe.astro";
import AccessibilityToggle from "../components/AccessibilityToggle.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CampusGlobalSelect from "../components/campus/CampusGlobalSelect.astro";
import { getRealCampuses, resolveCampusId } from "../lib/tenant-data";

const campuses = getRealCampuses();
const campusCatalog = campuses.map(({ id, name, slug }) => ({ id, name, slug }));
const baseUrlValue = import.meta.env.BASE_URL;
const navBasePath = import.meta.env.BASE_URL;

// Fontes institucionais (Ubuntu / Ubuntu Mono) self-hosted.
// @font-face montado aqui para respeitar o base path do GitHub Pages.
const fontBase = `${import.meta.env.BASE_URL}fonts/`;
const fontFaceCss = `
@font-face{font-family:'Ubuntu';font-style:normal;font-weight:400;font-display:swap;src:url('${fontBase}Ubuntu-400.woff2') format('woff2');}
@font-face{font-family:'Ubuntu';font-style:normal;font-weight:500;font-display:swap;src:url('${fontBase}Ubuntu-500.woff2') format('woff2');}
@font-face{font-family:'Ubuntu';font-style:normal;font-weight:700;font-display:swap;src:url('${fontBase}Ubuntu-700.woff2') format('woff2');}
@font-face{font-family:'Ubuntu Mono';font-style:normal;font-weight:400;font-display:swap;src:url('${fontBase}UbuntuMono-400.woff2') format('woff2');}
@font-face{font-family:'Ubuntu Mono';font-style:normal;font-weight:700;font-display:swap;src:url('${fontBase}UbuntuMono-700.woff2') format('woff2');}
`;
const pathSegments = Astro.url.pathname
	.replace(import.meta.env.BASE_URL, "/")
	.split("/")
	.filter(Boolean);
const currentCampusId =
	pathSegments[0] === "campus" && pathSegments[1]
		? resolveCampusId(pathSegments[1]) || null
		: null;

// Seção ativa (para destacar o item no menu horizontal).
const activeSection =
	pathSegments[0] && pathSegments[0] !== "campus"
		? pathSegments[0]
		: "overview";

// Itens de navegação (fonte única p/ o menu horizontal do desktop).
const navItems = [
	{
		label: "Buscar",
		section: "overview",
		href: navBasePath,
		icon: `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>`,
	},
	{
		label: "Grupos",
		section: "groups",
		href: `${navBasePath}groups`,
		icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>`,
	},
	{
		label: "Pesquisadores",
		section: "researchers",
		href: `${navBasePath}researchers`,
		icon: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>`,
	},
	{
		label: "Estudantes",
		section: "students",
		href: `${navBasePath}students`,
		icon: `<path d="M4 7 12 4l8 3-8 3-8-3Z"></path><path d="M6 10.5v4.5c0 1.2 2.7 3 6 3s6-1.8 6-3v-4.5"></path><path d="M12 13v5"></path>`,
	},
	{
		label: "Externos ao Ifes",
		section: "outside-ifes",
		href: `${navBasePath}outside-ifes`,
		icon: `<circle cx="12" cy="12" r="9"></circle><path d="M3 12h18"></path><path d="M12 3a15 15 0 0 1 0 18"></path><path d="M12 3a15 15 0 0 0 0 18"></path>`,
	},
	{
		label: "Não reconhecidos",
		section: "unrecognized",
		href: `${navBasePath}unrecognized`,
		icon: `<circle cx="12" cy="12" r="9"></circle><path d="M9.09 9a3 3 0 0 1 5.82 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path>`,
	},
	{
		label: "Áreas",
