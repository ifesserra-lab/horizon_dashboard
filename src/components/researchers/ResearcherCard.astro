---
import type { Researcher } from "../../types/researchers";
import type { ResearcherStats } from "../../lib/researchers-data";
import {
    buildResearcherCardView,
    renderResearcherCardMarkup,
} from "../../lib/researcher-card-markup";

interface Props {
    researcher: Researcher;
    stats: ResearcherStats;
    baseUrl: string;
    campusIds?: string[];
    campusNames?: string[];
    profileHref?: string;
}

const cardView = buildResearcherCardView(Astro.props as Props);
---

<Fragment set:html={renderResearcherCardMarkup(cardView)} />
