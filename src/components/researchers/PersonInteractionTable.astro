---
import type {
    StudentInteractionClassification,
    StudentInteractionGraphKind,
    StudentInteractionTableRow,
    StudentInteractionTableRowRelation,
} from "../../types/student-graphs";

interface Props {
    graphKind: StudentInteractionGraphKind;
    rows: StudentInteractionTableRow[];
}

const { graphKind, rows } = Astro.props;

const relationLabels: Record<StudentInteractionTableRowRelation["type"], string> = {
    project: "Projeto",
    orientation: "Orientacao",
    article: "Artigo",
    initiative: "Iniciativa",
    research_group: "Grupo de pesquisa",
    advisorship: "Orientacao",
};

const classificationLabels: Record<
    Exclude<StudentInteractionClassification, null> | "null",
    string
> = {
    student: "Estudante",
    researcher: "Pesquisador",
    outside_ifes: "Externo ao Ifes",
    null: "Sem classificacao",
};

const tableTitle =
    graphKind === "collaboration"
        ? "Tabela de colaboracoes diretas"
        : "Tabela de relacionamentos diretos";
const tableDescription =
    graphKind === "collaboration"
        ? "Cada linha representa uma aresta do grafo de colaboracao, com as pessoas envolvidas, os tipos de colaboracao e o peso acumulado dessa conexao."
        : "Cada linha representa uma aresta do grafo de relacionamento, com as pessoas envolvidas, os tipos de vinculo e o peso acumulado dessa conexao.";
const tableCountLabel =
    graphKind === "collaboration"
        ? `${rows.length} colaboracoes mapeadas neste recorte`
        : `${rows.length} relacionamentos mapeados neste recorte`;
const emptyLabel =
    graphKind === "collaboration"
        ? "Nenhuma colaboracao direta foi registrada neste recorte."
        : "Nenhum relacionamento direto foi registrado neste recorte.";

const formatRelationChip = (relation: StudentInteractionTableRowRelation) => {
    const label = relationLabels[relation.type];

    if (!relation.count || relation.count <= 1) {
        return label;
    }

    return `${label} x${relation.count}`;
};

const formatPersonMeta = (
    classification: StudentInteractionClassification,
    campusName: string | null,
) => {
    const parts = [
        classificationLabels[classification ?? "null"],
        campusName,
    ].filter(Boolean);

    return parts.join(" | ");
};

const getVisibleNamedItems = (
    relation: StudentInteractionTableRowRelation,
    limit = 3,
) => relation.namedItems.slice(0, limit);

const resolveNamedItemHref = (relation: StudentInteractionTableRowRelation, itemId: string) => {
    if (relation.type !== "project" && relation.type !== "initiative") {
        return null;
    }

    return `${import.meta.env.BASE_URL}projects/${itemId}`;
};
---

<section class="rounded-3xl border border-slate-200/80 bg-white/82 p-6 shadow-[0_18px_50px_rgba(148,163,184,0.08)]">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <div class="space-y-2">
            <span class="inline-flex items-center rounded-full border border-slate-300 bg-slate-100 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-700">
                Tabela
            </span>
            <div>
                <h4 class="text-xl font-bold font-['Outfit'] text-text-main">
                    {tableTitle}
                </h4>
                <p class="mt-2 max-w-3xl text-sm leading-relaxed text-text-secondary">
                    {tableDescription}
                </p>
            </div>
        </div>
        <div class="text-xs text-text-secondary">
            {rows.length > 0 ? tableCountLabel : emptyLabel}
        </div>
    </div>

    {
        rows.length > 0 ? (
            <div class="mt-6 overflow-x-auto">
                <table class="min-w-full border-separate border-spacing-0">
                    <thead>
                        <tr>
                            <th class="rounded-tl-2xl border border-border-main bg-slate-50 px-4 py-3 text-left text-[11px] font-bold uppercase tracking-[0.18em] text-text-secondary">
                                Pessoa A
                            </th>
                            <th class="border border-l-0 border-border-main bg-slate-50 px-4 py-3 text-left text-[11px] font-bold uppercase tracking-[0.18em] text-text-secondary">
                                Pessoa B
                            </th>
                            <th class="border border-l-0 border-border-main bg-slate-50 px-4 py-3 text-left text-[11px] font-bold uppercase tracking-[0.18em] text-text-secondary">
                                Relacoes
                            </th>
                            <th class="border border-l-0 border-border-main bg-slate-50 px-4 py-3 text-left text-[11px] font-bold uppercase tracking-[0.18em] text-text-secondary">
                                Eventos
                            </th>
                            <th class="rounded-tr-2xl border border-l-0 border-border-main bg-slate-50 px-4 py-3 text-left text-[11px] font-bold uppercase tracking-[0.18em] text-text-secondary">
                                Peso
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {
                            rows.map((row, index) => (
                                <tr class={index % 2 === 0 ? "bg-white" : "bg-slate-50/50"}>
                                    <td class="border border-t-0 border-border-main px-4 py-4 align-top">
                                        <div class="min-w-[14rem]">
                                            <p class="text-sm font-semibold text-text-main leading-snug">
                                                {
                                                    row.sourceProfileHref ? (
                                                        <a
                                                            href={row.sourceProfileHref}
                                                            class="transition-colors hover:text-premium-accent"
                                                        >
                                                            {row.sourceName}
                                                        </a>
                                                    ) : (
                                                        row.sourceName
                                                    )
                                                }
                                            </p>
                                            <p class="mt-1 text-xs text-text-secondary">
                                                {formatPersonMeta(
                                                    row.sourceClassification,
                                                    row.sourceCampusName,
                                                )}
                                            </p>
                                        </div>
                                    </td>
                                    <td class="border border-l-0 border-t-0 border-border-main px-4 py-4 align-top">
                                        <div class="min-w-[14rem]">
                                            <p class="text-sm font-semibold text-text-main leading-snug">
                                                {
                                                    row.targetProfileHref ? (
                                                        <a
                                                            href={row.targetProfileHref}
                                                            class="transition-colors hover:text-premium-accent"
                                                        >
                                                            {row.targetName}
                                                        </a>
                                                    ) : (
                                                        row.targetName
                                                    )
                                                }
                                            </p>
                                            <p class="mt-1 text-xs text-text-secondary">
                                                {formatPersonMeta(
                                                    row.targetClassification,
                                                    row.targetCampusName,
                                                )}
                                            </p>
                                        </div>
                                    </td>
                                    <td class="border border-l-0 border-t-0 border-border-main px-4 py-4 align-top">
                                        <div class="min-w-[20rem] space-y-3">
                                            {row.relations.map((relation) => {
                                                const visibleNamedItems =
                                                    getVisibleNamedItems(relation);
                                                const remainingNamedItems =
                                                    Math.max(
                                                        0,
                                                        relation.namedItems.length -
                                                            visibleNamedItems.length,
                                                    );

                                                return (
                                                    <div class="rounded-2xl border border-border-main bg-white/80 p-3">
                                                        <span class="inline-flex items-center rounded-full border border-border-main bg-white px-3 py-1 text-xs font-medium text-text-main">
                                                            {formatRelationChip(relation)}
                                                        </span>

                                                        {
                                                            visibleNamedItems.length > 0 && (
                                                                <div class="mt-3 space-y-2">
                                                                    {visibleNamedItems.map((item) => (
                                                                        <p class="text-xs leading-relaxed text-text-secondary">
                                                                            {
                                                                                resolveNamedItemHref(
                                                                                    relation,
                                                                                    item.id,
                                                                                ) ? (
                                                                                    <a
                                                                                        href={resolveNamedItemHref(
                                                                                            relation,
                                                                                            item.id,
                                                                                        ) ?? undefined}
                                                                                        class="font-medium text-premium-accent transition-colors hover:text-premium-accent/80"
                                                                                    >
                                                                                        {item.name}
                                                                                    </a>
                                                                                ) : (
                                                                                    item.name
                                                                                )
                                                                            }
                                                                        </p>
                                                                    ))}

                                                                    {
                                                                        remainingNamedItems > 0 && (
                                                                            <p class="text-xs font-medium text-text-secondary">
                                                                                + {remainingNamedItems} itens relacionados
                                                                            </p>
                                                                        )
                                                                    }
                                                                </div>
                                                            )
                                                        }
                                                    </div>
                                                );
                                            })}
                                        </div>
                                    </td>
                                    <td class="border border-l-0 border-t-0 border-border-main px-4 py-4 align-top">
                                        <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                                            {row.totalRelationEvents}
                                        </span>
                                    </td>
                                    <td class="border border-l-0 border-t-0 border-border-main px-4 py-4 align-top">
                                        <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
                                            {row.weight}
                                        </span>
                                    </td>
                                </tr>
                            ))
                        }
                    </tbody>
                </table>
            </div>
        ) : (
            <div class="mt-6 rounded-2xl border border-dashed border-border-main bg-white/60 p-6 text-sm text-text-secondary">
                {emptyLabel}
            </div>
        )
    }
</section>
