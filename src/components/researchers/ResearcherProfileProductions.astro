---
import type { ResearcherProduction } from "../../lib/researcher-lattes-extras";

interface Props {
    productions: ResearcherProduction[];
}

const { productions } = Astro.props;
---

<section aria-labelledby="productions-title" class="space-y-6">
    <div class="py-4 border-b border-border-main">
        <h3
            id="productions-title"
            class="text-2xl font-bold font-display text-text-main"
        >
            Produção Técnica ({productions.length})
        </h3>
    </div>

    <div class="space-y-4">
        {
            productions.map((production) => (
                <div class="glass-card p-5 border border-border-main hover:border-premium-purple/30 transition-all">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="px-2 py-0.5 rounded-md bg-premium-purple/10 text-premium-purple text-[10px] font-bold uppercase tracking-wider">
                            {production.type}
                        </span>
                        {production.year && (
                            <span class="text-xs font-bold text-text-secondary">
                                {production.year}
                            </span>
                        )}
                    </div>
                    <h4 class="text-sm font-bold text-text-main leading-snug">
                        {production.title}
                    </h4>
                </div>
            ))
        }
    </div>
</section>
