---
import type { KnowledgeAreaViewRecord } from "../../lib/tenant-data";
import { buildSearchIndex } from "../../lib/search";

interface TopAreaRecord {
    name: string;
    count: number;
    percentage: number;
}

interface Props {
    sortedAreas: KnowledgeAreaViewRecord[];
    top10Areas: TopAreaRecord[];
    baseUrl: string;
}

const { sortedAreas, top10Areas, baseUrl } = Astro.props;
---

<section class="glass-card p-6" aria-labelledby="areas-title">
    <h3 id="areas-title" class="text-xl font-bold font-['Outfit'] text-text-main mb-6">
        Top 10 Áreas de Conhecimento
    </h3>
    {
        top10Areas.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-5">
                {top10Areas.map((area) => (
                    <div class="space-y-1.5">
                        <div class="flex justify-between text-[10px] font-bold">
                            <span class="text-text-main truncate max-w-[70%]" title={area.name}>
                                {area.name}
                            </span>
                            <span class="text-text-secondary">{area.count} grupos</span>
                        </div>
                        <div class="w-full h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                            <div
                                class="h-full bg-gradient-to-r from-premium-accent to-premium-purple rounded-full"
                                style={`width: ${Math.min(area.percentage * 5, 100)}%`}
                            ></div>
                        </div>
                    </div>
                ))}
            </div>
        ) : (
            <p class="text-sm text-text-secondary">
                Nenhuma área encontrada para o campus selecionado.
            </p>
        )
    }
</section>

<div class="grid grid-cols-1 gap-6">
    {sortedAreas.map((area) => (
        <div
            class="area-card glass-card p-6 flex flex-col md:flex-row gap-6 group hover:border-premium-accent/30 transition-all"
            data-name={area.area_name.toLowerCase()}
            data-campuses={area.campuses.join("|").toLowerCase()}
            data-campus-ids=""
            data-groups={area.groups.map((group) => group.name.toLowerCase()).join("|")}
            data-search={buildSearchIndex([
                area.area_name,
                ...area.campuses,
                ...area.groups.map((group) => group.name),
            ])}
        >
            <div class="md:w-1/3">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 bg-premium-accent/10 rounded-xl flex items-center justify-center text-premium-accent group-hover:bg-premium-accent group-hover:text-white transition-all">
                        <span class="font-bold text-lg">{area.groups_count}</span>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold font-['Outfit']">{area.area_name}</h2>
                        <p class="text-xs text-text-muted">{area.campuses.length} Campi envolvidos</p>
                    </div>
                </div>

                <div class="flex flex-wrap gap-2 mt-2">
                    {area.campuses.slice(0, 5).map((campus) => (
                        <span class="px-2 py-0.5 bg-tag-bg text-[10px] rounded-full border border-outline text-text-main">
                            {campus}
                        </span>
                    ))}
                    {
                        area.campuses.length > 5 && (
                            <span class="px-2 py-0.5 bg-tag-bg text-[10px] rounded-full border border-outline text-text-main">
                                +{area.campuses.length - 5}
                            </span>
                        )
                    }
                </div>
            </div>

            <div class="md:w-2/3 border-t md:border-t-0 md:border-l border-outline pt-4 md:pt-0 md:pl-6">
                <h3 class="text-sm font-semibold mb-3 text-text-muted flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    Grupos Vinculados
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {area.groups.map((group) => (
                        <a
                            href={`${baseUrl}groups/${group.id}`}
                            class="text-sm p-3 rounded-lg border border-outline bg-white/5 hover:bg-premium-accent/5 hover:border-premium-accent/20 transition-all flex flex-col gap-1 group/item"
                        >
                            <span class="font-medium group-hover/item:text-premium-accent transition-colors line-clamp-1">
                                {group.name}
                            </span>
                            <span class="text-[10px] text-text-muted">{group.campus}</span>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    ))}
</div>
