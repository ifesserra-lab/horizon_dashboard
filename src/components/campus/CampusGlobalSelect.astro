---
interface CampusOption {
    id: string;
    slug: string;
    name: string;
}

interface Props {
    campuses: CampusOption[];
    currentCampusId?: string | null;
    compact?: boolean;
}

const { campuses, currentCampusId = null, compact = false } = Astro.props;
const selectId = compact ? "campus-global-select-mobile" : "campus-global-select";
---

<div class={`flex items-center gap-3 ${compact ? "min-w-0" : ""}`}>
    <label
        for={selectId}
        class={`text-xs font-bold uppercase tracking-[0.2em] text-text-muted ${compact ? "sr-only" : ""}`}
    >
        Campus
    </label>
    <div class={`relative ${compact ? "w-full" : "min-w-[220px]"}`}>
        <select
            id={selectId}
            data-campus-switcher
            class="w-full appearance-none rounded-xl border border-border-main bg-[var(--tag-bg)] px-4 py-2.5 pr-10 text-sm font-semibold text-text-main focus:outline-none focus:ring-2 focus:ring-premium-accent/50"
            value={currentCampusId ?? ""}
        >
            <option value="">Todos os campi</option>
            {
                campuses.map((campus) => (
                    <option
                        value={campus.id}
                        selected={campus.id === currentCampusId}
                    >
                        {campus.name}
                    </option>
                ))
            }
        </select>
        <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-text-secondary"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="m6 9 6 6 6-6"></path>
        </svg>
    </div>
</div>
