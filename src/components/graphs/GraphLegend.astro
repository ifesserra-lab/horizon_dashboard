---
export interface LegendItem {
    label: string;
    type: "dot" | "node" | "line";
    color?: string;
    strokeColor?: string;
    secondaryIndicator?: "ring" | "double";
}

export interface LegendSection {
    title: string;
    items: LegendItem[];
}

interface Props {
    sections: LegendSection[];
}

const { sections } = Astro.props;
---

<div
    data-graph-legend
    class="graph-legend absolute bottom-4 left-4 z-20 pointer-events-none transition-all duration-300"
>
    <!-- Botão para Expandir (quando colapsado) -->
    <button
        type="button"
        data-legend-expand
        class="legend-expand-btn pointer-events-auto flex items-center gap-2 rounded-full border border-outline bg-page-bg/95 px-3.5 py-2 text-xs font-bold text-text-main shadow-lg hover:bg-page hover:scale-105 active:scale-95 focus:outline-none focus:ring-2 focus:ring-premium-accent transition-all cursor-pointer"
        aria-label="Mostrar legenda do grafo"
        aria-expanded="false"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <span>Legenda</span>
    </button>

    <!-- Painel de Legenda Completo (quando expandido) -->
    <div
        data-legend-panel
        class="legend-panel pointer-events-auto w-64 rounded-2xl border border-outline bg-page-bg/90 p-4 shadow-xl backdrop-blur-md transition-all duration-300"
        role="region"
        aria-label="Legenda do Grafo"
    >
        <div class="flex items-center justify-between border-b border-outline pb-2 mb-3">
            <h4 class="font-['Outfit'] text-[11px] font-bold uppercase tracking-[0.12em] text-text-main">
                Legenda do Grafo
            </h4>
            <button
                type="button"
                data-legend-collapse
                class="text-text-secondary transition-colors hover:text-text-main focus:outline-none cursor-pointer"
                aria-label="Ocultar legenda do grafo"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>

        <div class="space-y-4 max-h-[280px] overflow-y-auto pr-1">
            {sections.map((section) => (
                <div class="space-y-2">
                    <h5 class="text-[10px] font-bold uppercase tracking-[0.1em] text-text-secondary">
                        {section.title}
                    </h5>
                    <ul class="space-y-2" role="list">
                        {section.items.map((item) => (
                            <li class="flex items-center gap-3 text-[11px] text-text-secondary">
                                {/* Visual Markers */}
                                {item.type === "dot" && (
                                    <span
                                        class="h-3 w-3 shrink-0 rounded-full"
                                        style={`background: ${item.color}`}
                                        aria-hidden="true"
                                    ></span>
                                )}

                                {item.type === "line" && (
                                    <span
                                        class="h-1 w-5 shrink-0 rounded-full"
                                        style={`background: ${item.color}`}
                                        aria-hidden="true"
                                    ></span>
                                )}

                                {item.type === "node" && (
                                    <div class="relative flex h-4 w-4 shrink-0 items-center justify-center" aria-hidden="true">
                                        {item.secondaryIndicator === "ring" && (
                                            <div
                                                class="absolute h-4.5 w-4.5 rounded-full border border-dashed animate-[spin_30s_linear_infinite]"
                                                style={`border-color: ${item.strokeColor || "#94a3b8"}`}
                                            ></div>
                                        )}
                                        <div
                                            class={`h-3 w-3 rounded-full border-2 ${item.secondaryIndicator === "double" ? "ring-1 ring-offset-1 ring-offset-page-bg" : ""}`}
                                            style={`
                                                background: ${item.color || "#ffffff"};
                                                border-color: ${item.strokeColor || "#94a3b8"};
                                                ${item.secondaryIndicator === "double" ? `--tw-ring-color: ${item.strokeColor || "#94a3b8"}` : ""}
                                            `}
                                        ></div>
                                    </div>
                                )}

                                <span class="leading-snug">{item.label}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
    </div>
</div>

<script>
    function initLegend() {
        const legends = document.querySelectorAll("[data-graph-legend]");
        legends.forEach((legend) => {
            const panel = legend.querySelector("[data-legend-panel]") as HTMLElement | null;
            const expandBtn = legend.querySelector("[data-legend-expand]") as HTMLButtonElement | null;
            const collapseBtn = legend.querySelector("[data-legend-collapse]") as HTMLButtonElement | null;

            if (!panel || !expandBtn || !collapseBtn) return;

            // Collapsed by default on small screens
            const isMobile = window.innerWidth < 640;
            let isCollapsed = isMobile;

            function updateState() {
                if (isCollapsed) {
                    panel!.classList.add("hidden");
                    expandBtn!.classList.remove("hidden");
                    expandBtn!.setAttribute("aria-expanded", "false");
                } else {
                    panel!.classList.remove("hidden");
                    expandBtn!.classList.add("hidden");
                    expandBtn!.setAttribute("aria-expanded", "true");
                }
            }

            // Init
            updateState();

            expandBtn.addEventListener("click", () => {
                isCollapsed = false;
                updateState();
            });

            collapseBtn.addEventListener("click", () => {
                isCollapsed = true;
                updateState();
            });
        });
    }

    // Load listeners
    document.addEventListener("DOMContentLoaded", initLegend);
    document.addEventListener("astro:page-load", initLegend);
    initLegend();
</script>
