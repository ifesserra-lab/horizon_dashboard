---
import type { ProvenanceField } from "../../lib/provenance";

interface Props {
    title?: string;
    intro?: string;
    fields: ProvenanceField[];
}

const { title = "Fontes dos dados", intro, fields } = Astro.props;
const visibleFields = (fields || []).filter((field) => field.sources.length > 0);

const formatDateTime = (value: string | null) => {
    if (!value) return null;

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;

    return date.toLocaleString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
    });
};
---

{
    visibleFields.length > 0 && (
        <details class="glass-card p-6 group" aria-labelledby="data-sources-title">
            <summary class="list-none cursor-pointer flex items-center justify-between gap-4">
                <div class="flex items-baseline gap-3 flex-wrap">
                    <h3
                        id="data-sources-title"
                        class="text-lg font-bold font-display text-text-main"
                    >
                        {title}
                    </h3>
                    <span class="text-xs text-text-secondary">
                        {visibleFields.length} blocos rastreados
                    </span>
                </div>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-text-secondary shrink-0 transition-transform group-open:rotate-180"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </summary>

            {
                intro && (
                    <p class="text-xs text-text-secondary mt-2 max-w-3xl">
                        {intro}
                    </p>
                )
            }

            <div class="mt-4 space-y-1.5">
                {
                    visibleFields.map((field) => {
                        const systemLabels = [
                            ...new Set(field.sources.map((source) => source.sourceSystemLabel)),
                        ];

                        return (
                            <details class="rounded-lg border border-border-main bg-[var(--tag-bg)]/40 px-3 py-2 group/field">
                                <summary class="list-none cursor-pointer flex items-center justify-between gap-3">
                                    <span class="text-sm font-bold text-text-main truncate">
                                        {field.label}
                                    </span>
                                    <div class="flex items-center gap-1.5 shrink-0">
                                        {
                                            systemLabels.map((label) => (
                                                <span class="px-2 py-0.5 rounded-full bg-track border border-border-main text-[9px] font-bold uppercase tracking-wider text-text-secondary">
                                                    {label}
                                                </span>
                                            ))
                                        }
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="w-3.5 h-3.5 text-text-secondary transition-transform group-open/field:rotate-180"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <polyline points="6 9 12 15 18 9" />
                                        </svg>
                                    </div>
                                </summary>

                                <div class="mt-3 pt-3 border-t border-border-main space-y-3">
                                    {
                                        field.description && (
                                            <p class="text-xs text-text-secondary">
                                                {field.description}
                                            </p>
                                        )
                                    }
                                    {
                                        field.sources.map((source) => (
                                            <article class="rounded-lg border border-border-main/70 bg-surface p-3 space-y-2">
                                                <div class="flex flex-wrap gap-1.5">
                                                    <span class="px-2 py-0.5 rounded-full bg-premium-accent/10 text-premium-accent text-[9px] font-bold uppercase tracking-wider">
                                                        {source.sourceSystemLabel}
                                                    </span>
                                                    <span class="px-2 py-0.5 rounded-full bg-track text-text-secondary text-[9px] font-bold uppercase tracking-wider border border-border-main">
                                                        {source.sourceEntityLabel}
                                                    </span>
                                                    {
                                                        source.flowName && (
                                                            <span class="px-2 py-0.5 rounded-full bg-track text-text-secondary text-[9px] font-bold uppercase tracking-wider border border-border-main">
                                                                {source.flowName}
                                                            </span>
                                                        )
                                                    }
                                                </div>

                                                <div>
                                                    <p class="text-sm font-bold text-text-main">
                                                        {source.sourceLabel}
                                                    </p>
                                                    {
                                                        source.sourceUrl ? (
                                                            <a
                                                                href={source.sourceUrl}
                                                                target="_blank"
                                                                rel="noopener noreferrer"
                                                                class="text-xs text-premium-accent hover:underline break-all"
                                                            >
                                                                {source.sourceUrl}
                                                            </a>
                                                        ) : (
                                                            <p class="text-xs text-text-secondary break-all font-mono">
                                                                {source.sourcePath ||
                                                                    source.sourceFile ||
                                                                    source.sourceRecordKey}
                                                            </p>
                                                        )
                                                    }
                                                </div>

                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-xs text-text-secondary">
                                                    {
                                                        source.extractedAt && (
                                                            <p>
                                                                <span class="font-bold text-text-main">
                                                                    Extraído em:
                                                                </span>{" "}
                                                                {formatDateTime(source.extractedAt)}
                                                            </p>
                                                        )
                                                    }
                                                    {
                                                        source.assertedAt && (
                                                            <p>
                                                                <span class="font-bold text-text-main">
                                                                    Afirmado em:
                                                                </span>{" "}
                                                                {formatDateTime(source.assertedAt)}
                                                            </p>
                                                        )
                                                    }
                                                </div>
                                            </article>
                                        ))
                                    }
                                </div>
                            </details>
                        );
                    })
                }
            </div>
        </details>
    )
}
