---
interface Props {
    martData: any;
}

const { martData } = Astro.props;

const topResearchers = martData.top_researchers || [];
const evolutionData = martData.evolution || [];
const typeDistribution = martData.type_distribution || [];
const topVenues = martData.top_venues || [];

const maxPublications = Math.max(
    ...topResearchers.map((item: any) => item.count),
    1,
);
const maxEvolution = Math.max(
    ...evolutionData.map((item: any) => item.count),
    1,
);
const maxVenueCount = Math.max(...topVenues.map((item: any) => item.count), 1);

const evoWidth = 600;
const evoHeight = 280;
const evoPadding = 36;
const evoInnerWidth = evoWidth - evoPadding * 2;
const evoInnerHeight = evoHeight - evoPadding * 2;
const stepX =
    evolutionData.length > 1
        ? evoInnerWidth / (evolutionData.length - 1)
        : evoInnerWidth;
const points = evolutionData.map((item: any, index: number) => ({
    x: evoPadding + index * stepX,
    y:
        evoHeight -
        evoPadding -
        (item.count / maxEvolution) * evoInnerHeight,
    value: item.count,
    year: item.year,
}));
const linePath = points.reduce(
    (path: string, point: any, index: number) =>
        index === 0 ? `M ${point.x} ${point.y}` : `${path} L ${point.x} ${point.y}`,
    "",
);
const areaPath = points.length
    ? `${linePath} L ${evoWidth - evoPadding} ${evoHeight - evoPadding} L ${evoPadding} ${evoHeight - evoPadding} Z`
    : "";
const xAxisLabels = points.filter((_: any, index: number) => {
    if (points.length <= 8) return true;
    if (index === 0 || index === points.length - 1) return true;
    const step = Math.ceil(points.length / 6);
    return index % step === 0;
});
---

<div
    class="space-y-6 mb-12"
    data-publications-tabs
>
    <div class="flex items-center justify-between border-b border-outline/50 pb-px overflow-x-auto no-scrollbar">
        <div class="flex gap-4 md:gap-8" role="tablist" aria-label="Visualizações de publicações">
            <button
                role="tab"
                aria-selected="true"
                aria-controls="publications-panel-top"
                id="publications-tab-top"
                class="pb-3 md:pb-4 text-xs md:text-sm font-bold tracking-wide transition-all relative cursor-pointer text-premium-accent border-b-2 border-premium-accent whitespace-nowrap"
            >
                Top Pesquisadores
            </button>
            <button
                role="tab"
                aria-selected="false"
                aria-controls="publications-panel-evolution"
                id="publications-tab-evolution"
                class="pb-3 md:pb-4 text-xs md:text-sm font-bold tracking-wide transition-all relative cursor-pointer text-text-muted hover:text-text-main border-b-2 border-transparent whitespace-nowrap"
            >
                Evolução Temporal
            </button>
            <button
                role="tab"
                aria-selected="false"
                aria-controls="publications-panel-types"
                id="publications-tab-types"
                class="pb-3 md:pb-4 text-xs md:text-sm font-bold tracking-wide transition-all relative cursor-pointer text-text-muted hover:text-text-main border-b-2 border-transparent whitespace-nowrap"
            >
                Distribuição por Tipo
            </button>
            <button
                role="tab"
                aria-selected="false"
                aria-controls="publications-panel-venues"
                id="publications-tab-venues"
                class="pb-3 md:pb-4 text-xs md:text-sm font-bold tracking-wide transition-all relative cursor-pointer text-text-muted hover:text-text-main border-b-2 border-transparent whitespace-nowrap"
            >
                Veículos em Destaque
            </button>
        </div>
    </div>

    <div class="relative min-h-[420px]">
        <div
            id="publications-panel-top"
            role="tabpanel"
            aria-labelledby="publications-tab-top"
            class="transition-all duration-300 opacity-100 scale-100"
        >
            <section class="glass-card p-6 flex flex-col relative overflow-hidden">
                <header class="relative z-10 mb-6">
                    <h3 class="text-xl font-bold font-['Outfit'] text-text-main">
                        Top Pesquisadores
                    </h3>
                    <p class="text-sm text-text-secondary mt-1">
                        Autores com maior volume de publicações vinculadas.
                    </p>
                </header>

                {
                    topResearchers.length > 0 ? (
                        <div class="relative z-10 space-y-4">
                            {topResearchers.map((item: any, index: number) => {
                                const width = Math.max(
                                    10,
                                    Math.round((item.count / maxPublications) * 100),
                                );

                                return (
                                    <div class="space-y-2.5">
                                        <div class="flex items-center justify-between gap-4">
                                            <p class="text-sm font-medium text-text-main truncate">
                                                {item.name}
                                            </p>
                                            <span class="text-xs font-medium text-text-secondary">
                                                {item.count}
                                            </span>
                                        </div>

                                        <div class="flex items-center gap-3">
                                            <span class="text-[10px] uppercase tracking-[0.22em] text-text-muted min-w-8">
                                                #{index + 1}
                                            </span>

                                            <div class="relative h-2 w-full rounded-full bg-slate-200/65 dark:bg-white/[0.06] overflow-hidden">
                                                <div
                                                    class="absolute inset-y-0 left-0 rounded-full bg-gradient-to-r from-sky-500/75 via-cyan-400/70 to-indigo-500/70"
                                                    style={`width:${width}%`}
                                                ></div>
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    ) : (
                        <p class="text-text-secondary">
                            Nenhuma publicação encontrada para este recorte.
                        </p>
                    )
                }
            </section>
        </div>

        <div
            id="publications-panel-evolution"
            role="tabpanel"
            aria-labelledby="publications-tab-evolution"
            class="hidden transition-all duration-300 opacity-0 scale-95"
        >
            <section class="glass-card p-6 flex flex-col relative overflow-hidden">
                <header class="relative z-10 mb-6">
                    <h3 class="text-xl font-bold font-['Outfit'] text-text-main">
                        Evolução Temporal
                    </h3>
                    <p class="text-sm text-text-secondary mt-1">
                        Distribuição anual da produção acadêmica.
                    </p>
                </header>

                {
                    points.length > 0 ? (
                        <div class="relative z-10 w-full h-full mt-auto min-h-[280px]">
                            <svg
                                viewBox={`0 0 ${evoWidth} ${evoHeight}`}
                                class="w-full h-full overflow-visible"
                            >
                                {xAxisLabels.map((point: any) => (
                                    <line
                                        x1={point.x}
                                        y1={evoPadding}
                                        x2={point.x}
                                        y2={evoHeight - evoPadding}
                                        stroke="#334155"
                                        stroke-opacity="0.12"
                                        stroke-dasharray="4 6"
                                    />
                                ))}

                                <line
                                    x1={evoPadding}
                                    y1={evoHeight - evoPadding}
                                    x2={evoWidth - evoPadding}
                                    y2={evoHeight - evoPadding}
                                    stroke="#334155"
                                    stroke-width="1"
                                />

                                <path
                                    d={areaPath}
                                    fill="var(--color-premium-accent)"
                                    fill-opacity="0.12"
                                />
                                <path
                                    d={linePath}
                                    fill="none"
                                    stroke="var(--color-premium-accent)"
                                    stroke-width="3.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="drop-shadow-[0_10px_24px_rgba(56,189,248,0.18)]"
                                />

                                {points.map((point: any) => (
                                    <g>
                                        <circle
                                            cx={point.x}
                                            cy={point.y}
                                            r="4.5"
                                            class="fill-bg-main stroke-premium-accent stroke-2"
                                        />
                                        <text
                                            x={point.x}
                                            y={point.y - 12}
                                            text-anchor="middle"
                                            class="text-[10px] font-bold fill-text-main"
                                        >
                                            {point.value}
                                        </text>
                                    </g>
                                ))}

                                {xAxisLabels.map((point: any) => (
                                    <text
                                        x={point.x}
                                        y={evoHeight - 10}
                                        text-anchor="middle"
                                        class="text-[10px] fill-text-muted font-medium"
                                    >
                                        {point.year}
                                    </text>
                                ))}
                            </svg>
                        </div>
                    ) : (
                        <p class="text-text-secondary">
                            Nenhuma série histórica disponível para este recorte.
                        </p>
                    )
                }
            </section>
        </div>

        <div
            id="publications-panel-types"
            role="tabpanel"
            aria-labelledby="publications-tab-types"
            class="hidden transition-all duration-300 opacity-0 scale-95"
        >
            <section class="glass-card p-6">
                <header class="mb-6">
                    <h3 class="text-xl font-bold font-['Outfit'] text-text-main">
                        Distribuição por Tipo
                    </h3>
                    <p class="text-sm text-text-secondary mt-1">
                        Peso relativo entre periódicos e eventos.
                    </p>
                </header>

                <div class="space-y-4">
                    {typeDistribution.map((item: any) => {
                        const total = martData.summary.total_publications || 1;
                        const width = Math.round((item.value / total) * 100);
                        return (
                            <div class="space-y-2">
                                <div class="flex items-center justify-between gap-4">
                                    <div class="flex items-center gap-3">
                                        <span
                                            class="w-3 h-3 rounded-full"
                                            style={`background:${item.color}`}
                                        ></span>
                                        <span class="text-sm font-semibold text-text-main">
                                            {item.label}
                                        </span>
                                    </div>
                                    <span class="text-xs font-bold text-text-secondary">
                                        {item.value} ({width}%)
                                    </span>
                                </div>
                                <div class="h-3 rounded-full bg-white/5 overflow-hidden">
                                    <div
                                        class="h-full rounded-full"
                                        style={`width:${width}%; background:${item.color}`}
                                    ></div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </section>
        </div>

        <div
            id="publications-panel-venues"
            role="tabpanel"
            aria-labelledby="publications-tab-venues"
            class="hidden transition-all duration-300 opacity-0 scale-95"
        >
            <section class="glass-card p-6">
                <header class="mb-6">
                    <h3 class="text-xl font-bold font-['Outfit'] text-text-main">
                        Veículos em Destaque
                    </h3>
                    <p class="text-sm text-text-secondary mt-1">
                        Periódicos e eventos com maior recorrência.
                    </p>
                </header>

                <div class="space-y-4">
                    {topVenues.map((venue: any) => {
                        const width = Math.max(
                            8,
                            Math.round((venue.count / maxVenueCount) * 100),
                        );
                        return (
                            <div class="space-y-2">
                                <div class="flex items-start justify-between gap-4">
                                    <p class="text-sm font-semibold text-text-main leading-snug">
                                        {venue.name}
                                    </p>
                                    <span class="text-xs font-bold text-text-secondary whitespace-nowrap">
                                        {venue.count}
                                    </span>
                                </div>
                                <div class="h-2 rounded-full bg-white/5 overflow-hidden">
                                    <div
                                        class="h-full rounded-full bg-gradient-to-r from-premium-accent to-premium-purple"
                                        style={`width:${width}%`}
                                    ></div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </section>
        </div>
    </div>
</div>

<script>
    const setupPublicationsTabs = () => {
        document.querySelectorAll("[data-publications-tabs]").forEach((root) => {
            const tabs = root.querySelectorAll('[role="tab"]');
            const panels = root.querySelectorAll('[role="tabpanel"]');

            tabs.forEach((tab) => {
                tab.addEventListener("click", () => {
                    const targetId = tab.getAttribute("aria-controls");

                    tabs.forEach((item) => {
                        item.setAttribute("aria-selected", "false");
                        item.className =
                            "pb-3 md:pb-4 text-xs md:text-sm font-bold tracking-wide transition-all relative cursor-pointer text-text-muted hover:text-text-main border-b-2 border-transparent whitespace-nowrap";
                    });

                    tab.setAttribute("aria-selected", "true");
                    tab.className =
                        "pb-3 md:pb-4 text-xs md:text-sm font-bold tracking-wide transition-all relative cursor-pointer text-premium-accent border-b-2 border-premium-accent whitespace-nowrap";

                    panels.forEach((panel) => {
                        if (panel.id === targetId) {
                            panel.classList.remove("hidden");
                            requestAnimationFrame(() => {
                                panel.classList.add("opacity-100", "scale-100");
                                panel.classList.remove("opacity-0", "scale-95");
                            });
                        } else {
                            panel.classList.add("hidden", "opacity-0", "scale-95");
                            panel.classList.remove("opacity-100", "scale-100");
                        }
                    });
                });
            });
        });
    };

    setupPublicationsTabs();
    document.addEventListener("astro:after-swap", setupPublicationsTabs);
</script>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }

    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
