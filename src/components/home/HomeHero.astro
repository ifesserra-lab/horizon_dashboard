---
// Assinatura da home: publicações por ano (dado canônico), como uma
// área suave preenchida em verde Ifes, com o ano de pico destacado.
// Sem ECharts (o projeto não usa a lib) — SVG, no mesmo padrão de HomeCharts.
// Cores só via token; animação respeita reduzir-movimento (regra global).
import {
	getAggregatedPublications,
	buildPublicationsMart,
} from "../../lib/publications-data";

const mart = buildPublicationsMart(getAggregatedPublications());
let series = mart.evolution.filter((d) => Number.isFinite(d.year));
// Recorta a cauda inicial esparsa: no máximo os últimos 25 anos.
if (series.length > 25) series = series.slice(series.length - 25);

const total = mart.summary.total_publications;
const maxCount = Math.max(...series.map((d) => d.count), 1);
const peak = series.reduce((a, b) => (b.count > a.count ? b : a), series[0]);
const firstYear = series.length ? series[0].year : null;
const lastYear = series.length ? series[series.length - 1].year : null;

// Geometria do SVG
const W = 800;
const H = 130;
const padX = 10;
const padTop = 26; // espaço para o rótulo do pico
const padBottom = 22; // espaço para os anos
const plotH = H - padTop - padBottom;
const stepX = series.length > 1 ? (W - padX * 2) / (series.length - 1) : 0;

const pts = series.map((d, i) => ({
	x: padX + i * stepX,
	y: padTop + (1 - d.count / maxCount) * plotH,
	...d,
}));

// Curva suave (Catmull-Rom -> Bézier cúbica)
function smoothPath(points: { x: number; y: number }[]): string {
	if (points.length === 0) return "";
	if (points.length === 1) return `M ${points[0].x} ${points[0].y}`;
	let d = `M ${points[0].x} ${points[0].y}`;
	for (let i = 0; i < points.length - 1; i++) {
		const p0 = points[i - 1] || points[i];
		const p1 = points[i];
		const p2 = points[i + 1];
		const p3 = points[i + 2] || p2;
		const c1x = p1.x + (p2.x - p0.x) / 6;
		const c1y = p1.y + (p2.y - p0.y) / 6;
		const c2x = p2.x - (p3.x - p1.x) / 6;
		const c2y = p2.y - (p3.y - p1.y) / 6;
		d += ` C ${c1x} ${c1y}, ${c2x} ${c2y}, ${p2.x} ${p2.y}`;
	}
	return d;
}

const linePath = smoothPath(pts);
const areaPath = pts.length
	? `${linePath} L ${pts[pts.length - 1].x} ${H - padBottom} L ${pts[0].x} ${H - padBottom} Z`
	: "";
const peakPt = pts.find((p) => p.year === peak?.year);

const ariaLabel =
	firstYear && lastYear
		? `Publicações por ano, de ${firstYear} a ${lastYear}. Total de ${total}. Pico em ${peak.year}, com ${peak.count}.`
		: "Publicações por ano.";

const pubUrl = `${import.meta.env.BASE_URL}publications`;
const plural = (n: number) => (n === 1 ? "publicação" : "publicações");
---

{
	series.length > 1 && (
		<figure class="home-hero not-sr-only" role="img" aria-label={ariaLabel}>
			<div class="home-hero-head">
				<span class="hero-title">Publicações por ano</span>
				<a class="hero-total" href={pubUrl}
					>{total.toLocaleString("pt-BR")} no total →</a
				>
			</div>
			<div class="hero-plot">
			<svg
				viewBox={`0 0 ${W} ${H}`}
				preserveAspectRatio="none"
				class="w-full h-28 md:h-32 overflow-visible"
				aria-hidden="true"
			>
				<defs>
					<linearGradient id="heroFill" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="var(--color-brand-green)" stop-opacity="0.28" />
						<stop offset="100%" stop-color="var(--color-brand-green)" stop-opacity="0" />
					</linearGradient>
				</defs>

				{/* linha de base */}
				<line
					x1={padX}
					y1={H - padBottom}
					x2={W - padX}
					y2={H - padBottom}
					stroke="var(--color-border-main)"
					stroke-width="1"
				/>

				{/* área preenchida */}
				<path class="hero-area" d={areaPath} fill="url(#heroFill)" />

				{/* linha */}
				<path
					class="hero-line"
					d={linePath}
					fill="none"
					stroke="var(--color-brand-green)"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					vector-effect="non-scaling-stroke"
				/>

				{/* marcador do ano de pico (amarelo da faixa) */}
				{peakPt && (
					<g class="hero-peak">
						<line
							x1={peakPt.x}
							y1={peakPt.y}
							x2={peakPt.x}
							y2={H - padBottom}
							stroke="var(--color-brand-yellow)"
							stroke-width="1.5"
							stroke-dasharray="2 3"
							opacity="0.7"
						/>
						<circle
							cx={peakPt.x}
							cy={peakPt.y}
							r="4.5"
							fill="var(--color-brand-yellow)"
							stroke="var(--color-surface)"
							stroke-width="2"
						/>
					</g>
				)}
			</svg>
			{/* colunas de hover: tooltip por ano + clique leva a Publicações */}
			<div class="hero-cols">
				{series.map((d) => (
					<a
						class="hero-col"
						href={pubUrl}
						title={`${d.year}: ${d.count} ${plural(d.count)}`}
						aria-label={`${d.year}: ${d.count} ${plural(d.count)}. Ver publicações.`}
					/>
				))}
			</div>
			</div>

			{/* rótulos textuais (fonte mono), fora do SVG para não distorcer */}
			<figcaption class="home-hero-caption">
				<span class="hero-range">
					{firstYear}–{lastYear}
				</span>
				<span class="hero-peak-label">
					pico {peak.year}: {peak.count}
				</span>
			</figcaption>
		</figure>
	)
}

<style>
	.home-hero {
		margin-top: 2rem;
		padding: 1rem 1.25rem 0.75rem;
		border: 1px solid var(--border-primary);
		border-radius: 1rem;
		background: var(--surface);
	}
	.home-hero-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.5rem;
	}
	.hero-title {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-secondary);
	}
	.hero-total {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: var(--brand-green-dark);
		text-decoration: none;
		transition: color 0.15s;
	}
	.hero-total:hover {
		color: var(--color-premium-accent);
	}

	/* Interação: colunas de hover sobre o gráfico */
	.hero-plot {
		position: relative;
	}
	.hero-cols {
		position: absolute;
		inset: 0;
		display: flex;
		gap: 1px;
	}
	.hero-col {
		flex: 1;
		border-radius: 3px;
		transition: background 0.12s;
	}
	.hero-col:hover,
	.hero-col:focus-visible {
		background: color-mix(in srgb, var(--brand-green) 10%, transparent);
		outline: none;
	}
	.home-hero-caption {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.02em;
		color: var(--text-secondary);
		margin-top: 0.25rem;
	}
	.hero-peak-label {
		color: var(--brand-green-dark);
	}

	/* Animação de entrada — desenha a linha e revela a área. */
	.hero-line {
		stroke-dasharray: 2000;
		stroke-dashoffset: 2000;
		animation: hero-draw 1.6s ease-out forwards;
	}
	.hero-area {
		opacity: 0;
		animation: hero-reveal 1.2s ease-out 0.4s forwards;
	}
	.hero-peak {
		opacity: 0;
		animation: hero-reveal 0.5s ease-out 1.4s forwards;
	}
	@keyframes hero-draw {
		to {
			stroke-dashoffset: 0;
		}
	}
	@keyframes hero-reveal {
		to {
			opacity: 1;
		}
	}

	/* Reduzir movimento: sem animação, estado final imediato. */
	:global(:root.reduce-motion) .hero-line,
	:global(:root.reduce-motion) .hero-area,
	:global(:root.reduce-motion) .hero-peak {
		animation: none;
		stroke-dashoffset: 0;
		opacity: 1;
	}
	@media (prefers-reduced-motion: reduce) {
		.hero-line,
		.hero-area,
		.hero-peak {
			animation: none;
			stroke-dashoffset: 0;
			opacity: 1;
		}
	}
</style>
