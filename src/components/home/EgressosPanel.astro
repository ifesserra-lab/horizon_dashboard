---
import egressos from "../../data/egressos_summary.json";

const e = egressos as any;
const p = e.pipeline ?? {};
const nf = (v: number) => new Intl.NumberFormat("pt-BR").format(v);
const durMonths = e.dur_median_dias ? (e.dur_median_dias / 30).toFixed(0) : null;

const kpis = [
    { value: nf(e.total ?? 0), label: "Formandos analisados", hint: "coortes com dados" },
    { value: `${e.pct_research ?? 0}%`, label: "Com pesquisa", hint: `${nf(e.with_research ?? 0)} fizeram IC/TCC` },
    { value: `${p.both_pct ?? 0}%`, label: "Pipeline IC → TCC", hint: `${nf(p.both ?? 0)} fizeram IC e TCC` },
    { value: `${p.same_sup_pct ?? 0}%`, label: "Mesmo orientador", hint: "continuidade IC→TCC" },
];

const cursos = (e.cursos ?? []) as { curso: string; n: number }[];
const maxCurso = Math.max(...cursos.map((c) => c.n), 1);
---

<section aria-labelledby="egr-title" class="py-4">
    <div class="flex items-baseline justify-between border-b border-border-main pb-3 mb-6">
        <h2 id="egr-title" class="font-display text-xl font-bold text-text-main">
            Formação & egressos
        </h2>
        <span class="text-xs text-text-muted">pesquisa na graduação</span>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-border-main border border-border-main mb-8">
        {
            kpis.map((kpi) => (
                <div class="bg-page-bg p-4">
                    <div class="font-display text-2xl font-bold text-text-main tabular-nums">
                        {kpi.value}
                    </div>
                    <div class="text-xs font-medium text-text-main mt-1">{kpi.label}</div>
                    <div class="text-[11px] text-text-muted mt-0.5">{kpi.hint}</div>
                </div>
            ))
        }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div>
            <h3 class="text-xs uppercase tracking-wider text-text-muted mb-4">
                Formandos por curso
            </h3>
            <div class="space-y-2.5">
                {
                    cursos.map((c) => (
                        <div>
                            <div class="flex items-baseline justify-between gap-3 text-sm">
                                <span class="text-text-main truncate">{c.curso}</span>
                                <span class="tabular-nums text-text-muted flex-none">{c.n}</span>
                            </div>
                            <div class="mt-1 h-1 bg-border-main">
                                <div
                                    class="h-full bg-premium-accent/70"
                                    style={`width:${(c.n / maxCurso) * 100}%`}
                                />
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
        <div class="text-sm text-text-muted leading-relaxed self-center">
            <p>
                <b class="text-text-main">{e.pct_research ?? 0}%</b> dos formandos
                passaram por pesquisa (IC ou TCC), e
                <b class="text-text-main">{p.both_pct ?? 0}%</b> completaram o
                caminho <b class="text-text-main">IC → TCC</b> — quase sempre com o
                <b class="text-text-main"> mesmo orientador</b> ({p.same_sup_pct ?? 0}%),
                sinal de vínculos de pesquisa que se sustentam.
                {durMonths && (
                    <> Tempo mediano entre IC e TCC: ~{durMonths} meses.</>
                )}
            </p>
        </div>
    </div>
</section>
