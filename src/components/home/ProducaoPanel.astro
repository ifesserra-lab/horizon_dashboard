---
import articles from "../../data/articles_canonical.json";
import kaMart from "../../data/knowledge_areas_mart.json";
import productions from "../../data/research_productions_canonical.json";
import prodTypes from "../../data/production_types_canonical.json";

const nf = (v: number) => new Intl.NumberFormat("pt-BR").format(v);

// Articles per year (from 2015)
const yearCount: Record<number, number> = {};
for (const a of articles as any[]) {
    const y = Number(a.year);
    if (y >= 2015 && y <= 2026) yearCount[y] = (yearCount[y] || 0) + 1;
}
const years = Object.keys(yearCount)
    .map(Number)
    .sort((a, b) => a - b)
    .map((y) => ({ ano: y, n: yearCount[y] }));
const maxYear = Math.max(...years.map((y) => y.n), 1);

// Top knowledge areas by group count
const topAreas = (kaMart as any[])
    .filter((a) => (a.groups_count || 0) > 0)
    .sort((a, b) => (b.groups_count || 0) - (a.groups_count || 0))
    .slice(0, 8);
const maxArea = Math.max(...topAreas.map((a) => a.groups_count || 0), 1);

// Technical production by type
const typeName: Record<string, string> = {};
for (const t of prodTypes as any[]) typeName[String(t.id)] = t.name;
const TYPE_LABELS: Record<string, string> = {
    softwares_sem_patente: "Software",
    softwares_com_patente: "Software (patente)",
    produtos_tecnologicos: "Produto tecnológico",
    processos_tecnicas: "Processo/técnica",
    trabalhos_tecnicos: "Trabalho técnico",
    outras_producoes_tecnicas: "Outras",
    entrevistas: "Entrevista/mídia",
    patentes: "Patente",
    programas_computador: "Programa de computador",
    desenhos_industriais: "Desenho industrial",
};
const techCount: Record<string, number> = {};
for (const p of productions as any[]) {
    const slug = typeName[String(p.production_type_id)] || "outras";
    const label = TYPE_LABELS[slug] || slug;
    techCount[label] = (techCount[label] || 0) + 1;
}
const techList = Object.entries(techCount).sort((a, b) => b[1] - a[1]);

const kpis = [
    { value: nf((articles as any[]).length), label: "Artigos científicos", hint: "periódicos + eventos" },
    { value: nf((productions as any[]).length), label: "Produção técnica", hint: "softwares, patentes, produtos" },
    { value: nf(topAreas.length ? (kaMart as any[]).filter((a) => a.groups_count > 0).length : 0), label: "Áreas com grupos", hint: "áreas de conhecimento ativas" },
];
---

<section aria-labelledby="prod-title" class="py-4">
    <div class="flex items-baseline justify-between border-b border-border-main pb-3 mb-6">
        <h2 id="prod-title" class="font-display text-xl font-bold text-text-main">
            Produção & áreas
        </h2>
        <span class="text-xs text-text-muted">Lattes · grupos</span>
    </div>

    <div class="grid grid-cols-3 gap-px bg-border-main border border-border-main mb-8">
        {
            kpis.map((kpi) => (
                <div class="bg-page-bg p-4">
                    <div class="font-display text-2xl font-bold text-text-main tabular-nums">
                        {kpi.value}
                    </div>
                    <div class="text-xs font-medium text-text-main mt-1">{kpi.label}</div>
                    <div class="text-[11px] text-text-muted mt-0.5">{kpi.hint}</div>
                </div>
            ))
        }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Articles per year -->
        <div>
            <h3 class="text-xs uppercase tracking-wider text-text-muted mb-4">
                Artigos publicados por ano
            </h3>
            <div class="flex items-end gap-1.5">
                {
                    years.map((y) => (
                        <div class="flex-1 flex flex-col items-center gap-1 group">
                            <div class="w-full h-24 flex items-end bg-track">
                                <div
                                    class="w-full bg-brand-green/70 group-hover:bg-brand-green transition-colors"
                                    style={`height:${Math.max(4, (y.n / maxYear) * 96)}px`}
                                    title={`${y.ano}: ${y.n}`}
                                />
                            </div>
                            <span class="text-[10px] text-text-muted tabular-nums">
                                {String(y.ano).slice(2)}
                            </span>
                        </div>
                    ))
                }
            </div>
            {
                techList.length > 0 && (
                    <div class="mt-6">
                        <h3 class="text-xs uppercase tracking-wider text-text-muted mb-2">
                            Produção técnica por tipo
                        </h3>
                        <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm">
                            {techList.map(([label, n]) => (
                                <span class="text-text-muted">
                                    {label}{" "}
                                    <b class="text-text-main tabular-nums">{n}</b>
                                </span>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>

        <!-- Top areas -->
        <div>
            <h3 class="text-xs uppercase tracking-wider text-text-muted mb-4">
                Áreas com mais grupos
            </h3>
            <div class="space-y-2.5">
                {
                    topAreas.map((a) => (
                        <div>
                            <div class="flex items-baseline justify-between gap-3 text-sm">
                                <span class="text-text-main truncate">{a.area_name}</span>
                                <span class="tabular-nums text-text-muted flex-none">
                                    {a.groups_count}
                                </span>
                            </div>
                            <div class="mt-1 h-1 bg-track">
                                <div
                                    class="h-full bg-premium-accent/70"
                                    style={`width:${(a.groups_count / maxArea) * 100}%`}
                                />
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
