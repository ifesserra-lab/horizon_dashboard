---
import facto from "../../data/facto_summary.json";

const d = facto as any;

const brl = (v: number) =>
    new Intl.NumberFormat("pt-BR", {
        style: "currency",
        currency: "BRL",
        maximumFractionDigits: v >= 1_000_000 ? 1 : 0,
        notation: v >= 1_000_000 ? "compact" : "standard",
    }).format(v);
const nf = (v: number) => new Intl.NumberFormat("pt-BR").format(v);

const kpis = [
    { value: brl(d.valor_total_aprovado), label: "Valor aprovado", hint: "soma dos projetos FACTO" },
    { value: nf(d.projetos), label: "Projetos", hint: "convênios, contratos, PD&I…" },
    { value: nf(d.financiadoras), label: "Parceiros financiadores", hint: "empresas e órgãos" },
    { value: nf(d.coordenadores_unicos), label: "Coordenadores", hint: "docentes à frente" },
];

const years = d.por_ano as { ano: number; n: number }[];
const maxYear = Math.max(...years.map((y) => y.n), 1);
const topFin = (d.top_financiadoras as { nome: string; projetos: number; valor: number }[]).slice(0, 6);
const maxFin = Math.max(...topFin.map((f) => f.valor), 1);
---

<section aria-labelledby="fomento-title" class="py-4">
    <div class="flex items-baseline justify-between border-b border-border-main pb-3 mb-6">
        <h2 id="fomento-title" class="font-display text-xl font-bold text-text-main">
            Fomento & captação
        </h2>
        <span class="text-xs text-text-muted">FACTO · fundação de apoio</span>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-border-main border border-border-main">
        {
            kpis.map((kpi) => (
                <div class="bg-page-bg p-4">
                    <div class="font-display text-2xl font-bold text-text-main tabular-nums">
                        {kpi.value}
                    </div>
                    <div class="text-xs font-medium text-text-main mt-1">{kpi.label}</div>
                    <div class="text-[11px] text-text-muted mt-0.5">{kpi.hint}</div>
                </div>
            ))
        }
    </div>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Projetos por ano — minimalist bar series -->
        <div>
            <h3 class="text-xs uppercase tracking-wider text-text-muted mb-4">
                Projetos iniciados por ano
            </h3>
            <div class="flex items-end gap-1.5">
                {
                    years.map((y) => (
                        <div class="flex-1 flex flex-col items-center gap-1 group">
                            <div class="w-full h-24 flex items-end bg-track">
                                <div
                                    class="w-full bg-brand-green/70 group-hover:bg-brand-green transition-colors"
                                    style={`height:${Math.max(4, (y.n / maxYear) * 96)}px`}
                                    title={`${y.ano}: ${y.n} projetos`}
                                />
                            </div>
                            <span class="text-[10px] text-text-muted tabular-nums">
                                {String(y.ano).slice(2)}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Top financiadores — hairline rows with value bar -->
        <div>
            <h3 class="text-xs uppercase tracking-wider text-text-muted mb-4">
                Principais financiadores
            </h3>
            <div class="space-y-2.5">
                {
                    topFin.map((f) => (
                        <div>
                            <div class="flex items-baseline justify-between gap-3 text-sm">
                                <span class="text-text-main truncate">{f.nome}</span>
                                <span class="tabular-nums text-text-muted flex-none">
                                    {brl(f.valor)} · {f.projetos}
                                </span>
                            </div>
                            <div class="mt-1 h-1 bg-track">
                                <div
                                    class="h-full bg-premium-accent/70"
                                    style={`width:${(f.valor / maxFin) * 100}%`}
                                />
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
