---
import Layout from "../../layouts/Layout.astro";
import initiativesData from "../../data/initiatives_canonical.json";
import advisorshipsData from "../../data/advisorships_canonical.json";
import type { Researcher } from "../../types/researchers";
import {
    getAttributeSources,
    toInlineSourceItems,
} from "../../lib/provenance";
import {
    enrichResearcherInitiatives,
    getStudentAdvisors,
    getStudentFellowships,
    type CanonicalAdvisorshipProjectRecord,
    type CanonicalInitiativeRecord,
} from "../../lib/researcher-profiles";
import { studentsResearchers } from "../../lib/researcher-collections";
import ResearcherProfileHeader from "../../components/researchers/ResearcherProfileHeader.astro";
import ResearcherProfileGroups from "../../components/researchers/ResearcherProfileGroups.astro";
import ResearcherProfileInitiatives from "../../components/researchers/ResearcherProfileInitiatives.astro";
import StudentProfileAdvisors from "../../components/researchers/StudentProfileAdvisors.astro";
import StudentProfileFellowships from "../../components/researchers/StudentProfileFellowships.astro";

export function getStaticPaths() {
    return studentsResearchers.map((student) => ({
        params: { id: student.id.toString() },
        props: { student },
    }));
}

interface Props {
    student: Researcher;
}

const { student } = Astro.props;
const canonicalInitiatives = initiativesData as CanonicalInitiativeRecord[];
const canonicalAdvisorshipProjects =
    advisorshipsData as CanonicalAdvisorshipProjectRecord[];
const enrichedStudent = {
    ...student,
    initiatives: enrichResearcherInitiatives(student, canonicalInitiatives),
};
const studentAdvisors = getStudentAdvisors(
    student,
    canonicalInitiatives,
    canonicalAdvisorshipProjects,
);
const studentFellowships = getStudentFellowships(
    student,
    canonicalAdvisorshipProjects,
    canonicalInitiatives,
);

const profileHeaderSources = toInlineSourceItems([
    ...getAttributeSources("researcher", student.id, [
        "name",
        "identification_id",
        "cnpq_url",
        "google_scholar_url",
    ]),
    ...student.knowledge_areas.flatMap((area) =>
        getAttributeSources("knowledge_area", area.id, ["name"]),
    ),
]);

const groupSourcesById = Object.fromEntries(
    student.research_groups.map((group) => [
        String(group.id),
        toInlineSourceItems(
            getAttributeSources("research_group", group.id, ["name"]),
        ),
    ]),
);

const initiativeSourcesById = Object.fromEntries(
    enrichedStudent.initiatives.map((initiative) => [
        String(initiative.id),
        toInlineSourceItems(
            getAttributeSources("initiative", initiative.id, [
                "name",
                "status",
                "start_date",
                "end_date",
            ]),
        ),
    ]),
);

const highlightCards = [
    {
        label: "Grupos de pesquisa",
        value: enrichedStudent.research_groups.length,
        description: "vínculos registrados para o estudante",
        accentClass: "text-premium-accent",
        surfaceClass: "bg-premium-accent/8 border-premium-accent/20",
    },
    {
        label: "Iniciativas",
        value: enrichedStudent.initiatives.length,
        description: "projetos e orientações vinculadas",
        accentClass: "text-emerald-500",
        surfaceClass: "bg-emerald-500/8 border-emerald-500/20",
    },
    {
        label: "Bolsas",
        value: studentFellowships.length,
        description: "bolsas registradas no dataset de orientações",
        accentClass: "text-premium-purple",
        surfaceClass: "bg-premium-purple/8 border-premium-purple/20",
    },
    {
        label: "Orientadores",
        value: studentAdvisors.length,
        description: "nomes derivados do export canônico",
        accentClass: "text-amber-500",
        surfaceClass: "bg-amber-500/8 border-amber-500/20",
    },
];
---

<Layout
    title={student.name}
    breadcrumbReplacements={{
        students: "Estudantes",
        [student.id]: student.name,
    }}
>
    <div class="space-y-8 pb-16">
        <nav aria-label="Voltar para estudantes">
            <a
                href={`${import.meta.env.BASE_URL}students`}
                class="inline-flex items-center gap-2 text-sm font-bold text-text-secondary hover:text-premium-accent transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="m15 18-6-6 6-6"></path>
                </svg>
                Voltar para estudantes
            </a>
        </nav>

        <section class="glass-card p-6 md:p-8 border border-border-main space-y-5">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-premium-accent mb-2">
                        Perfil discente
                    </p>
                    <h2 class="text-3xl md:text-4xl font-bold font-['Outfit'] text-text-main">
                        Trajetória em pesquisa
                    </h2>
                    <p class="text-text-secondary mt-3 max-w-3xl">
                        Esta visualização destaca os vínculos do estudante com
                        grupos de pesquisa, iniciativas e orientadores a partir
                        do recorte <code>students_canonical</code>.
                    </p>
                </div>

                <div class="inline-flex items-center gap-2 px-3 py-2 rounded-full bg-premium-purple/10 border border-premium-purple/20 text-xs font-bold uppercase tracking-wider text-premium-purple">
                    <span class="w-2 h-2 rounded-full bg-premium-purple"></span>
                    Classificação estudante
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                {highlightCards.map((card) => (
                    <article class={`rounded-3xl border p-5 ${card.surfaceClass}`}>
                        <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-text-secondary">
                            {card.label}
                        </p>
                        <div class={`mt-3 text-4xl font-extrabold font-['Outfit'] ${card.accentClass}`}>
                            {card.value}
                        </div>
                        <p class="mt-2 text-sm text-text-secondary">
                            {card.description}
                        </p>
                    </article>
                ))}
            </div>
        </section>

        <ResearcherProfileHeader
            researcher={enrichedStudent}
            sources={profileHeaderSources}
        />

        <StudentProfileFellowships fellowships={studentFellowships} />

        <StudentProfileAdvisors advisors={studentAdvisors} />

        <ResearcherProfileGroups
            researcher={enrichedStudent}
            groupSourcesById={groupSourcesById}
        />

        <ResearcherProfileInitiatives
            researcher={enrichedStudent}
            initiativeSourcesById={initiativeSourcesById}
            incrementalLoading={false}
        />
    </div>
</Layout>
