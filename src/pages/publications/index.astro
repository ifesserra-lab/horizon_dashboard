---
import Layout from "../../layouts/Layout.astro";
import KpiCard from "../../components/KpiCard.astro";
import PublicationsCharts from "../../components/charts/PublicationsCharts.astro";
import {
    buildPublicationsMart,
    getAggregatedPublications,
    getPublicationsByCampusId,
    getCampusPublicationViews,
} from "../../lib/publications-data";

const title = "Produção Acadêmica | Horizon Dashboard";
const description =
    "Dashboard de indicadores de publicações e artigos publicados pelos pesquisadores.";

const allPublications = getAggregatedPublications();
const publicationsMart = buildPublicationsMart(allPublications);
const campusViews = getCampusPublicationViews();

const publicationIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`;
const journalIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M16 12h2"/><path d="M16 8h2"/><path d="M3 18c0-1 .6-1.9 1.5-2.4l7-4.1c1-.6 2.2-.6 3.2 0l7 4.1c.9.5 1.5 1.4 1.5 2.4"/><path d="M3 6c0-1 .6-1.9 1.5-2.4l7-4.1c1-.6 2.2-.6 3.2 0l7 4.1c.9.5 1.5 1.4 1.5 2.4"/></svg>`;
const conferenceIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>`;
const researchersIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><circle cx="19" cy="11" r="3"/></svg>`;
const venueIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h20"/><path d="M5 7V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2"/><path d="M6 11v6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M18 11v6"/><path d="M4 21h16"/></svg>`;

const uniqueYears = [
    ...new Set(
        allPublications
            .map((publication) => Number(publication.year))
            .filter((year) => Number.isFinite(year)),
    ),
].sort((a, b) => b - a);

const buildResearcherOptions = (publications: typeof allPublications) => {
    const authors = new Map<string, { id: string; name: string }>();

    publications.forEach((publication) => {
        publication.authors.forEach((author) => {
            if (!authors.has(author.id)) {
                authors.set(author.id, {
                    id: author.id,
                    name: author.name,
                });
            }
        });
    });

    return [...authors.values()].sort((a, b) => a.name.localeCompare(b.name));
};

const buildPublicationYears = (publications: typeof allPublications) =>
    [
        ...new Set(
            publications
                .map((publication) => Number(publication.year))
                .filter((year) => Number.isFinite(year)),
        ),
    ].sort((a, b) => b - a);

const researchersWithPublications = buildResearcherOptions(allPublications);
const publicationsCatalogByCampus = {
    "": {
        total: allPublications.length,
        researchers: researchersWithPublications,
        years: uniqueYears,
        keywords: publicationsMart.top_keywords,
    },
    ...Object.fromEntries(
        Object.keys(campusViews).map((campusId) => {
            const campusPublications = getPublicationsByCampusId(campusId);

            return [
                campusId,
                {
                    total: campusPublications.length,
                    researchers: buildResearcherOptions(campusPublications),
                    years: buildPublicationYears(campusPublications),
                    keywords: campusViews[campusId].top_keywords,
                },
            ];
        }),
    ),
};
---

<Layout
    title={title}
    description={description}
    breadcrumbReplacements={{ publications: "Publicações" }}
>
    <div class="space-y-8 animate-fade-in pb-12">
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h1 class="text-4xl font-extrabold font-['Outfit'] tracking-tight text-text-main mt-4">
                    Produção <span class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple">Acadêmica</span>
                </h1>
                <p class="text-text-secondary mt-2 max-w-2xl">
                    Explore os artigos publicados pelos pesquisadores e acompanhe a produção científica do portal.
                </p>
            </div>
        </header>

        <hr class="border-white/10" />

        <main>
            <div id="publications-dashboard-views" class="space-y-8">
                <div data-campus-view="" class="space-y-8">
                    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-5 gap-6">
                        <KpiCard
                            title="Publicações"
                            value={publicationsMart.summary.total_publications}
                            icon={publicationIcon}
                            color="premium-accent"
                        />
                        <KpiCard
                            title="Periódicos"
                            value={publicationsMart.summary.journal_publications}
                            icon={journalIcon}
                            color="sky-500"
                        />
                        <KpiCard
                            title="Eventos"
                            value={publicationsMart.summary.conference_publications}
                            icon={conferenceIcon}
                            color="premium-purple"
                        />
                        <KpiCard
                            title="Autores"
                            value={publicationsMart.summary.unique_researchers}
                            icon={researchersIcon}
                            color="emerald-500"
                        />
                        <KpiCard
                            title="Veículos"
                            value={publicationsMart.summary.unique_venues}
                            icon={venueIcon}
                            color="amber-500"
                        />
                    </div>

                    <PublicationsCharts martData={publicationsMart} />
                </div>

                {
                    Object.entries(campusViews).map(([campusId, martData]) => (
                        <div data-campus-view={campusId} class="space-y-8 hidden">
                            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-5 gap-6">
                                <KpiCard
                                    title="Publicações"
                                    value={martData.summary.total_publications}
                                    icon={publicationIcon}
                                    color="premium-accent"
                                />
                                <KpiCard
                                    title="Periódicos"
                                    value={martData.summary.journal_publications}
                                    icon={journalIcon}
                                    color="sky-500"
                                />
                                <KpiCard
                                    title="Eventos"
                                    value={martData.summary.conference_publications}
                                    icon={conferenceIcon}
                                    color="premium-purple"
                                />
                                <KpiCard
                                    title="Autores"
                                    value={martData.summary.unique_researchers}
                                    icon={researchersIcon}
                                    color="emerald-500"
                                />
                                <KpiCard
                                    title="Veículos"
                                    value={martData.summary.unique_venues}
                                    icon={venueIcon}
                                    color="amber-500"
                                />
                            </div>

                            <PublicationsCharts martData={martData} />
                        </div>
                    ))
                }
            </div>

            <section class="space-y-6">
                <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
                    <div>
                        <h2 class="text-2xl font-bold font-['Outfit'] text-text-main">
                            Explorar Publicações
                        </h2>
                        <p class="text-text-secondary mt-1">
                            Busque por título, autor, veículo, ano ou tipo de publicação.
                        </p>
                    </div>
                    <div
                        id="publicationsCountLabel"
                        class="text-xs font-bold uppercase tracking-[0.2em] text-text-muted"
                        data-total={allPublications.length}
                    >
                        {allPublications.length} publicações
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr),220px,180px,220px] gap-4">
                    <div class="relative">
                        <label for="publicationSearch" class="sr-only">
                            Buscar publicações
                        </label>
                        <input
                            type="text"
                            id="publicationSearch"
                            placeholder="Buscar por título, autor ou veículo..."
                            class="w-full bg-glass-bg border border-border-main rounded-2xl px-12 py-4 text-sm focus:outline-none focus:ring-2 focus:ring-premium-accent/50 focus:border-premium-accent transition-all text-text-main shadow-lg shadow-premium-accent/5"
                        />
                        <svg
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-text-secondary"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="11" cy="11" r="8"></circle>
                            <path d="m21 21-4.3-4.3"></path>
                        </svg>
                    </div>

                    <div>
                        <label for="publicationResearcherFilter" class="sr-only">
                            Filtrar por pesquisador
                        </label>
                        <select
                            id="publicationResearcherFilter"
                            class="w-full bg-glass-bg border border-border-main rounded-2xl px-4 py-4 text-sm focus:outline-none focus:ring-2 focus:ring-premium-accent/50 focus:border-premium-accent transition-all text-text-main"
                        >
                            <option value="">Todos os pesquisadores</option>
                            {
                                researchersWithPublications.map((researcher) => (
                                    <option value={researcher.id}>
                                        {researcher.name}
                                    </option>
                                ))
                            }
                        </select>
                    </div>

                    <div>
                        <label for="publicationTypeFilter" class="sr-only">
                            Filtrar por tipo
                        </label>
                        <select
                            id="publicationTypeFilter"
                            class="w-full bg-glass-bg border border-border-main rounded-2xl px-4 py-4 text-sm focus:outline-none focus:ring-2 focus:ring-premium-accent/50 focus:border-premium-accent transition-all text-text-main"
                        >
                            <option value="">Todos os tipos</option>
                            <option value="Journal">Periódicos</option>
                            <option value="Conference Event">Eventos</option>
                        </select>
                    </div>

                    <div>
                        <label for="publicationYearFilter" class="sr-only">
                            Filtrar por ano
                        </label>
                        <select
                            id="publicationYearFilter"
                            class="w-full bg-glass-bg border border-border-main rounded-2xl px-4 py-4 text-sm focus:outline-none focus:ring-2 focus:ring-premium-accent/50 focus:border-premium-accent transition-all text-text-main"
                        >
                            <option value="">Todos os anos</option>
                            {
                                uniqueYears.map((year) => (
                                    <option value={year}>{year}</option>
                                ))
                            }
                        </select>
                    </div>
                </div>

                <div class="glass-card p-5 space-y-4">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-text-muted">
                                Palavras-chave
                            </h3>
                            <p class="text-sm text-text-secondary mt-1">
                                Clique em uma palavra para filtrar as publicações.
                            </p>
                        </div>
                        <button
                            id="clearKeywordFilter"
                            class="text-xs font-bold text-premium-accent hover:text-premium-accent/80 transition-colors"
                            type="button"
                        >
                            Limpar palavra-chave
                        </button>
                    </div>

                    <div id="publicationKeywordList" class="flex flex-wrap gap-2">
                        {
                            publicationsMart.top_keywords.map((item) => (
                                <button
                                    type="button"
                                    class="publication-keyword-chip px-3 py-1.5 rounded-full bg-white/5 hover:bg-white/10 text-sm text-text-main transition-colors"
                                    data-keyword={item.keyword}
                                >
                                    {item.keyword} ({item.count})
                                </button>
                            ))
                        }
                    </div>
                </div>

                <div id="publicationsList" class="space-y-4">
                    {
                        allPublications.map((publication) => (
                            <article
                                class="publication-card glass-card p-6 space-y-4 transition-all duration-300"
                                data-campus-id={publication.campus_id}
                                data-title={publication.title.toLowerCase()}
                                data-venue={String(
                                    publication.journal_conference || "",
                                ).toLowerCase()}
                                data-authors={publication.author_names.join(" ").toLowerCase()}
                                data-author-ids={publication.authors.map((author) => author.id).join("|")}
                                data-type={publication.type}
                                data-year={publication.year}
                                data-keywords={publication.keywords.join("|")}
                            >
                                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
                                    <div class="space-y-3">
                                        <div class="flex flex-wrap items-center gap-2">
                                            <span class="px-3 py-1 rounded-full bg-premium-accent/10 text-premium-accent text-[11px] font-bold uppercase tracking-wider">
                                                {publication.type === "Journal"
                                                    ? "Periódico"
                                                    : "Evento"}
                                            </span>
                                            <span class="px-3 py-1 rounded-full bg-white/5 text-text-secondary text-[11px] font-bold uppercase tracking-wider">
                                                {publication.year}
                                            </span>
                                        </div>

                                        <h3 class="text-xl font-bold font-['Outfit'] text-text-main leading-snug">
                                            {publication.title}
                                        </h3>

                                        <p class="text-sm text-text-secondary leading-relaxed">
                                            {publication.journal_conference || "Veículo não informado"}
                                        </p>

                                        <div class="flex flex-wrap gap-2">
                                            {publication.keywords.slice(0, 6).map((keyword) => (
                                                <span class="px-2.5 py-1 rounded-full bg-premium-purple/10 text-premium-purple text-[11px] font-semibold">
                                                    {keyword}
                                                </span>
                                            ))}
                                        </div>
                                    </div>

                                    {
                                        publication.doi &&
                                            publication.doi !== "None" &&
                                            publication.doi.trim() !== "" && (
                                                <a
                                                    href={publication.doi.startsWith("http")
                                                        ? publication.doi
                                                        : `https://doi.org/${publication.doi}`}
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                    class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 text-sm font-semibold text-text-main transition-colors"
                                                >
                                                    Ver DOI
                                                </a>
                                            )
                                    }
                                </div>

                                <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr),240px] gap-4">
                                    <div class="space-y-2">
                                        <p class="text-xs font-bold uppercase tracking-[0.2em] text-text-muted">
                                            Autores internos
                                        </p>
                                        <div class="flex flex-wrap gap-2">
                                            {
                                                publication.authors.map((author) => (
                                                    <a
                                                        href={`/horizon_dashboard/researchers/${author.id}`}
                                                        class="px-3 py-1.5 rounded-full bg-white/5 hover:bg-white/10 text-sm text-text-main transition-colors"
                                                    >
                                                        {author.name}
                                                    </a>
                                                ))
                                            }
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-2 gap-3">
                                        <div class="rounded-2xl border border-white/5 bg-white/5 p-4 col-span-2">
                                            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-text-muted">
                                                Pesquisador principal
                                            </p>
                                            <p class="text-base font-bold text-text-main mt-2">
                                                {publication.primary_author?.name || "Não vinculado"}
                                            </p>
                                            <p class="text-xs text-text-secondary mt-1">
                                                {publication.internal_authors_count} autor(es) interno(s)
                                            </p>
                                        </div>
                                        <div class="rounded-2xl border border-white/5 bg-white/5 p-4">
                                            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-text-muted">
                                                Volume
                                            </p>
                                            <p class="text-lg font-bold text-text-main mt-2">
                                                {publication.volume || "N/A"}
                                            </p>
                                        </div>
                                        <div class="rounded-2xl border border-white/5 bg-white/5 p-4">
                                            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-text-muted">
                                                Páginas
                                            </p>
                                            <p class="text-lg font-bold text-text-main mt-2">
                                                {publication.pages || "N/A"}
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        ))
                    }
                </div>

                <div
                    id="publicationsEmptyState"
                    class="hidden flex-col items-center justify-center py-20 text-center glass-card border-dashed"
                >
                    <h3 class="text-xl font-bold font-['Outfit'] text-text-main mb-2">
                        Nenhuma publicação encontrada
                    </h3>
                    <p class="text-text-secondary max-w-md">
                        Ajuste a busca, os filtros ou o campus selecionado para encontrar publicações.
                    </p>
                </div>
            </section>
        </main>
    </div>

    <script define:vars={{ publicationsCatalogByCampus }}>
        const publicationSearch = document.getElementById(
            "publicationSearch",
        ) as HTMLInputElement | null;
        const publicationTypeFilter = document.getElementById(
            "publicationTypeFilter",
        ) as HTMLSelectElement | null;
        const publicationResearcherFilter = document.getElementById(
            "publicationResearcherFilter",
        ) as HTMLSelectElement | null;
        const publicationYearFilter = document.getElementById(
            "publicationYearFilter",
        ) as HTMLSelectElement | null;
        const keywordContainer = document.getElementById("publicationKeywordList");
        const clearKeywordFilter = document.getElementById("clearKeywordFilter");
        const publicationCards = document.querySelectorAll(".publication-card");
        const emptyState = document.getElementById("publicationsEmptyState");
        const countLabel = document.getElementById("publicationsCountLabel");
        const publicationsCatalog = publicationsCatalogByCampus || {};
        let selectedKeyword = "";

        function getCatalogForCampus(selectedCampus) {
            return publicationsCatalog[selectedCampus] || publicationsCatalog[""] || {
                total: publicationCards.length,
                researchers: [],
                years: [],
                keywords: [],
            };
        }

        function populateSelect(select, options, defaultLabel, getOptionValue) {
            if (!select) return;

            const currentValue = select.value;
            const allowedValues = ["", ...options.map((option) => getOptionValue(option))];
            const safeValue = allowedValues.includes(currentValue) ? currentValue : "";

            select.innerHTML = "";

            const defaultOption = document.createElement("option");
            defaultOption.value = "";
            defaultOption.textContent = defaultLabel;
            select.appendChild(defaultOption);

            options.forEach((option) => {
                const element = document.createElement("option");
                const optionValue = getOptionValue(option);
                element.value = optionValue;
                element.textContent =
                    typeof option === "object" && option !== null && "name" in option
                        ? option.name
                        : optionValue;
                select.appendChild(element);
            });

            select.value = safeValue;
        }

        function renderKeywordChips(keywords) {
            if (!keywordContainer) return;

            keywordContainer.innerHTML = keywords
                .map(
                    (item) => `
                        <button
                            type="button"
                            class="publication-keyword-chip px-3 py-1.5 rounded-full bg-white/5 hover:bg-white/10 text-sm text-text-main transition-colors"
                            data-keyword="${item.keyword}"
                        >
                            ${item.keyword} (${item.count})
                        </button>
                    `,
                )
                .join("");

            keywordContainer
                .querySelectorAll(".publication-keyword-chip")
                .forEach((node) => {
                    const isActive =
                        (node as HTMLElement).dataset.keyword === selectedKeyword;
                    node.classList.toggle("bg-premium-accent/15", isActive);
                    node.classList.toggle("text-premium-accent", isActive);
                });
        }

        function syncCampusControls(selectedCampus) {
            const catalog = getCatalogForCampus(selectedCampus);

            populateSelect(
                publicationResearcherFilter,
                catalog.researchers || [],
                "Todos os pesquisadores",
                (option) => String(option.id || ""),
            );
            populateSelect(
                publicationYearFilter,
                catalog.years || [],
                "Todos os anos",
                (option) => String(option),
            );

            const availableKeywords = (catalog.keywords || []).map(
                (item) => item.keyword,
            );

            if (selectedKeyword && !availableKeywords.includes(selectedKeyword)) {
                selectedKeyword = "";
            }

            renderKeywordChips(catalog.keywords || []);
        }

        function updatePublicationViews(selectedCampus) {
            document
                .querySelectorAll(
                    "#publications-dashboard-views [data-campus-view]",
                )
                .forEach((node) => {
                    const viewCampus = node.getAttribute("data-campus-view") || "";
                    node.classList.toggle("hidden", viewCampus !== selectedCampus);
                });
        }

        function filterPublications() {
            const query = publicationSearch?.value.toLowerCase().trim() || "";
            const selectedType = publicationTypeFilter?.value || "";
            const selectedResearcher = publicationResearcherFilter?.value || "";
            const selectedYear = publicationYearFilter?.value || "";
            const selectedCampus = localStorage.getItem("preferred-campus") || "";
            const campusCatalog = getCatalogForCampus(selectedCampus);
            const totalForCampus = Number(campusCatalog.total || 0);
            let visibleCount = 0;

            publicationCards.forEach((card) => {
                const element = card as HTMLElement;
                const matchesCampus =
                    !selectedCampus ||
                    (element.dataset.campusId || "") === selectedCampus;
                const matchesQuery =
                    !query ||
                    (element.dataset.title || "").includes(query) ||
                    (element.dataset.venue || "").includes(query) ||
                    (element.dataset.authors || "").includes(query);
                const matchesType =
                    !selectedType || (element.dataset.type || "") === selectedType;
                const researcherIds = (element.dataset.authorIds || "")
                    .split("|")
                    .filter(Boolean);
                const matchesResearcher =
                    !selectedResearcher ||
                    researcherIds.includes(selectedResearcher);
                const matchesYear =
                    !selectedYear || (element.dataset.year || "") === selectedYear;
                const matchesKeyword =
                    !selectedKeyword ||
                    (element.dataset.keywords || "")
                        .split("|")
                        .filter(Boolean)
                        .includes(selectedKeyword);
                const matches =
                    matchesCampus &&
                    matchesQuery &&
                    matchesType &&
                    matchesResearcher &&
                    matchesYear &&
                    matchesKeyword;

                element.style.display = matches ? "block" : "none";
                if (matches) visibleCount += 1;
            });

            if (countLabel) {
                countLabel.textContent = `${visibleCount} de ${totalForCampus} publicações`;
            }

            if (visibleCount === 0) {
                emptyState?.classList.remove("hidden");
                emptyState?.classList.add("flex");
            } else {
                emptyState?.classList.add("hidden");
                emptyState?.classList.remove("flex");
            }
        }

        publicationSearch?.addEventListener("input", filterPublications);
        publicationTypeFilter?.addEventListener("change", filterPublications);
        publicationResearcherFilter?.addEventListener("change", filterPublications);
        publicationYearFilter?.addEventListener("change", filterPublications);
        keywordContainer?.addEventListener("click", (event) => {
            const button = (event.target as HTMLElement)?.closest(
                ".publication-keyword-chip",
            ) as HTMLElement | null;

            if (!button) return;

            selectedKeyword = button.dataset.keyword || "";
            renderKeywordChips(
                getCatalogForCampus(
                    localStorage.getItem("preferred-campus") || "",
                ).keywords || [],
            );
            filterPublications();
        });
        clearKeywordFilter?.addEventListener("click", () => {
            selectedKeyword = "";
            renderKeywordChips(
                getCatalogForCampus(
                    localStorage.getItem("preferred-campus") || "",
                ).keywords || [],
            );
            filterPublications();
        });
        window.addEventListener("campus-filter-change", (event) => {
            const selectedCampus = event.detail?.campusId || event.detail?.campus || "";
            syncCampusControls(selectedCampus);
            updatePublicationViews(selectedCampus);
            filterPublications();
        });

        const initialCampus = localStorage.getItem("preferred-campus") || "";
        syncCampusControls(initialCampus);
        updatePublicationViews(initialCampus);
        filterPublications();
    </script>
</Layout>
