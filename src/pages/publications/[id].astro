---
import Layout from "../../layouts/Layout.astro";
import {
    getAggregatedPublications,
    type AggregatedPublication,
} from "../../lib/publications-data";
import {
    researchersOnly,
    studentsResearchers,
} from "../../lib/researcher-collections";

export function getStaticPaths() {
    const publications = getAggregatedPublications();
    return publications.map((publication) => ({
        params: { id: String(publication.id) },
        props: { publication },
    }));
}

interface Props {
    publication: AggregatedPublication;
}

const { publication } = Astro.props;
const base = import.meta.env.BASE_URL;

// Rotas de autor só quando a pessoa tem página (evita link quebrado).
const researcherIds = new Set(researchersOnly.map((r) => String(r.id)));
const studentIds = new Set(studentsResearchers.map((r) => String(r.id)));
const authorHref = (id: string) =>
    researcherIds.has(id)
        ? `${base}researchers/${id}`
        : studentIds.has(id)
          ? `${base}students/${id}`
          : null;

const typeLabel =
    publication.type === "Journal"
        ? "Artigo em periódico"
        : publication.type === "Conference Event"
          ? "Trabalho em evento"
          : publication.type || "Publicação";

const doiUrl = publication.doi
    ? `https://doi.org/${String(publication.doi).replace(/^https?:\/\/(dx\.)?doi\.org\//i, "")}`
    : null;

const venue = String(publication.journal_conference || "").trim();
const meta: string[] = [];
if (publication.year) meta.push(String(publication.year));
if (publication.volume) meta.push(`v. ${publication.volume}`);
if (publication.pages) meta.push(`p. ${publication.pages}`);
if (publication.campus_name) meta.push(publication.campus_name);
---

<Layout
    title={publication.title || "Publicação"}
    breadcrumbReplacements={{
        publications: "Publicações",
        [String(publication.id)]: publication.title || "Publicação",
    }}
>
    <div class="max-w-3xl mx-auto pb-20">
        <nav aria-label="Voltar para publicações" class="mb-8">
            <a
                href={`${base}publications`}
                class="inline-flex items-center gap-2 text-sm font-bold text-text-secondary hover:text-premium-accent transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="m15 18-6-6 6-6"></path>
                </svg>
                Voltar para publicações
            </a>
        </nav>

        <article class="glass-card p-6 md:p-8 space-y-6">
            <header class="space-y-3">
                <span
                    class="inline-block font-mono text-[11px] uppercase tracking-wider text-premium-accent bg-brand-green/10 border border-brand-green/20 rounded-full px-3 py-1"
                >
                    {typeLabel}
                </span>
                <h1
                    class="font-display text-2xl md:text-3xl font-bold tracking-tight text-text-main leading-tight text-balance"
                >
                    {publication.title || "Sem título"}
                </h1>
                {
                    venue && (
                        <p class="text-text-secondary text-lg leading-snug">
                            {venue}
                        </p>
                    )
                }
                {
                    meta.length > 0 && (
                        <p class="font-mono text-xs text-text-muted uppercase tracking-wide">
                            {meta.join("  ·  ")}
                        </p>
                    )
                }
            </header>

            {
                doiUrl && (
                    <div>
                        <a
                            href={doiUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Abrir DOI (abre em nova aba)"
                            class="inline-flex items-center gap-2 text-sm font-bold text-white bg-brand-green-dark hover:bg-brand-green rounded-lg px-4 py-2 transition-colors"
                        >
                            DOI
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-4 h-4"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"
                            >
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                <polyline points="15 3 21 3 21 9"></polyline>
                                <line x1="10" y1="14" x2="21" y2="3"></line>
                            </svg>
                        </a>
                    </div>
                )
            }

            {
                publication.authors.length > 0 && (
                    <section class="space-y-2">
                        <h2 class="font-mono text-xs uppercase tracking-wider text-text-muted">
                            Autores
                            {publication.internal_authors_count > 0 && (
                                <span class="text-text-muted-2">
                                    {" "}
                                    · {publication.internal_authors_count} do Ifes
                                </span>
                            )}
                        </h2>
                        <ul class="flex flex-wrap gap-x-4 gap-y-1">
                            {publication.authors.map((author) => {
                                const href = authorHref(String(author.id));
                                return (
                                    <li>
                                        {href ? (
                                            <a
                                                href={href}
                                                class="text-text-main hover:text-premium-accent underline underline-offset-4 decoration-border-main hover:decoration-premium-accent transition-colors"
                                            >
                                                {author.name}
                                            </a>
                                        ) : (
                                            <span class="text-text-main">
                                                {author.name}
                                            </span>
                                        )}
                                    </li>
                                );
                            })}
                        </ul>
                    </section>
                )
            }

            {
                publication.keywords.length > 0 && (
                    <section class="space-y-2">
                        <h2 class="font-mono text-xs uppercase tracking-wider text-text-muted">
                            Palavras-chave
                        </h2>
                        <div class="flex flex-wrap gap-2">
                            {publication.keywords.slice(0, 20).map((keyword) => (
                                <span class="px-2 py-0.5 rounded-md bg-tag-bg border border-border-main text-[11px] text-text-secondary">
                                    {keyword}
                                </span>
                            ))}
                        </div>
                    </section>
                )
            }
        </article>
    </div>
</Layout>
