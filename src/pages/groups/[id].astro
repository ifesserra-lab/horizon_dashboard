---
import Layout from "../../layouts/Layout.astro";
import groupsData from "../../data/research_groups_canonical.json";
import projectsData from "../../data/initiatives_canonical.json";
import membershipGraphManifest from "../../data/research_group_membership_graphs_manifest.json";
import relationshipGraphManifest from "../../data/research_group_relationship_graphs_manifest.json";
import DataSourcesPanel from "../../components/provenance/DataSourcesPanel.astro";
import ResearchGroupGraphDatasets from "../../components/groups/ResearchGroupGraphDatasets.astro";
import ResearchGroupInteractionGraph from "../../components/groups/ResearchGroupInteractionGraph.astro";
import ResearchGroupRelationshipTable from "../../components/groups/ResearchGroupRelationshipTable.astro";
import { buildProvenanceFields } from "../../lib/provenance";
import {
	buildResearchGroupInteractionViewModel,
	buildResearchGroupRelationshipTableRows,
} from "../../lib/research-group-interaction";
import type {
	ResearchGroup,
	ResearchGroupInteractionRawGraphFile,
} from "../../types/groups";
import type { Project } from "../../types/projects";

const graphModules = import.meta.glob<{
	default: ResearchGroupInteractionRawGraphFile;
}>("../../data/research_group_relationship_graphs/*.json");
const membershipGraphModules = import.meta.glob<{
	default: ResearchGroupSummaryGraphFile;
}>("../../data/research_group_membership_graphs/*.json");

interface ResearchGroupGraphManifestEntry {
	id: number;
	path: string;
	name?: string | null;
	short_name?: string | null;
	member_count?: number;
	nodes?: number;
	edges?: number;
}

interface ResearchGroupSummaryGraphFile {
	metadata: {
		scope: {
			graph_type?: string;
			research_group: {
				id: string | number;
				name: string;
				short_name?: string | null;
				member_count?: number;
			};
		};
	};
	graph_stats: {
		nodes?: number;
		edges?: number;
		isolated_nodes?: number;
		connected_components?: number;
		largest_component_size?: number;
		relation_event_totals?: Record<string, number | undefined>;
		classification_distribution?: Record<string, number | undefined>;
		top_people_by_weighted_degree?: Array<{
			id: string | number;
			name: string;
			classification?: string | null;
			weighted_degree?: number;
			degree?: number;
		}>;
	};
}

const membershipGraphEntriesById = new Map(
	(
		(membershipGraphManifest as {
			graphs: ResearchGroupGraphManifestEntry[];
		}).graphs ?? []
	).map((entry) => [String(entry.id), entry]),
);

const relationshipGraphEntriesById = new Map(
	(
		(relationshipGraphManifest as {
			graphs: ResearchGroupGraphManifestEntry[];
		}).graphs ?? []
	).map((entry) => [String(entry.id), entry]),
);

const relationLabels: Record<string, string> = {
	present_in: "Presenca no grupo",
	research_group: "Grupo de pesquisa",
	project: "Projeto",
	article: "Artigo",
	orientation: "Orientacao",
	initiative: "Iniciativa",
	advisorship: "Orientacao",
};

const classificationLabels: Record<string, string> = {
	student: "Estudantes",
	researcher: "Pesquisadores",
	outside_ifes: "Externos ao Ifes",
	null: "Sem classificacao",
};

const resolveGraphImporter = <T,>(
	modules: Record<string, () => Promise<{ default: T }>>,
	path: string | null,
) =>
	path
		? Object.entries(modules).find(([modulePath]) => modulePath.endsWith(path))?.[1] ?? null
		: null;

const summarizeCountRecord = (record?: Record<string, number | undefined>) =>
	Object.entries(record ?? {})
		.map(([key, value]) => ({
			label: relationLabels[key] ?? key.replaceAll("_", " "),
			value: Number(value ?? 0),
		}))
		.filter((item) => item.value > 0)
		.sort((left, right) => right.value - left.value);

const summarizeClassificationRecord = (record?: Record<string, number | undefined>) =>
	Object.entries(record ?? {})
		.map(([key, value]) => ({
			label: classificationLabels[key] ?? key.replaceAll("_", " "),
			value: Number(value ?? 0),
		}))
		.filter((item) => item.value > 0)
		.sort((left, right) => right.value - left.value);

const buildDatasetCard = ({
	key,
	title,
	description,
	path,
	manifestEntry,
	graphFile,
}: {
	key: "membership" | "relationship";
	title: string;
	description: string;
	path: string | null;
	manifestEntry?: ResearchGroupGraphManifestEntry | null;
	graphFile?: ResearchGroupSummaryGraphFile | null;
}) => {
	const stats = graphFile?.graph_stats;
	const topPeople = (stats?.top_people_by_weighted_degree ?? [])
		.slice(0, 5)
		.map((person) => ({
			id: String(person.id),
			name: person.name,
			classification: person.classification ?? null,
			weightedDegree: Number(person.weighted_degree ?? 0),
			degree: Number(person.degree ?? 0),
		}));

	return {
		key,
		title,
		description,
		graphType: graphFile?.metadata.scope.graph_type ?? null,
		available: Boolean(path && (graphFile || manifestEntry)),
		stats: {
			nodes: Number(stats?.nodes ?? manifestEntry?.nodes ?? 0),
			edges: Number(stats?.edges ?? manifestEntry?.edges ?? 0),
			connectedComponents: Number(stats?.connected_components ?? 0),
			largestComponentSize: Number(stats?.largest_component_size ?? 0),
			memberCount: Number(
				graphFile?.metadata.scope.research_group.member_count ??
					manifestEntry?.member_count ??
					group.members.length,
			),
		},
		relationTotals: summarizeCountRecord(stats?.relation_event_totals),
		classificationDistribution: summarizeClassificationRecord(
			stats?.classification_distribution,
		),
		topPeople,
	};
};

export function getStaticPaths() {
	const groups = groupsData as ResearchGroup[];
	const relationshipEntriesById = new Map(
		(
			(relationshipGraphManifest as {
				graphs: ResearchGroupGraphManifestEntry[];
			}).graphs ?? []
		).map((entry) => [String(entry.id), entry]),
	);
	const membershipEntriesById = new Map(
		(
			(membershipGraphManifest as {
				graphs: ResearchGroupGraphManifestEntry[];
			}).graphs ?? []
		).map((entry) => [String(entry.id), entry]),
	);
	return groups.map((group) => ({
		params: { id: group.id.toString() },
		props: {
			group,
			relationshipGraphPath:
				relationshipEntriesById.get(String(group.id))?.path ?? null,
			membershipGraphPath:
				membershipEntriesById.get(String(group.id))?.path ?? null,
		},
	}));
}

interface Props {
	group: ResearchGroup;
	relationshipGraphPath?: string | null;
	membershipGraphPath?: string | null;
}

const {
	group,
	relationshipGraphPath = null,
	membershipGraphPath = null,
} = Astro.props;
const groupProjects = (projectsData as Project[]).filter(
	(p) => p.research_group?.id === group.id,
);
const formatDate = (dateStr: string) => {
	if (!dateStr) return "N/A";
	const date = new Date(dateStr);
	return date.toLocaleDateString("pt-BR", { year: "numeric" });
};

// Helper function to check if a member is alumni (egresso)
// Handles both null/undefined and the string "None" from Python exports
const isAlumni = (endDate: string | null | undefined) => {
	return endDate && endDate !== "None" && endDate !== "null";
};

const groupSourceFields = buildProvenanceFields([
	{
		label: "Identidade do grupo",
		description:
			"Nome, sigla, campus e metadados basicos exibidos no topo da pagina.",
		entityType: "research_group",
		entityId: group.id,
		attributeNames: ["name", "short_name", "campus_name", "site_url"],
	},
	{
		label: "Descricao do grupo",
		description: "Texto descritivo principal do grupo de pesquisa.",
		entityType: "research_group",
		entityId: group.id,
		attributeNames: ["description"],
	},
	{
		label: "Areas de conhecimento",
		description: "Areas exibidas como tags no perfil do grupo.",
		entityType: "research_group",
		entityId: group.id,
		attributeNames: ["area_name"],
	},
	{
		label: "Membros e liderancas",
		description:
			"Registros fonte que sustentam as pessoas listadas como membros e lideres do grupo.",
		entityType: "research_group",
		entityId: group.id,
	},
	...(groupProjects.length > 0
		? [
				{
					label: "Projetos vinculados ao grupo",
					description:
						"Projetos relacionados a este grupo e mostrados nesta rota.",
					entities: groupProjects.map((project) => ({
						entityType: "initiative" as const,
						entityId: project.id,
						attributeNames: ["name", "status", "start_date", "end_date"],
					})),
				},
			]
		: []),
]);

const relationshipGraphImporter = resolveGraphImporter(
	graphModules,
	relationshipGraphPath,
);
const membershipGraphImporter = resolveGraphImporter(
	membershipGraphModules,
	membershipGraphPath,
);

const relationshipGraphFile = relationshipGraphImporter
	? ((await relationshipGraphImporter()).default ?? null)
	: null;
const membershipGraphFile = membershipGraphImporter
	? ((await membershipGraphImporter()).default ?? null)
	: null;

const relationshipGraphEntry =
	relationshipGraphEntriesById.get(String(group.id)) ?? null;
const membershipGraphEntry =
	membershipGraphEntriesById.get(String(group.id)) ?? null;

const groupGraphDatasets = [
	buildDatasetCard({
		key: "membership",
		title: "Grafo de membresia",
		description:
			"Mostra a composicao do grupo no recorte exportado, sem depender de colaboracao direta entre as pessoas.",
		path: membershipGraphPath,
		manifestEntry: membershipGraphEntry,
		graphFile: membershipGraphFile,
	}),
	buildDatasetCard({
		key: "relationship",
		title: "Grafo relacional",
		description:
			"Conecta pessoas por projeto, artigo e orientacao compartilhados e serve de base para a leitura estrutural mais rica da rede.",
		path: relationshipGraphPath,
		manifestEntry: relationshipGraphEntry,
		graphFile: relationshipGraphFile,
	}),
];

const groupInteractionGraph = relationshipGraphFile
	? buildResearchGroupInteractionViewModel(
			relationshipGraphFile as ResearchGroupInteractionRawGraphFile,
			{
				groupId: group.id,
				groupName: group.name,
				baseUrl: import.meta.env.BASE_URL,
			},
		)
	: null;
const topCollaboratingResearchers = (groupInteractionGraph?.nodes ?? [])
	.filter(
		(node) =>
			node.classification === "researcher" && node.weightedDegree > 0,
	)
	.sort((left, right) => {
		if (right.weightedDegree !== left.weightedDegree) {
			return right.weightedDegree - left.weightedDegree;
		}

		if (right.degree !== left.degree) {
			return right.degree - left.degree;
		}

		return left.name.localeCompare(right.name, "pt-BR");
	})
	.slice(0, 5);
const relationshipTableRows = groupInteractionGraph
	? buildResearchGroupRelationshipTableRows(groupInteractionGraph)
	: [];
---

<Layout title={group.name} breadcrumbReplacements={{ [group.id]: group.name }}>
	<nav class="mb-8" aria-label="Navegação secundária">
		<a
			href={`${import.meta.env.BASE_URL}groups`}
			class="text-sm font-bold text-text-secondary hover:text-premium-accent flex items-center gap-2 transition-colors focus:ring-2 focus:ring-premium-accent rounded px-1"
		>
			<svg
				aria-hidden="true"
				xmlns="http://www.w3.org/2000/svg"
				class="w-4 h-4"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
			>
			Voltar para lista
		</a>
	</nav>

	<div class="flex flex-col lg:flex-row gap-8 items-start">
		<!-- Main Details -->
		<div class="flex-1 space-y-8">
			<article class="glass-card p-8" aria-labelledby="group-title">
				<div
					class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8"
				>
					<div class="flex items-center gap-6">
						<div
							aria-hidden="true"
							class="w-20 h-20 rounded-2xl bg-gradient-to-br from-premium-accent to-premium-purple flex items-center justify-center text-white text-3xl font-bold font-['Outfit'] shadow-xl shadow-premium-accent/10"
						>
							{
								group.short_name?.charAt(0) ||
									group.name.charAt(0)
							}
						</div>
						<div>
							<div class="flex flex-wrap gap-2 mb-2">
								<span
									class="px-3 py-1 rounded-full bg-premium-accent/10 text-premium-accent text-[10px] font-bold uppercase tracking-widest border border-premium-accent/20"
								>
									{group.organization.name}
								</span>
								<span
									class="px-3 py-1 rounded-full bg-[var(--tag-bg)] text-text-secondary text-[10px] font-bold uppercase tracking-widest border border-border-main"
								>
									{group.campus.name}
								</span>
							</div>
							<h1
								id="group-title"
								class="text-3xl font-bold font-['Outfit'] text-text-main leading-tight"
							>
								{group.name}
							</h1>
						</div>
					</div>
					{
						group.cnpq_url && (
							<a
								href={group.cnpq_url}
								target="_blank"
								rel="noopener noreferrer"
								class="px-6 py-3 bg-[var(--tag-bg)] hover:bg-premium-accent/10 border border-border-main rounded-xl text-xs font-bold transition-all flex items-center gap-2 text-text-main focus:ring-2 focus:ring-premium-accent"
							>
								Espelho CNPq
								<svg
									aria-hidden="true"
									xmlns="http://www.w3.org/2000/svg"
									class="w-4 h-4"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<>
										<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
										<polyline points="15 3 21 3 21 9" />
										<line x1="10" y1="14" x2="21" y2="3" />
									</>
								</svg>
							</a>
						)
					}
				</div>

				<div class="prose dark:prose-invert max-w-none mb-10">
					<h4
						class="text-text-main text-sm font-bold uppercase tracking-wider mb-3"
					>
						Sobre o Grupo
					</h4>
					<p class="text-text-secondary leading-relaxed">
						{
							group.description ||
								"Este grupo de pesquisa foca em estudos avançados e desenvolvimento científico na sua respectiva área, contribuindo para o ecossistema acadêmico da instituição."
						}
					</p>
				</div>

				<div>
					<h4
						class="text-text-main text-sm font-bold uppercase tracking-wider mb-4"
					>
						Áreas de Conhecimento
					</h4>
					<div
						class="flex flex-wrap gap-3"
						role="list"
						aria-label="Áreas de atuação"
					>
						{
							group.knowledge_areas.map((area) => (
								<div
									role="listitem"
									class="px-4 py-2 bg-[var(--tag-bg)] border border-border-main rounded-xl text-xs text-text-main font-bold"
								>
									{area.name}
								</div>
							))
						}
					</div>
				</div>
			</article>

			<!-- Members Section -->
			<section aria-labelledby="members-title" class="space-y-10">
				<div>
					<h3
						id="members-title"
						class="text-2xl font-bold font-['Outfit'] text-text-main mb-6"
					>
						Membros do Grupo
					</h3>

					{/* Researchers Section */}
					{
						group.members.filter((m) =>
							["Leader", "Pesquisador"].includes(m.role),
						).length > 0 && (
							<div class="mb-12">
								<h4 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2">
									<span class="w-1.5 h-6 bg-premium-accent rounded-full" />
									Pesquisadores
								</h4>

								{/* Current Researchers */}
								{group.members.filter(
									(m) =>
										["Leader", "Pesquisador"].includes(
											m.role,
										) && !isAlumni(m.end_date),
								).length > 0 && (
									<div class="mb-8">
										<h5 class="text-xs font-bold uppercase tracking-widest text-text-secondary mb-4 px-1">
											Atuais
										</h5>
										<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
											{group.members
												.filter(
													(m) =>
														[
															"Leader",
															"Pesquisador",
														].includes(m.role) &&
														!isAlumni(m.end_date),
												)
												.map((member) => (
													<div class="glass-card p-4 flex items-center gap-4 transition-all hover:border-premium-accent/30">
														<div
															aria-hidden="true"
															class="w-12 h-12 rounded-full bg-[var(--tag-bg)] border-2 border-border-main flex items-center justify-center text-text-secondary font-bold shrink-0 relative"
														>
															{member.name.charAt(
																0,
															)}
														</div>
														<div class="flex-1 overflow-hidden">
															<div class="flex items-center gap-2">
																<h5 class="text-sm font-bold text-text-main truncate">
																	{
																		member.name
																	}
																</h5>
															</div>
															<p
																class={`text-[10px] font-bold uppercase tracking-tight ${member.role === "Leader" ? "text-premium-accent" : "text-text-secondary"}`}
															>
																{member.role ===
																"Leader"
																	? "Líder / Pesquisador"
																	: "Pesquisador"}
															</p>
														</div>
														{member.lattes_url && (
															<a
																href={
																	member.lattes_url
																}
																target="_blank"
																rel="noopener noreferrer"
																class="p-2 rounded-lg bg-[var(--tag-bg)] hover:bg-premium-accent/10 text-text-secondary hover:text-premium-accent transition-all focus:ring-2 focus:ring-premium-accent"
																aria-label={`Currículo Lattes de ${member.name}`}
															>
																<svg
																	aria-hidden="true"
																	xmlns="http://www.w3.org/2000/svg"
																	class="w-4 h-4"
																	viewBox="0 0 24 24"
																	fill="none"
																	stroke="currentColor"
																	stroke-width="2"
																	stroke-linecap="round"
																	stroke-linejoin="round"
																>
																	<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
																	<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
																</svg>
															</a>
														)}
													</div>
												))}
										</div>
									</div>
								)}

								{/* Alumni Researchers */}
								{group.members.filter(
									(m) =>
										["Leader", "Pesquisador"].includes(
											m.role,
										) && isAlumni(m.end_date),
								).length > 0 && (
									<div>
										<h5 class="text-xs font-bold uppercase tracking-widest text-text-secondary mb-4 px-1">
											Egressos
										</h5>
										<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
											{group.members
												.filter(
													(m) =>
														[
															"Leader",
															"Pesquisador",
														].includes(m.role) &&
														isAlumni(m.end_date),
												)
												.map((member) => (
													<div class="glass-card p-4 flex items-center gap-4 transition-all opacity-70 grayscale hover:grayscale-0 hover:opacity-100 hover:border-slate-400">
														<div
															aria-hidden="true"
															class="w-12 h-12 rounded-full bg-[var(--tag-bg)] border-2 border-border-main flex items-center justify-center text-text-secondary font-bold shrink-0 relative"
														>
															{member.name.charAt(
																0,
															)}
															<span
																class="absolute -bottom-1 -right-1 w-4 h-4 bg-slate-500 rounded-full border-2 border-[var(--tag-bg)] flex items-center justify-center"
																title="Egresso"
															>
																<svg
																	xmlns="http://www.w3.org/2000/svg"
																	class="w-2.5 h-2.5 text-white"
																	viewBox="0 0 24 24"
																	fill="none"
																	stroke="currentColor"
																	stroke-width="3"
																	stroke-linecap="round"
																	stroke-linejoin="round"
																>
																	<path d="M5 12h14" />
																	<path d="m12 5 7 7-7 7" />
																</svg>
															</span>
														</div>
														<div class="flex-1 overflow-hidden">
															<div class="flex items-center gap-2">
																<h5 class="text-sm font-bold text-text-main truncate">
																	{
																		member.name
																	}
																</h5>
																<span class="px-1.5 py-0.5 rounded text-[9px] font-bold uppercase bg-slate-100 dark:bg-slate-800 text-slate-500 border border-slate-200 dark:border-slate-700">
																	Egresso
																</span>
															</div>
															<p
																class={`text-[10px] font-bold uppercase tracking-tight text-text-secondary`}
															>
																Pesquisador
															</p>
														</div>
														{member.lattes_url && (
															<a
																href={
																	member.lattes_url
																}
																target="_blank"
																rel="noopener noreferrer"
																class="p-2 rounded-lg bg-[var(--tag-bg)] hover:bg-premium-accent/10 text-text-secondary hover:text-premium-accent transition-all focus:ring-2 focus:ring-premium-accent"
																aria-label={`Currículo Lattes de ${member.name}`}
															>
																<svg
																	aria-hidden="true"
																	xmlns="http://www.w3.org/2000/svg"
																	class="w-4 h-4"
																	viewBox="0 0 24 24"
																	fill="none"
																	stroke="currentColor"
																	stroke-width="2"
																	stroke-linecap="round"
																	stroke-linejoin="round"
																>
																	<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
																	<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
																</svg>
															</a>
														)}
													</div>
												))}
										</div>
									</div>
								)}
							</div>
						)
					}

					{/* Students Section */}
					{
						group.members.filter((m) => m.role === "Estudante")
							.length > 0 && (
							<div class="mb-12">
								<h4 class="text-lg font-bold text-text-main mb-6 flex items-center gap-2">
