					<div class="mt-6 grid grid-cols-1 xl:grid-cols-5 gap-4">
						{topCollaboratingResearchers.map((researcher, index) => (
							<article class="rounded-2xl border border-border-main bg-white/80 p-4 shadow-[0_16px_40px_rgba(15,23,42,0.06)]">
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<p class="text-[11px] font-bold uppercase tracking-[0.18em] text-emerald-700">
											#{index + 1}
										</p>
										<h5 class="mt-2 text-sm font-bold text-text-main leading-snug">
											{
												researcher.profileHref ? (
													<a
														href={`${researcher.profileHref}`}
														class="transition-colors hover:text-premium-accent"
													>
														{researcher.name}
													</a>
												) : (
													researcher.name
												)
											}
										</h5>
										{
											researcher.campusName && (
												<p class="mt-1 text-xs text-text-secondary">
													{researcher.campusName}
												</p>
											)
										}
									</div>
									<span class="shrink-0 rounded-full border border-emerald-200 bg-emerald-100 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-emerald-700">
										Peso {researcher.weightedDegree}
									</span>
								</div>

								<div class="mt-4 grid grid-cols-2 gap-3">
									<div class="rounded-xl border border-border-main bg-white p-3">
										<p class="text-[10px] font-bold uppercase tracking-[0.16em] text-text-secondary">
											Conexoes
										</p>
										<p class="mt-1 text-lg font-extrabold font-['Outfit'] text-text-main">
											{researcher.degree}
										</p>
									</div>
									<div class="rounded-xl border border-border-main bg-white p-3">
										<p class="text-[10px] font-bold uppercase tracking-[0.16em] text-text-secondary">
											Peso total
										</p>
										<p class="mt-1 text-lg font-extrabold font-['Outfit'] text-text-main">
											{researcher.weightedDegree}
										</p>
									</div>
								</div>
							</article>
						))}
					</div>
				) : (
					<div class="mt-6 rounded-2xl border border-dashed border-border-main bg-white/60 p-6 text-sm text-text-secondary">
						Este grupo ainda nao possui pesquisadores com colaboracoes registradas
						no grafo relacional atual.
					</div>
				)
			}
		</div>

		<ResearchGroupGraphDatasets datasets={groupGraphDatasets} />

		<ResearchGroupRelationshipTable rows={relationshipTableRows} />

		<ResearchGroupInteractionGraph
			groupId={group.id}
			groupName={group.name}
			graphData={groupInteractionGraph}
			baseUrl={import.meta.env.BASE_URL}
		/>
	</section>

	<DataSourcesPanel
		title="Fontes dos Dados do Grupo"
		intro="A rastreabilidade abaixo mostra quais registros de origem alimentaram os blocos principais exibidos nesta pagina do grupo."
		fields={groupSourceFields}
	/>
</Layout>
