---
import Layout from "../../layouts/Layout.astro";

import advisorshipsCanonical from "../../data/advisorships_canonical.json";
import advisorshipsCanonicalUrl from "../../data/advisorships_canonical.json?url";
import articlesCanonical from "../../data/articles_canonical.json";
import articlesCanonicalUrl from "../../data/articles_canonical.json?url";
import campusesCanonical from "../../data/campuses_canonical.json";
import campusesCanonicalUrl from "../../data/campuses_canonical.json?url";
import fellowshipsCanonical from "../../data/fellowships_canonical.json";
import fellowshipsCanonicalUrl from "../../data/fellowships_canonical.json?url";
import initiativeTypesCanonical from "../../data/initiative_types_canonical.json";
import initiativeTypesCanonicalUrl from "../../data/initiative_types_canonical.json?url";
import initiativesCanonical from "../../data/initiatives_canonical.json";
import initiativesCanonicalUrl from "../../data/initiatives_canonical.json?url";
import knowledgeAreasCanonical from "../../data/knowledge_areas_canonical.json";
import knowledgeAreasCanonicalUrl from "../../data/knowledge_areas_canonical.json?url";
import organizationsCanonical from "../../data/organizations_canonical.json";
import organizationsCanonicalUrl from "../../data/organizations_canonical.json?url";
import researchGroupsCanonical from "../../data/research_groups_canonical.json";
import researchGroupsCanonicalUrl from "../../data/research_groups_canonical.json?url";
import researchersCanonical from "../../data/researchers_canonical.json";
import researchersCanonicalUrl from "../../data/researchers_canonical.json?url";
import advisorshipAnalytics from "../../data/advisorship_analytics.json";
import advisorshipAnalyticsUrl from "../../data/advisorship_analytics.json?url";
import initiativesMart from "../../data/initiatives_analytics_mart.json";
import initiativesMartUrl from "../../data/initiatives_analytics_mart.json?url";
import knowledgeAreasMart from "../../data/knowledge_areas_mart.json";
import knowledgeAreasMartUrl from "../../data/knowledge_areas_mart.json?url";

type DatasetType = "Canonical" | "Mart";

interface DatasetItem {
    id: string;
    name: string;
    description: string;
    type: DatasetType;
    countValue: number;
    countLabel: string;
    sizeLabel: string;
    structure: string;
    sampleKeys: string[];
    downloadHref: string;
    searchText: string;
}

const buildStructurePreview = (data: unknown) => {
    if (Array.isArray(data)) {
        return JSON.stringify(data[0] ?? {}, null, 2);
    }

    return JSON.stringify(data, null, 2);
};

const buildCountValue = (data: unknown) => {
    if (Array.isArray(data)) {
        return data.length;
    }

    if (data && typeof data === "object") {
        return Object.keys(data).length;
    }

    return 0;
};

const buildCountLabel = (data: unknown) => {
    if (Array.isArray(data)) {
        return `${data.length} registros`;
    }

    if (data && typeof data === "object") {
        return `${Object.keys(data).length} blocos`;
    }

    return "Sem contagem";
};

const buildSizeBytes = (data: unknown) =>
    Buffer.byteLength(JSON.stringify(data), "utf8");

const buildSizeLabel = (data: unknown) => {
    const bytes = buildSizeBytes(data);

    if (bytes < 1024) {
        return `${bytes} B`;
    }

    if (bytes < 1024 * 1024) {
        return `${(bytes / 1024).toFixed(1)} KB`;
    }

    return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
};

const buildSampleKeys = (data: unknown) => {
    if (Array.isArray(data)) {
        const firstItem = data[0];
        if (firstItem && typeof firstItem === "object" && !Array.isArray(firstItem)) {
            return Object.keys(firstItem).slice(0, 6);
        }
        return [];
    }

    if (data && typeof data === "object") {
        return Object.keys(data).slice(0, 6);
    }

    return [];
};

const buildSearchText = (
    name: string,
    description: string,
    type: DatasetType,
    sampleKeys: string[],
) => [name, description, type, ...sampleKeys].join(" ").toLowerCase();

const datasets: DatasetItem[] = [
    {
        id: "advisorships",
        name: "advisorships_canonical.json",
        description: "Orientações com estudante, tipologia, período e status.",
        type: "Canonical",
        countValue: buildCountValue(advisorshipsCanonical),
        countLabel: buildCountLabel(advisorshipsCanonical),
        sizeLabel: buildSizeLabel(advisorshipsCanonical),
        structure: buildStructurePreview(advisorshipsCanonical),
        sampleKeys: buildSampleKeys(advisorshipsCanonical),
        downloadHref: advisorshipsCanonicalUrl,
        searchText: buildSearchText(
            "advisorships_canonical.json",
            "Orientações com estudante, tipologia, período e status.",
            "Canonical",
            buildSampleKeys(advisorshipsCanonical),
        ),
    },
    {
        id: "articles",
        name: "articles_canonical.json",
        description: "Artigos publicados com ano, tipo, DOI e veículo.",
        type: "Canonical",
        countValue: buildCountValue(articlesCanonical),
        countLabel: buildCountLabel(articlesCanonical),
        sizeLabel: buildSizeLabel(articlesCanonical),
        structure: buildStructurePreview(articlesCanonical),
        sampleKeys: buildSampleKeys(articlesCanonical),
        downloadHref: articlesCanonicalUrl,
        searchText: buildSearchText(
            "articles_canonical.json",
            "Artigos publicados com ano, tipo, DOI e veículo.",
            "Canonical",
            buildSampleKeys(articlesCanonical),
        ),
    },
    {
        id: "campuses",
        name: "campuses_canonical.json",
        description: "Cadastro de campi usado nos vínculos e filtros do portal.",
        type: "Canonical",
        countValue: buildCountValue(campusesCanonical),
        countLabel: buildCountLabel(campusesCanonical),
        sizeLabel: buildSizeLabel(campusesCanonical),
        structure: buildStructurePreview(campusesCanonical),
        sampleKeys: buildSampleKeys(campusesCanonical),
        downloadHref: campusesCanonicalUrl,
        searchText: buildSearchText(
            "campuses_canonical.json",
            "Cadastro de campi usado nos vínculos e filtros do portal.",
            "Canonical",
            buildSampleKeys(campusesCanonical),
        ),
    },
    {
        id: "fellowships",
        name: "fellowships_canonical.json",
        description: "Bolsas e relações de fomento ligadas às iniciativas.",
        type: "Canonical",
        countValue: buildCountValue(fellowshipsCanonical),
        countLabel: buildCountLabel(fellowshipsCanonical),
        sizeLabel: buildSizeLabel(fellowshipsCanonical),
        structure: buildStructurePreview(fellowshipsCanonical),
        sampleKeys: buildSampleKeys(fellowshipsCanonical),
        downloadHref: fellowshipsCanonicalUrl,
        searchText: buildSearchText(
            "fellowships_canonical.json",
            "Bolsas e relações de fomento ligadas às iniciativas.",
            "Canonical",
            buildSampleKeys(fellowshipsCanonical),
        ),
    },
    {
        id: "initiative-types",
        name: "initiative_types_canonical.json",
        description: "Tipos de iniciativa utilizados na base do portal.",
        type: "Canonical",
        countValue: buildCountValue(initiativeTypesCanonical),
        countLabel: buildCountLabel(initiativeTypesCanonical),
        sizeLabel: buildSizeLabel(initiativeTypesCanonical),
        structure: buildStructurePreview(initiativeTypesCanonical),
        sampleKeys: buildSampleKeys(initiativeTypesCanonical),
        downloadHref: initiativeTypesCanonicalUrl,
        searchText: buildSearchText(
            "initiative_types_canonical.json",
            "Tipos de iniciativa utilizados na base do portal.",
            "Canonical",
            buildSampleKeys(initiativeTypesCanonical),
        ),
    },
    {
        id: "initiatives",
        name: "initiatives_canonical.json",
        description: "Projetos e iniciativas com vigência, equipe e tipo.",
        type: "Canonical",
        countValue: buildCountValue(initiativesCanonical),
        countLabel: buildCountLabel(initiativesCanonical),
        sizeLabel: buildSizeLabel(initiativesCanonical),
        structure: buildStructurePreview(initiativesCanonical),
        sampleKeys: buildSampleKeys(initiativesCanonical),
        downloadHref: initiativesCanonicalUrl,
        searchText: buildSearchText(
            "initiatives_canonical.json",
            "Projetos e iniciativas com vigência, equipe e tipo.",
            "Canonical",
            buildSampleKeys(initiativesCanonical),
        ),
    },
    {
        id: "knowledge-areas",
        name: "knowledge_areas_canonical.json",
        description: "Tabela de áreas do conhecimento adotadas no portal.",
        type: "Canonical",
        countValue: buildCountValue(knowledgeAreasCanonical),
        countLabel: buildCountLabel(knowledgeAreasCanonical),
        sizeLabel: buildSizeLabel(knowledgeAreasCanonical),
        structure: buildStructurePreview(knowledgeAreasCanonical),
        sampleKeys: buildSampleKeys(knowledgeAreasCanonical),
        downloadHref: knowledgeAreasCanonicalUrl,
        searchText: buildSearchText(
            "knowledge_areas_canonical.json",
            "Tabela de áreas do conhecimento adotadas no portal.",
            "Canonical",
            buildSampleKeys(knowledgeAreasCanonical),
        ),
    },
    {
        id: "organizations",
        name: "organizations_canonical.json",
        description: "Organizações financiadoras, parceiras e relacionadas.",
        type: "Canonical",
        countValue: buildCountValue(organizationsCanonical),
        countLabel: buildCountLabel(organizationsCanonical),
        sizeLabel: buildSizeLabel(organizationsCanonical),
        structure: buildStructurePreview(organizationsCanonical),
        sampleKeys: buildSampleKeys(organizationsCanonical),
        downloadHref: organizationsCanonicalUrl,
        searchText: buildSearchText(
            "organizations_canonical.json",
            "Organizações financiadoras, parceiras e relacionadas.",
            "Canonical",
            buildSampleKeys(organizationsCanonical),
        ),
    },
    {
        id: "groups",
        name: "research_groups_canonical.json",
        description: "Grupos de pesquisa com líderes, membros e áreas.",
        type: "Canonical",
        countValue: buildCountValue(researchGroupsCanonical),
        countLabel: buildCountLabel(researchGroupsCanonical),
        sizeLabel: buildSizeLabel(researchGroupsCanonical),
        structure: buildStructurePreview(researchGroupsCanonical),
        sampleKeys: buildSampleKeys(researchGroupsCanonical),
        downloadHref: researchGroupsCanonicalUrl,
        searchText: buildSearchText(
            "research_groups_canonical.json",
            "Grupos de pesquisa com líderes, membros e áreas.",
            "Canonical",
            buildSampleKeys(researchGroupsCanonical),
        ),
    },
    {
        id: "researchers",
        name: "researchers_canonical.json",
        description: "Pesquisadores com perfil, vínculos, artigos e orientações.",
        type: "Canonical",
        countValue: buildCountValue(researchersCanonical),
        countLabel: buildCountLabel(researchersCanonical),
        sizeLabel: buildSizeLabel(researchersCanonical),
        structure: buildStructurePreview(researchersCanonical),
        sampleKeys: buildSampleKeys(researchersCanonical),
        downloadHref: researchersCanonicalUrl,
        searchText: buildSearchText(
            "researchers_canonical.json",
            "Pesquisadores com perfil, vínculos, artigos e orientações.",
            "Canonical",
            buildSampleKeys(researchersCanonical),
        ),
    },
    {
        id: "advisorship-analytics",
        name: "advisorship_analytics.json",
        description: "Agregações analíticas das orientações para dashboards.",
        type: "Mart",
        countValue: buildCountValue(advisorshipAnalytics),
        countLabel: buildCountLabel(advisorshipAnalytics),
        sizeLabel: buildSizeLabel(advisorshipAnalytics),
        structure: buildStructurePreview(advisorshipAnalytics),
        sampleKeys: buildSampleKeys(advisorshipAnalytics),
        downloadHref: advisorshipAnalyticsUrl,
        searchText: buildSearchText(
            "advisorship_analytics.json",
            "Agregações analíticas das orientações para dashboards.",
            "Mart",
            buildSampleKeys(advisorshipAnalytics),
        ),
    },
    {
        id: "initiatives-analytics",
        name: "initiatives_analytics_mart.json",
        description: "Agregações de projetos com resumo, evolução e composição.",
        type: "Mart",
        countValue: buildCountValue(initiativesMart),
        countLabel: buildCountLabel(initiativesMart),
        sizeLabel: buildSizeLabel(initiativesMart),
        structure: buildStructurePreview(initiativesMart),
        sampleKeys: buildSampleKeys(initiativesMart),
        downloadHref: initiativesMartUrl,
        searchText: buildSearchText(
            "initiatives_analytics_mart.json",
            "Agregações de projetos com resumo, evolução e composição.",
            "Mart",
            buildSampleKeys(initiativesMart),
        ),
    },
    {
        id: "knowledge-areas-mart",
        name: "knowledge_areas_mart.json",
        description: "Matriz analítica das áreas com contagens e agrupamentos.",
        type: "Mart",
        countValue: buildCountValue(knowledgeAreasMart),
        countLabel: buildCountLabel(knowledgeAreasMart),
        sizeLabel: buildSizeLabel(knowledgeAreasMart),
        structure: buildStructurePreview(knowledgeAreasMart),
        sampleKeys: buildSampleKeys(knowledgeAreasMart),
        downloadHref: knowledgeAreasMartUrl,
        searchText: buildSearchText(
            "knowledge_areas_mart.json",
            "Matriz analítica das áreas com contagens e agrupamentos.",
            "Mart",
            buildSampleKeys(knowledgeAreasMart),
        ),
    },
];

const canonicalDatasets = datasets.filter((dataset) => dataset.type === "Canonical");
const martDatasets = datasets.filter((dataset) => dataset.type === "Mart");
const totalDatasets = datasets.length;
const totalItems = datasets.reduce((sum, dataset) => sum + dataset.countValue, 0);
const totalDownloadBytes = [
    advisorshipsCanonical,
    articlesCanonical,
    campusesCanonical,
    fellowshipsCanonical,
    initiativeTypesCanonical,
    initiativesCanonical,
    knowledgeAreasCanonical,
    organizationsCanonical,
    researchGroupsCanonical,
    researchersCanonical,
    advisorshipAnalytics,
    initiativesMart,
    knowledgeAreasMart,
].reduce((sum, data) => sum + buildSizeBytes(data), 0);

const formatSummaryBytes = (bytes: number) => {
    if (bytes < 1024 * 1024) {
        return `${(bytes / 1024).toFixed(0)} KB`;
    }

    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
};

const catalogHighlights = [
    {
        label: "Datasets disponíveis",
        value: totalDatasets,
        description: "Arquivos prontos para download direto em JSON.",
        accentClass: "text-premium-accent",
        surfaceClass: "bg-premium-accent/[0.08] border-premium-accent/20",
    },
    {
        label: "Estruturas catalogadas",
        value: totalItems.toLocaleString("pt-BR"),
        description: "Registros ou blocos somados entre bases canônicas e marts.",
        accentClass: "text-emerald-400",
        surfaceClass: "bg-emerald-400/[0.08] border-emerald-400/20",
    },
    {
        label: "Peso do catálogo",
        value: formatSummaryBytes(totalDownloadBytes),
        description: "Estimativa de navegação e prévia estrutural exibida nesta página.",
        accentClass: "text-amber-400",
        surfaceClass: "bg-amber-400/[0.08] border-amber-400/20",
    },
];

const guideCards = [
    {
        title: "Baixe o arquivo bruto",
        body: "Cada card aponta para o JSON gerado pelo build. O download não depende mais de blobs inline no HTML.",
    },
    {
        title: "Use a estrutura como contrato",
        body: "A prévia mostra o primeiro registro ou o bloco raiz para acelerar integrações, ETL e exploração em notebook.",
    },
    {
        title: "Separe base e análise",
        body: "As bases canônicas preservam entidades e vínculos. Os marts já chegam agregados para KPIs, séries e dashboards.",
    },
];
---

<Layout title="Dados Abertos">
    <div class="space-y-10 pb-12" id="open-data-catalog">
        <header class="relative overflow-hidden glass-card border border-border-main p-8 md:p-10">
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute -top-24 right-0 h-56 w-56 rounded-full bg-premium-accent/10 blur-3xl"></div>
                <div class="absolute bottom-0 left-0 h-48 w-48 rounded-full bg-premium-purple/10 blur-3xl"></div>
            </div>

            <div class="relative space-y-8">
                <div class="flex flex-wrap gap-2">
                    <span class="inline-flex items-center gap-2 rounded-full border border-premium-accent/20 bg-premium-accent/[0.08] px-3 py-1 text-[10px] font-bold uppercase tracking-[0.22em] text-premium-accent">
                        Catálogo técnico
                    </span>
                    <span class="inline-flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/[0.08] px-3 py-1 text-[10px] font-bold uppercase tracking-[0.22em] text-emerald-400">
                        Download direto JSON
                    </span>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.6fr)_minmax(320px,0.8fr)] gap-8 items-start">
                    <div class="space-y-4">
                        <h1 class="text-4xl md:text-5xl font-extrabold font-['Outfit'] tracking-tight text-text-main leading-tight">
                            Dados <span class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple">Abertos</span>
                        </h1>
                        <p class="text-text-secondary max-w-3xl text-base leading-relaxed">
                            Repositório público dos arquivos que alimentam o portal Horizon.
                            Use esta página para baixar datasets em JSON, comparar bases canônicas
                            com marts analíticos e inspecionar rapidamente a estrutura esperada de cada arquivo.
                        </p>

                        <div class="flex flex-wrap gap-3 pt-2">
                            <a
                                href="#datasets-canonical"
                                class="inline-flex items-center gap-2 rounded-2xl border border-premium-accent/20 bg-premium-accent/[0.08] px-4 py-2 text-sm font-bold text-premium-accent transition-colors hover:bg-premium-accent/15"
                            >
                                Ver bases canônicas
                            </a>
                            <a
                                href="#datasets-mart"
                                class="inline-flex items-center gap-2 rounded-2xl border border-amber-400/20 bg-amber-400/[0.08] px-4 py-2 text-sm font-bold text-amber-300 transition-colors hover:bg-amber-400/15"
                            >
                                Ver marts analíticos
                            </a>
                            <a
                                href="#open-data-guide"
                                class="inline-flex items-center gap-2 rounded-2xl border border-border-main bg-white/[0.02] px-4 py-2 text-sm font-bold text-text-main transition-colors hover:border-premium-purple/20 hover:bg-premium-purple/[0.06]"
                            >
                                Como usar
                            </a>
                        </div>
                    </div>

                    <div class="rounded-[2rem] border border-border-main bg-black/10 p-5 backdrop-blur-sm">
                        <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-text-muted">
                            Leitura rápida
                        </p>
                        <div class="mt-4 grid grid-cols-1 gap-3">
                            <div class="rounded-2xl border border-border-main bg-white/[0.03] p-4">
                                <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-text-secondary">Bases canônicas</p>
                                <p class="mt-2 text-2xl font-bold font-['Outfit'] text-text-main">{canonicalDatasets.length}</p>
                                <p class="mt-1 text-sm text-text-secondary">Entidades normalizadas para navegação, vínculo e reconciliação.</p>
                            </div>
                            <div class="rounded-2xl border border-border-main bg-white/[0.03] p-4">
                                <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-text-secondary">Marts analíticos</p>
                                <p class="mt-2 text-2xl font-bold font-['Outfit'] text-text-main">{martDatasets.length}</p>
                                <p class="mt-1 text-sm text-text-secondary">Agregações prontas para KPIs, gráficos e séries históricas.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {catalogHighlights.map((highlight) => (
                        <article class={`rounded-3xl border p-5 ${highlight.surfaceClass}`}>
                            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-text-secondary">
                                {highlight.label}
                            </p>
                            <div class={`mt-3 text-4xl font-extrabold font-['Outfit'] ${highlight.accentClass}`}>
                                {highlight.value}
                            </div>
                            <p class="mt-2 text-sm text-text-secondary">
                                {highlight.description}
                            </p>
                        </article>
                    ))}
                </div>
            </div>
        </header>

        <section
            id="open-data-guide"
            class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.25fr)_minmax(320px,0.75fr)] gap-6"
        >
            <article class="glass-card border border-border-main p-6 md:p-8">
                <div class="flex items-center gap-3 mb-5">
                    <div class="w-11 h-11 rounded-2xl bg-premium-accent/10 border border-premium-accent/20 flex items-center justify-center text-premium-accent">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"></path><path d="m17 8-5-5-5 5"></path><path d="M20 21H4"></path></svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold font-['Outfit'] text-text-main">Como usar este catálogo</h2>
                        <p class="text-text-secondary text-sm mt-1">Baixe, valide e integre os dados sem depender da interface do portal.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {guideCards.map((card, index) => (
                        <article class="rounded-3xl border border-border-main bg-white/[0.03] p-5">
                            <div class="w-9 h-9 rounded-2xl bg-premium-purple/10 border border-premium-purple/20 flex items-center justify-center text-sm font-bold text-premium-purple">
                                {index + 1}
                            </div>
                            <h3 class="mt-4 text-base font-bold text-text-main">{card.title}</h3>
                            <p class="mt-2 text-sm leading-relaxed text-text-secondary">{card.body}</p>
                        </article>
                    ))}
                </div>
            </article>

            <article class="glass-card border border-border-main p-6 md:p-8">
                <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-premium-accent">
                    Convenções
                </p>
                <div class="mt-5 space-y-4">
                    <div class="rounded-2xl border border-border-main bg-white/[0.03] p-4">
                        <p class="text-sm font-bold text-text-main">Canonical</p>
                        <p class="mt-1 text-sm text-text-secondary">
                            Preserva entidades, vínculos e granularidade de origem para exploração e reconciliação.
                        </p>
                    </div>
                    <div class="rounded-2xl border border-border-main bg-white/[0.03] p-4">
                        <p class="text-sm font-bold text-text-main">Mart</p>
                        <p class="mt-1 text-sm text-text-secondary">
                            Resume métricas prontas para painéis, KPIs e análises comparativas.
                        </p>
                    </div>
                    <div class="rounded-2xl border border-border-main bg-white/[0.03] p-4">
                        <p class="text-sm font-bold text-text-main">Prévia estrutural</p>
                        <p class="mt-1 text-sm text-text-secondary">
                            Mostra o primeiro registro ou o bloco raiz para servir como contrato rápido do arquivo.
                        </p>
                    </div>
                </div>
            </article>
        </section>

        <section class="glass-card border border-border-main p-6 md:p-8 space-y-6">
            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
                <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-text-muted">
                        Explorar datasets
                    </p>
                    <h2 class="text-2xl font-bold font-['Outfit'] text-text-main mt-1">
                        Encontre a base certa mais rápido
                    </h2>
                </div>
                <div class="text-sm text-text-secondary">
                    <span id="datasetVisibleCount">{datasets.length}</span> arquivos visíveis
                </div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_auto] gap-4 items-center">
                <div class="relative">
                    <label for="datasetSearch" class="sr-only">Buscar dataset</label>
                    <input
                        type="text"
                        id="datasetSearch"
                        placeholder="Buscar por nome, descrição ou campos..."
                        class="w-full bg-glass-bg border border-border-main rounded-2xl px-12 py-4 text-sm focus:outline-none focus:ring-2 focus:ring-premium-accent/50 focus:border-premium-accent transition-all text-text-main shadow-lg shadow-premium-accent/5"
                    />
                    <svg
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-secondary"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
