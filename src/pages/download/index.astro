---
import Layout from "../../layouts/Layout.astro";

import advisorshipsCanonical from "../../data/canonical/advisorships_canonical.json";
import articlesCanonical from "../../data/canonical/articles_canonical.json";
import campusesCanonical from "../../data/canonical/campuses_canonical.json";
import fellowshipsCanonical from "../../data/canonical/fellowships_canonical.json";
import initiativeTypesCanonical from "../../data/canonical/initiative_types_canonical.json";
import initiativesCanonical from "../../data/canonical/initiatives_canonical.json";
import knowledgeAreasCanonical from "../../data/canonical/knowledge_areas_canonical.json";
import organizationsCanonical from "../../data/canonical/organizations_canonical.json";
import researchGroupsCanonical from "../../data/canonical/research_groups_canonical.json";
import researchersCanonical from "../../data/canonical/researchers_canonical.json";
import advisorshipAnalytics from "../../data/mart/advisorship_analytics.json";
import initiativesMart from "../../data/mart/initiatives_analytics_mart.json";
import knowledgeAreasMart from "../../data/mart/knowledge_areas_mart.json";

type DatasetType = "Canonical" | "Mart";

interface DatasetItem {
    id: string;
    name: string;
    description: string;
    type: DatasetType;
    folder: "canonical" | "mart";
    countLabel: string;
    data: unknown;
    structure: string;
}

const buildStructurePreview = (data: unknown) => {
    if (Array.isArray(data)) {
        return JSON.stringify(data[0] ?? {}, null, 2);
    }

    return JSON.stringify(data, null, 2);
};

const buildCountLabel = (data: unknown) => {
    if (Array.isArray(data)) {
        return `${data.length} registros`;
    }

    if (data && typeof data === "object") {
        return `${Object.keys(data).length} blocos`;
    }

    return "Sem contagem";
};

const datasets: DatasetItem[] = [
    {
        id: "advisorships",
        name: "advisorships_canonical.json",
        description: "Orientações com estudante, tipologia, período e status.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(advisorshipsCanonical),
        data: advisorshipsCanonical,
        structure: buildStructurePreview(advisorshipsCanonical),
    },
    {
        id: "articles",
        name: "articles_canonical.json",
        description: "Artigos publicados com ano, tipo, DOI e veículo.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(articlesCanonical),
        data: articlesCanonical,
        structure: buildStructurePreview(articlesCanonical),
    },
    {
        id: "campuses",
        name: "campuses_canonical.json",
        description: "Cadastro de campi usado nos vínculos e filtros do portal.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(campusesCanonical),
        data: campusesCanonical,
        structure: buildStructurePreview(campusesCanonical),
    },
    {
        id: "fellowships",
        name: "fellowships_canonical.json",
        description: "Bolsas e relações de fomento ligadas às iniciativas.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(fellowshipsCanonical),
        data: fellowshipsCanonical,
        structure: buildStructurePreview(fellowshipsCanonical),
    },
    {
        id: "initiative-types",
        name: "initiative_types_canonical.json",
        description: "Tipos de iniciativa utilizados na base do portal.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(initiativeTypesCanonical),
        data: initiativeTypesCanonical,
        structure: buildStructurePreview(initiativeTypesCanonical),
    },
    {
        id: "initiatives",
        name: "initiatives_canonical.json",
        description: "Projetos e iniciativas com vigência, equipe e tipo.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(initiativesCanonical),
        data: initiativesCanonical,
        structure: buildStructurePreview(initiativesCanonical),
    },
    {
        id: "knowledge-areas",
        name: "knowledge_areas_canonical.json",
        description: "Tabela de áreas do conhecimento adotadas no portal.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(knowledgeAreasCanonical),
        data: knowledgeAreasCanonical,
        structure: buildStructurePreview(knowledgeAreasCanonical),
    },
    {
        id: "organizations",
        name: "organizations_canonical.json",
        description: "Organizações financiadoras, parceiras e relacionadas.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(organizationsCanonical),
        data: organizationsCanonical,
        structure: buildStructurePreview(organizationsCanonical),
    },
    {
        id: "groups",
        name: "research_groups_canonical.json",
        description: "Grupos de pesquisa com líderes, membros e áreas.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(researchGroupsCanonical),
        data: researchGroupsCanonical,
        structure: buildStructurePreview(researchGroupsCanonical),
    },
    {
        id: "researchers",
        name: "researchers_canonical.json",
        description: "Pesquisadores com perfil, vínculos, artigos e orientações.",
        type: "Canonical",
        folder: "canonical",
        countLabel: buildCountLabel(researchersCanonical),
        data: researchersCanonical,
        structure: buildStructurePreview(researchersCanonical),
    },
    {
        id: "advisorship-analytics",
        name: "advisorship_analytics.json",
        description: "Agregações analíticas das orientações para dashboards.",
        type: "Mart",
        folder: "mart",
        countLabel: buildCountLabel(advisorshipAnalytics),
        data: advisorshipAnalytics,
        structure: buildStructurePreview(advisorshipAnalytics),
    },
    {
        id: "initiatives-analytics",
        name: "initiatives_analytics_mart.json",
        description: "Agregações de projetos com resumo, evolução e composição.",
        type: "Mart",
        folder: "mart",
        countLabel: buildCountLabel(initiativesMart),
        data: initiativesMart,
        structure: buildStructurePreview(initiativesMart),
    },
    {
        id: "knowledge-areas-mart",
        name: "knowledge_areas_mart.json",
        description: "Matriz analítica das áreas com contagens e agrupamentos.",
        type: "Mart",
        folder: "mart",
        countLabel: buildCountLabel(knowledgeAreasMart),
        data: knowledgeAreasMart,
        structure: buildStructurePreview(knowledgeAreasMart),
    },
];

const canonicalDatasets = datasets.filter((dataset) => dataset.type === "Canonical");
const martDatasets = datasets.filter((dataset) => dataset.type === "Mart");
---

<Layout title="Dados Abertos">
    <div class="space-y-10 pb-12">
        <header class="flex flex-col gap-6">
            <div>
                <h1 class="text-4xl font-extrabold font-['Outfit'] tracking-tight text-text-main">
                    Dados <span class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple">Abertos</span>
                </h1>
                <p class="text-text-secondary mt-2 max-w-3xl">
                    Catálogo dos arquivos disponíveis em <span class="font-mono text-text-main">src/data</span>.
                    Aqui você pode baixar as bases canônicas e os marts analíticos que alimentam o portal.
                </p>
            </div>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="glass-card p-6">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-text-muted">Bases Canônicas</p>
                <p class="text-3xl font-bold font-['Outfit'] text-text-main mt-2">{canonicalDatasets.length}</p>
                <p class="text-sm text-text-secondary mt-1">Arquivos brutos normalizados para navegação e vínculo de entidades.</p>
            </div>
            <div class="glass-card p-6">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-text-muted">Marts Analíticos</p>
                <p class="text-3xl font-bold font-['Outfit'] text-text-main mt-2">{martDatasets.length}</p>
                <p class="text-sm text-text-secondary mt-1">Agregações preparadas para gráficos, KPIs e séries históricas.</p>
            </div>
        </div>

        <section class="space-y-5">
            <div class="flex items-end justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-bold font-['Outfit'] text-text-main">Bases Canônicas</h2>
                    <p class="text-text-secondary mt-1">Arquivos em <span class="font-mono text-text-main">src/data/canonical</span>.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                {canonicalDatasets.map((dataset) => (
                    <article class="glass-card p-6 flex flex-col gap-4 h-full hover:border-premium-accent/40 transition-all duration-300">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-500">Canonical</p>
                                <h3 class="text-lg font-bold text-text-main font-['Outfit'] mt-2 break-all">{dataset.name}</h3>
                            </div>
                            <span class="px-3 py-1 rounded-full text-xs font-bold border bg-emerald-500/10 text-emerald-500 border-emerald-500/20">
                                {dataset.countLabel}
                            </span>
                        </div>

                        <p class="text-sm text-text-secondary leading-relaxed">
                            {dataset.description}
                        </p>

                        <p class="text-xs text-text-muted uppercase tracking-[0.18em]">
                            <span class="font-mono normal-case">src/data/{dataset.folder}</span>
                        </p>

                        <details class="group/details mt-2">
                            <summary class="cursor-pointer text-xs font-bold text-premium-accent uppercase tracking-wider hover:text-premium-purple transition-colors list-none flex items-center gap-2">
                                <span class="group-open/details:hidden">Ver Estrutura</span>
                                <span class="hidden group-open/details:inline">Ocultar Estrutura</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-open/details:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </summary>
                            <div class="mt-3 bg-slate-900 rounded-lg p-3 border border-white/10 overflow-hidden">
                                <pre class="text-[10px] text-slate-300 font-mono overflow-x-auto whitespace-pre no-scrollbar"><code>{dataset.structure}</code></pre>
                            </div>
                        </details>

                        <div class="mt-auto pt-4 border-t border-border-main flex items-center justify-end">
                            <button
                                class="download-btn flex items-center gap-2 text-sm font-bold text-premium-accent hover:text-white hover:bg-premium-accent px-3 py-1.5 rounded-lg transition-all duration-300"
                                data-filename={dataset.name}
                                data-blob={JSON.stringify(dataset.data)}
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                                Download
                            </button>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <section class="space-y-5">
            <div class="flex items-end justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-bold font-['Outfit'] text-text-main">Marts Analíticos</h2>
                    <p class="text-text-secondary mt-1">Arquivos em <span class="font-mono text-text-main">src/data/mart</span>.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                {martDatasets.map((dataset) => (
                    <article class="glass-card p-6 flex flex-col gap-4 h-full hover:border-premium-accent/40 transition-all duration-300">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-500">Mart</p>
                                <h3 class="text-lg font-bold text-text-main font-['Outfit'] mt-2 break-all">{dataset.name}</h3>
                            </div>
                            <span class="px-3 py-1 rounded-full text-xs font-bold border bg-amber-500/10 text-amber-500 border-amber-500/20">
                                {dataset.countLabel}
                            </span>
                        </div>

                        <p class="text-sm text-text-secondary leading-relaxed">
                            {dataset.description}
                        </p>

                        <p class="text-xs text-text-muted uppercase tracking-[0.18em]">
                            <span class="font-mono normal-case">src/data/{dataset.folder}</span>
                        </p>

                        <details class="group/details mt-2">
                            <summary class="cursor-pointer text-xs font-bold text-premium-accent uppercase tracking-wider hover:text-premium-purple transition-colors list-none flex items-center gap-2">
                                <span class="group-open/details:hidden">Ver Estrutura</span>
                                <span class="hidden group-open/details:inline">Ocultar Estrutura</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-open/details:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </summary>
                            <div class="mt-3 bg-slate-900 rounded-lg p-3 border border-white/10 overflow-hidden">
                                <pre class="text-[10px] text-slate-300 font-mono overflow-x-auto whitespace-pre no-scrollbar"><code>{dataset.structure}</code></pre>
                            </div>
                        </details>

                        <div class="mt-auto pt-4 border-t border-border-main flex items-center justify-end">
                            <button
                                class="download-btn flex items-center gap-2 text-sm font-bold text-premium-accent hover:text-white hover:bg-premium-accent px-3 py-1.5 rounded-lg transition-all duration-300"
                                data-filename={dataset.name}
                                data-blob={JSON.stringify(dataset.data)}
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                                Download
                            </button>
                        </div>
                    </article>
                ))}
            </div>
        </section>
    </div>
</Layout>

<script>
    function setupDownloads() {
        document.querySelectorAll(".download-btn").forEach((button) => {
            button.addEventListener("click", () => {
                const filename = button.getAttribute("data-filename");
                const content = button.getAttribute("data-blob");

                if (!filename || !content) return;

                const blob = new Blob([content], { type: "application/json" });
                const url = window.URL.createObjectURL(blob);
                const anchor = document.createElement("a");
                anchor.style.display = "none";
                anchor.href = url;
                anchor.download = filename;

                document.body.appendChild(anchor);
                anchor.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(anchor);
            });
        });
    }

    setupDownloads();
    document.addEventListener("astro:after-swap", setupDownloads);
</script>
