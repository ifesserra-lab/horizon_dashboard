                        data-dataset-filter="canonical"
                    >
                        Canonical
                    </button>
                    <button
                        class="dataset-filter-chip inline-flex items-center rounded-full border border-outline bg-white/[0.03] px-4 py-2 text-sm font-bold text-text-secondary transition-colors hover:border-sky-border hover:text-text-main"
                        data-dataset-filter="tracking"
                    >
                        Tracking
                    </button>
                    <button
                        class="dataset-filter-chip inline-flex items-center rounded-full border border-outline bg-white/[0.03] px-4 py-2 text-sm font-bold text-text-secondary transition-colors hover:border-premium-purple/20 hover:text-text-main"
                        data-dataset-filter="graph"
                    >
                        Grafos
                    </button>
                    <button
                        class="dataset-filter-chip inline-flex items-center rounded-full border border-outline bg-white/[0.03] px-4 py-2 text-sm font-bold text-text-secondary transition-colors hover:border-amber-400/20 hover:text-text-main"
                        data-dataset-filter="mart"
