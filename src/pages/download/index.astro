    summaryDescription: string;
}

const isObjectRecord = (
    value: unknown,
): value is Record<string, unknown> =>
    Boolean(value) && typeof value === "object" && !Array.isArray(value);

const isGraphDataset = (
    data: unknown,
): data is {
    metadata?: Record<string, unknown>;
    graph_stats?: Record<string, unknown>;
    graph: { nodes?: unknown[]; edges?: unknown[] };
} => {
    if (!isObjectRecord(data) || !isObjectRecord(data.graph)) {
        return false;
    }

    return Array.isArray(data.graph.nodes) && Array.isArray(data.graph.edges);
};

const isGraphManifestDataset = (
    data: unknown,
): data is {
    metadata?: Record<string, unknown>;
    graphs: unknown[];
} => isObjectRecord(data) && Array.isArray(data.graphs);

const buildStructurePreview = (data: unknown) => {
    if (Array.isArray(data)) {
        return JSON.stringify(data[0] ?? {}, null, 2);
    }

    if (isGraphDataset(data)) {
        return JSON.stringify(
            {
                metadata: data.metadata ?? {},
                graph_stats: data.graph_stats ?? {},
                sample_nodes: data.graph.nodes.slice(0, 1),
                sample_edges: data.graph.edges.slice(0, 1),
            },
            null,
            2,
        );
    }

    if (isGraphManifestDataset(data)) {
        return JSON.stringify(
            {
                metadata: data.metadata ?? {},
                sample_graphs: data.graphs.slice(0, 2),
            },
            null,
            2,
        );
    }

    return JSON.stringify(data, null, 2);
};

const buildCountValue = (data: unknown) => {
    if (isGraphDataset(data)) {
        return data.graph.nodes.length;
    }

    if (isGraphManifestDataset(data)) {
        return data.graphs.length;
    }

    if (Array.isArray(data)) {
        return data.length;
    }

    if (data && typeof data === "object") {
        return Object.keys(data).length;
    }

    return 0;
};

const buildCountLabel = (data: unknown) => {
    if (isGraphDataset(data)) {
        return `${data.graph.nodes.length} nós · ${data.graph.edges.length} arestas`;
    }

    if (isGraphManifestDataset(data)) {
        return `${data.graphs.length} grafos`;
    }

    if (Array.isArray(data)) {
        return `${data.length} registros`;
    }

    if (data && typeof data === "object") {
        return `${Object.keys(data).length} blocos`;
    }

    return "Sem contagem";
};

const buildSizeBytes = (data: unknown) =>
    Buffer.byteLength(JSON.stringify(data), "utf8");

const buildSizeLabel = (data: unknown) => {
    const bytes = buildSizeBytes(data);

    if (bytes < 1024) {
        return `${bytes} B`;
    }

    if (bytes < 1024 * 1024) {
        return `${(bytes / 1024).toFixed(1)} KB`;
    }

    return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
};

const buildSampleKeys = (data: unknown) => {
    if (isGraphDataset(data)) {
        const nodeKeys =
            data.graph.nodes[0] &&
            isObjectRecord(data.graph.nodes[0])
                ? Object.keys(data.graph.nodes[0]).slice(0, 3)
                : [];
        const edgeKeys =
            data.graph.edges[0] &&
            isObjectRecord(data.graph.edges[0])
                ? Object.keys(data.graph.edges[0]).slice(0, 3)
                : [];

        return [
            "metadata",
            "graph_stats",
            ...nodeKeys.map((key) => `node.${key}`),
            ...edgeKeys.map((key) => `edge.${key}`),
        ].slice(0, 6);
    }

    if (isGraphManifestDataset(data)) {
        const firstGraph = data.graphs[0];
        if (isObjectRecord(firstGraph)) {
            return Object.keys(firstGraph).slice(0, 6);
        }

        return ["metadata", "graphs"];
    }

    if (Array.isArray(data)) {
        const firstItem = data[0];
        if (firstItem && typeof firstItem === "object" && !Array.isArray(firstItem)) {
            return Object.keys(firstItem).slice(0, 6);
        }
        return [];
    }

    if (data && typeof data === "object") {
        return Object.keys(data).slice(0, 6);
    }

    return [];
};

const buildSearchText = (
    name: string,
    description: string,
    badgeLabel: string,
    sampleKeys: string[],
) => [name, description, badgeLabel, ...sampleKeys].join(" ").toLowerCase();

const createDataset = ({
    id,
    name,
    description,
    section,
    badgeLabel,
    data,
    downloadHref,
}: DatasetDefinition): DatasetItem => {
    const sampleKeys = buildSampleKeys(data);
    const sizeBytes = buildSizeBytes(data);

    return {
        id,
        name,
        description,
        section,
        badgeLabel,
        countValue: buildCountValue(data),
        countLabel: buildCountLabel(data),
        sizeBytes,
        sizeLabel: buildSizeLabel(data),
        structure: buildStructurePreview(data),
        sampleKeys,
        downloadHref,
        searchText: buildSearchText(name, description, badgeLabel, sampleKeys),
    };
};

