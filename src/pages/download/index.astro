            "border-premium-purple/20 bg-premium-purple/10 text-premium-purple",
        countClass:
            "border-premium-purple/20 bg-premium-purple/10 text-premium-purple",
        hoverClass: "hover:border-premium-purple/40",
        buttonClass:
            "border-premium-purple/20 bg-premium-purple/10 text-premium-purple hover:bg-premium-purple hover:text-white",
        summarySurfaceClass:
            "rounded-2xl border border-outline bg-white/[0.03] p-4",
        summaryValueClass: "text-premium-purple",
        summaryDescription:
            "Recortes relacionais e manifests para exploração de redes.",
    },
    {
        key: "mart",
        anchorId: "datasets-mart",
        title: "Marts Analíticos",
        description: "Agregações prontas para KPIs, gráficos e leituras sintéticas.",
        chipLabel: "Marts",
        badgeClass:
            "border-amber-400/20 bg-amber-400/10 text-amber-300",
        countClass:
            "border-amber-400/20 bg-amber-400/10 text-amber-300",
        hoverClass: "hover:border-amber-400/40",
        buttonClass:
            "border-amber-400/20 bg-amber-400/10 text-amber-300 hover:bg-amber-400 hover:text-slate-950",
        summarySurfaceClass:
            "rounded-2xl border border-outline bg-white/[0.03] p-4",
        summaryValueClass: "text-amber-300",
        summaryDescription:
            "Agregações prontas para séries, comparativos e dashboards.",
    },
];

const datasetSections = datasetSectionsMeta.map((section) => ({
    ...section,
    datasets: datasets.filter((dataset) => dataset.section === section.key),
}));

const canonicalDatasets = datasetSections.find((section) => section.key === "canonical")?.datasets || [];
const trackingDatasets = datasetSections.find((section) => section.key === "tracking")?.datasets || [];
const graphDatasets = datasetSections.find((section) => section.key === "graph")?.datasets || [];
const martDatasets = datasetSections.find((section) => section.key === "mart")?.datasets || [];
const totalDatasets = datasets.length;
const totalItems = datasets.reduce((sum, dataset) => sum + dataset.countValue, 0);
const totalDownloadBytes = datasets.reduce(
    (sum, dataset) => sum + dataset.sizeBytes,
    0,
);

const formatSummaryBytes = (bytes: number) => {
    if (bytes < 1024 * 1024) {
        return `${(bytes / 1024).toFixed(0)} KB`;
    }

    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
};

const latestIngestionDate = [...(ingestionRunsCanonical as Array<Record<string, string | null>>)]
    .map((run) => run.finished_at || run.started_at || "")
    .filter(Boolean)
    .sort()
    .at(-1);

const formatDateTime = (value: string | undefined) => {
    if (!value) {
        return "Sem data";
    }

    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
        return value;
    }

    return date.toLocaleString("pt-BR", {
        dateStyle: "short",
        timeStyle: "short",
    });
};

const catalogHighlights = [
    {
        label: "Datasets disponíveis",
        value: totalDatasets,
        description: "Arquivos prontos para download direto em JSON.",
        accentClass: "text-premium-accent",
        surfaceClass: "bg-premium-accent/[0.08] border-premium-accent/20",
    },
    {
        label: "Entradas catalogadas",
        value: totalItems.toLocaleString("pt-BR"),
        description: "Registros, nós ou grafos somados entre as categorias catalogadas.",
        accentClass: "text-emerald-text",
        surfaceClass: "bg-emerald-surface border border-emerald-border",
    },
    {
        label: "Peso do catálogo",
        value: formatSummaryBytes(totalDownloadBytes),
        description: "Estimativa de navegação e prévia estrutural exibida nesta página.",
        accentClass: "text-amber-400",
        surfaceClass: "bg-amber-400/[0.08] border-amber-400/20",
    },
    {
        label: "Última ingestão",
        value: formatDateTime(latestIngestionDate),
        description: "Referência temporal da última execução catalogada na base canônica.",
        accentClass: "text-sky-text",
        surfaceClass: "bg-sky-surface border border-sky-border",
    },
];

const guideCards = [
    {
        title: "Baixe o arquivo bruto",
        body: "Cada card aponta para o JSON gerado pelo build. O download não depende mais de blobs inline no HTML.",
    },
    {
        title: "Use a estrutura como contrato",
        body: "A prévia mostra o primeiro registro ou o bloco raiz para acelerar integrações, ETL e exploração em notebook.",
    },
    {
        title: "Separe base e análise",
        body: "As bases canônicas preservam entidades e vínculos. Os marts já chegam agregados para KPIs, séries e dashboards.",
    },
    {
        title: "Audite a pipeline",
        body: "Use tracking, assertivas e change logs para entender de onde veio cada atributo e como a entidade mudou ao longo das cargas.",
    },
    {
        title: "Explore redes complexas",
        body: "Os arquivos de grafos já incluem metadados, estatísticas de rede e arestas para estudos de colaboração e relacionamento.",
    },
];
---

<Layout title="Dados Abertos">
    <div class="space-y-10 pb-12" id="open-data-catalog">
        <header class="relative overflow-hidden glass-card border border-outline p-8 md:p-10">
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute -top-24 right-0 h-56 w-56 rounded-full bg-premium-accent/10 blur-3xl"></div>
                <div class="absolute bottom-0 left-0 h-48 w-48 rounded-full bg-premium-purple/10 blur-3xl"></div>
            </div>

            <div class="relative space-y-8">
                <div class="flex flex-wrap gap-2">
                    <span class="inline-flex items-center gap-2 rounded-full border border-premium-accent/20 bg-premium-accent/[0.08] px-3 py-1 text-[10px] font-bold uppercase tracking-[0.22em] text-premium-accent">
                        Catálogo técnico
                    </span>
                    <span class="inline-flex items-center gap-2 rounded-full border border-emerald-border bg-emerald-surface px-3 py-1 text-[10px] font-bold uppercase tracking-[0.22em] text-emerald-text">
                        Download direto JSON
                    </span>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.6fr)_minmax(320px,0.8fr)] gap-8 items-start">
                    <div class="space-y-4">
                        <h1 class="text-4xl md:text-5xl font-extrabold font-['Outfit'] tracking-tight text-text-main leading-tight">
                            Dados <span class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple">Abertos</span>
                        </h1>
                        <p class="text-text-secondary max-w-3xl text-base leading-relaxed">
                            Repositório público dos arquivos que alimentam o portal Horizon.
                            Use esta página para baixar datasets em JSON, navegar por bases
                            canônicas, rastreabilidade, grafos e marts analíticos, além de
                            inspecionar rapidamente a estrutura esperada de cada arquivo.
                        </p>

                        <div class="flex flex-wrap gap-3 pt-2">
                            {datasetSections.map((section) => (
                                <a
                                    href={`#${section.anchorId}`}
                                    class="inline-flex items-center gap-2 rounded-2xl border border-outline bg-white/[0.02] px-4 py-2 text-sm font-bold text-text-main transition-colors hover:border-premium-accent/20 hover:bg-premium-accent/[0.08]"
                                >
                                    {section.title}
                                </a>
                            ))}
                            <a
                                href="#open-data-guide"
                                class="inline-flex items-center gap-2 rounded-2xl border border-outline bg-white/[0.02] px-4 py-2 text-sm font-bold text-text-main transition-colors hover:border-premium-purple/20 hover:bg-premium-purple/[0.06]"
                            >
                                Como usar
                            </a>
                        </div>
                    </div>

                    <div class="rounded-[2rem] border border-outline bg-black/10 p-5 backdrop-blur-sm">
                        <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-text-muted">
                            Leitura rápida
                        </p>
                        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {datasetSections.map((section) => (
                                <div class={section.summarySurfaceClass}>
                                    <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-text-secondary">
                                        {section.title}
                                    </p>
                                    <p class={`mt-2 text-2xl font-bold font-['Outfit'] ${section.summaryValueClass}`}>
                                        {section.datasets.length}
                                    </p>
                                    <p class="mt-1 text-sm text-text-secondary">
                                        {section.summaryDescription}
                                    </p>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                    {catalogHighlights.map((highlight) => (
                        <article class={`rounded-3xl border p-5 ${highlight.surfaceClass}`}>
                            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-text-secondary">
                                {highlight.label}
                            </p>
                            <div class={`mt-3 text-4xl font-extrabold font-['Outfit'] ${highlight.accentClass}`}>
