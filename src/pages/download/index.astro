                <div class="mt-5 space-y-4">
                    {datasetSections.map((section) => (
                        <div class="rounded-2xl border border-outline bg-white/[0.03] p-4">
                            <p class="text-sm font-bold text-text-main">{section.title}</p>
                            <p class="mt-1 text-sm text-text-secondary">
                                {section.summaryDescription}
                            </p>
                        </div>
