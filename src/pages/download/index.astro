                                    <span class="group-open/details:hidden">Ver estrutura</span>
                                    <span class="hidden group-open/details:inline">Ocultar estrutura</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-open/details:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                </summary>
                                <div class="mt-3 overflow-hidden rounded-2xl border border-white/10 bg-slate-950 p-3">
                                    <pre class="no-scrollbar overflow-x-auto whitespace-pre text-[10px] text-slate-300 font-mono"><code>{dataset.structure}</code></pre>
                                </div>
                            </details>

                            <div class="mt-auto pt-4 border-t border-outline flex items-center justify-between gap-3">
                                <span class="text-xs text-text-secondary">
                                    Arquivo JSON
                                </span>
                                <a
                                    href={dataset.downloadHref}
                                    download={dataset.name}
                                    class={`inline-flex items-center gap-2 rounded-xl border px-4 py-2 text-sm font-bold transition-colors ${section.buttonClass}`}
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
                                    Download
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
            </section>
        ))}

        <div
            id="datasetEmptyState"
            class="hidden flex-col items-center justify-center py-20 text-center glass-card border border-dashed border-outline"
        >
            <div class="w-16 h-16 rounded-3xl bg-white/[0.03] border border-outline flex items-center justify-center text-text-secondary mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path><path d="M8 11h6"></path></svg>
            </div>
            <h3 class="text-xl font-bold font-['Outfit'] text-text-main">Nenhum dataset encontrado</h3>
            <p class="mt-2 max-w-md text-text-secondary">
                Ajuste sua busca ou volte para o filtro <strong>Todos</strong> para ver o catálogo completo.
            </p>
        </div>
    </div>
</Layout>

<script>
    import { normalizeSearchText } from "../../lib/search";

    function setupOpenDataCatalog() {
        const root = document.getElementById("open-data-catalog");
        if (!root || root.dataset.initialized === "true") return;
        root.dataset.initialized = "true";

        const searchInput = document.getElementById(
            "datasetSearch",
        ) as HTMLInputElement | null;
        const resetButton = document.getElementById("resetDatasetSearch");
        const visibleCountLabel = document.getElementById("datasetVisibleCount");
        const emptyState = document.getElementById("datasetEmptyState");
        const cards = Array.from(
            document.querySelectorAll<HTMLElement>("[data-dataset-card]"),
        );
        const sections = Array.from(
            document.querySelectorAll<HTMLElement>("[data-dataset-section]"),
        );
        const filterButtons = Array.from(
            document.querySelectorAll<HTMLButtonElement>("[data-dataset-filter]"),
        );

        let activeFilter = "all";

        const syncFilterButtonState = () => {
            filterButtons.forEach((button) => {
                const isActive = button.dataset.datasetFilter === activeFilter;
                button.classList.toggle("border-premium-accent/20", isActive);
                button.classList.toggle("bg-premium-accent/[0.08]", isActive);
                button.classList.toggle("text-premium-accent", isActive);
                button.classList.toggle("border-outline", !isActive);
                button.classList.toggle("bg-white/[0.03]", !isActive);
                button.classList.toggle("text-text-secondary", !isActive);
            });
        };

        const applyFilters = () => {
            const query = normalizeSearchText(searchInput?.value || "");
            let visibleCards = 0;

            if (query) {
                resetButton?.classList.remove("hidden");
            } else {
                resetButton?.classList.add("hidden");
            }

            cards.forEach((card) => {
                const matchesType =
                    activeFilter === "all" ||
                    card.dataset.datasetType === activeFilter;
                const matchesQuery =
                    !query ||
                    normalizeSearchText(card.dataset.search || "").includes(query);
                const isVisible = matchesType && matchesQuery;

                card.classList.toggle("hidden", !isVisible);
                if (isVisible) visibleCards += 1;
            });

            sections.forEach((section) => {
                const visibleSectionCards = section.querySelectorAll(
                    "[data-dataset-card]:not(.hidden)",
                ).length;
                section.classList.toggle("hidden", visibleSectionCards === 0);
            });

            if (visibleCountLabel) {
                visibleCountLabel.textContent = String(visibleCards);
            }

            emptyState?.classList.toggle("hidden", visibleCards !== 0);
            emptyState?.classList.toggle("flex", visibleCards === 0);
        };

        filterButtons.forEach((button) => {
            button.addEventListener("click", () => {
                activeFilter = button.dataset.datasetFilter || "all";
                syncFilterButtonState();
                applyFilters();
            });
        });

        searchInput?.addEventListener("input", applyFilters);
        resetButton?.addEventListener("click", () => {
            if (searchInput) {
                searchInput.value = "";
            }
            applyFilters();
            searchInput?.focus();
        });

        syncFilterButtonState();
        applyFilters();
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupOpenDataCatalog, {
            once: true,
        });
    } else {
        setupOpenDataCatalog();
    }

    document.addEventListener("astro:after-swap", setupOpenDataCatalog);
</script>
