                            </p>

                            <div class="grid grid-cols-2 gap-3 text-sm">
                                <div class="rounded-2xl border border-outline bg-white/[0.03] px-4 py-3">
                                    <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-text-secondary">Tamanho</p>
                                    <p class="mt-1 font-semibold text-text-main">{dataset.sizeLabel}</p>
                                </div>
                                <div class="rounded-2xl border border-outline bg-white/[0.03] px-4 py-3">
                                    <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-text-secondary">Origem</p>
                                    <p class="mt-1 font-mono text-xs text-text-main">src/data</p>
                                </div>
                            </div>

                            <div class="space-y-2">
                                <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-text-secondary">
                                    Campos visíveis na prévia
                                </p>
                                <div class="flex flex-wrap gap-2">
                                    {dataset.sampleKeys.length > 0 ? (
                                        dataset.sampleKeys.map((field) => (
                                            <span class="inline-flex items-center rounded-full border border-outline bg-[var(--tag-bg)] px-2.5 py-1 text-[10px] font-bold text-text-secondary">
                                                {field}
                                            </span>
                                        ))
                                    ) : (
                                        <span class="text-sm text-text-secondary">Sem amostra de campos.</span>
                                    )}
