                    ))}
                </div>
            </div>
        </header>

        <section
            id="open-data-guide"
            class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.25fr)_minmax(320px,0.75fr)] gap-6"
        >
            <article class="glass-card border border-outline p-6 md:p-8">
                <div class="flex items-center gap-3 mb-5">
