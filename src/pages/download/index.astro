                id={section.anchorId}
                class="space-y-5"
                data-dataset-section={section.key}
            >
                <div class="flex items-end justify-between gap-4">
                    <div>
                        <h2 class="text-2xl font-bold font-['Outfit'] text-text-main">
                            {section.title}
                        </h2>
                        <p class="text-text-secondary mt-1">
                            {section.description} em <span class="font-mono text-text-main">src/data</span>.
                        </p>
                    </div>
                    <span class="text-xs font-bold uppercase tracking-[0.18em] text-text-muted">
                        {section.datasets.length} arquivos
                    </span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    {section.datasets.map((dataset) => (
                        <article
                            class={`glass-card p-6 flex flex-col gap-5 h-full transition-all duration-300 ${section.hoverClass}`}
                            data-dataset-card
                            data-dataset-type={section.key}
                            data-search={dataset.searchText}
                        >
