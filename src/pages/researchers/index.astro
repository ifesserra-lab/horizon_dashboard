---
import Layout from "../../layouts/Layout.astro";
import type { Researcher } from "../../types/researchers";
import ResearcherFilters from "../../components/researchers/ResearcherFilters.astro";
import ResearcherCard from "../../components/researchers/ResearcherCard.astro";
import ResearcherModal from "../../components/researchers/ResearcherModal.astro";
import ResearcherCharts from "../../components/researchers/ResearcherCharts.astro";
import ResearcherKpiCards from "../../components/researchers/ResearcherKpiCards.astro";
import {
    getCampusNamesFromIds,
    getResearcherCampusIds,
} from "../../lib/tenant-data";
import {
    buildCampusResearcherViews,
    researchersOnly,
} from "../../lib/researcher-collections";
import { buildResearcherStatsById } from "../../lib/researchers-data";

const researchers = researchersOnly as Researcher[];
const campusResearcherViews = buildCampusResearcherViews(researchers);
const researcherStats = buildResearcherStatsById(researchers);
const researcherCards = researchers.map((researcher) => {
    const campusIds = getResearcherCampusIds(researcher);

    return {
        researcher,
        stats: researcherStats[researcher.id],
        campusIds,
        campusNames: getCampusNamesFromIds(campusIds),
    };
});

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Pesquisadores">
    <div class="space-y-10 pb-12">
        <!-- Header -->
        <header class="flex flex-col gap-6">
            <div>
                <h1
                    class="text-4xl font-extrabold font-['Outfit'] tracking-tight text-text-main"
                >
                    Nossos <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple"
                        >Pesquisadores</span
                    >
                </h1>
                <p class="text-text-secondary mt-2 max-w-2xl">
                    Conheça os profissionais que impulsionam a ciência e
                    inovação.
                </p>
            </div>
        </header>

        <div id="researcher-dashboard-views">
            <div data-campus-view="">
                <ResearcherKpiCards researchers={researchers} />
                <ResearcherCharts researchers={researchers} instanceId="all" />
            </div>
            {
                Object.entries(campusResearcherViews).map(
                    ([campusId, campusResearchers]) => (
                        <div data-campus-view={campusId} class="hidden">
                            <ResearcherKpiCards researchers={campusResearchers} />
                            <ResearcherCharts
                                researchers={campusResearchers}
                                instanceId={`campus-${campusId}`}
                            />
                        </div>
                    ),
                )
            }
        </div>

        <!-- Search & Filters -->
        <ResearcherFilters />

        <!-- Researchers Grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
            id="researchersGrid"
            role="region"
            aria-label="Lista de pesquisadores"
        >
            {
                researcherCards.map(({ researcher, stats, campusIds, campusNames }) => (
                    <ResearcherCard
                        researcher={researcher}
                        stats={stats}
                        baseUrl={baseUrl}
                        campusIds={campusIds}
                        campusNames={campusNames}
                    />
                ))
            }
        </div>

        <!-- Empty State -->
        <div
            id="emptyState"
            class="hidden flex-col items-center justify-center py-24 text-center"
        >
            <div
                class="w-24 h-24 bg-slate-100 dark:bg-white/5 rounded-3xl flex items-center justify-center mb-6 text-text-secondary border border-border-main border-dashed"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-12 h-12 opacity-50"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="11" cy="11" r="8"></circle><path
                        d="m21 21-4.3-4.3"></path><path d="M8 11h6"></path></svg
                >
            </div>
            <h3 class="text-2xl font-bold font-['Outfit'] text-text-main mb-2">
                Nenhum pesquisador encontrado
            </h3>
            <p class="text-text-secondary max-w-sm">
                Tente buscar por outro nome.
            </p>
        </div>
    </div>

    <!-- Articles/Profile Modal -->
    <ResearcherModal />

    <!-- Data for client-side -->
    <script define:vars={{ researchers }}>
        window.researchersData = researchers;
    </script>

    <script>
        import { normalizeSearchText } from "../../lib/search";
        import {
            getCampusFilterValue,
            splitPipeValues,
            updateCampusViews,
        } from "../../lib/campus-ui";

        // Main Search & Filter Logic
        const searchInput = document.getElementById(
            "researcherSearch",
        ) as HTMLInputElement;
        const resetBtn = document.getElementById("resetFilters");
        const emptyState = document.getElementById("emptyState");
        const cards = document.querySelectorAll(".researcher-card");
        let currentCampusId = localStorage.getItem("preferred-campus") || "";

        function updateResearcherViews(selectedCampus) {
            updateCampusViews(
                "#researcher-dashboard-views [data-campus-view]",
                selectedCampus,
            );
        }

        function filterResearchers() {
            const query = normalizeSearchText(searchInput?.value || "");
            let visibleCount = 0;

            if (query) {
                resetBtn?.classList.remove("hidden");
            } else {
                resetBtn?.classList.add("hidden");
            }

            cards.forEach((card) => {
                const element = card as HTMLElement;
                const searchIndex = element.dataset.search || "";
                const campusIds = splitPipeValues(element.dataset.campusIds);
                const matchesCampus =
                    !currentCampusId || campusIds.includes(currentCampusId);
                const matches =
                    (!query || searchIndex.includes(query)) && matchesCampus;

                if (matches) {
                    element.style.display = "flex";
                    visibleCount++;
                } else {
                    element.style.display = "none";
                }
            });

            if (visibleCount === 0) {
                emptyState?.classList.remove("hidden");
                emptyState?.classList.add("flex");
            } else {
                emptyState?.classList.add("hidden");
                emptyState?.classList.remove("flex");
            }
        }

        searchInput?.addEventListener("input", filterResearchers);
        window.addEventListener("campus-filter-change", (event) => {
            currentCampusId = getCampusFilterValue(event);
            updateResearcherViews(currentCampusId);
            filterResearchers();
        });
        resetBtn?.addEventListener("click", () => {
            searchInput.value = "";
            filterResearchers();
            searchInput.focus();
        });

        // Event listener for opening modal (from cards)
        document.addEventListener("click", (e) => {
            const btn = (e.target as HTMLElement).closest(
                ".view-articles-btn",
            ) as HTMLButtonElement;
            if (btn) {
                const id = btn.dataset.researcherId!;
                const name = btn.dataset.researcherName!;
                window.dispatchEvent(
                    new CustomEvent("open-researcher-modal", {
                        detail: { id, name },
                    }),
                );
            }
        });

        filterResearchers();
        updateResearcherViews(currentCampusId);
    </script>
</Layout>
