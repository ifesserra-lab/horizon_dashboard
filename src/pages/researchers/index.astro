---
import Layout from "../../layouts/Layout.astro";
import type { Researcher } from "../../types/researchers";
import ResearcherFilters from "../../components/researchers/ResearcherFilters.astro";
import ResearcherCard from "../../components/researchers/ResearcherCard.astro";
import ResearcherModal from "../../components/researchers/ResearcherModal.astro";
import ResearcherCharts from "../../components/researchers/ResearcherCharts.astro";
import ResearcherKpiCards from "../../components/researchers/ResearcherKpiCards.astro";
import {
    getCampusNamesFromIds,
    getResearcherCampusIds,
} from "../../lib/tenant-data";
import {
    buildCampusResearcherViews,
    researchersOnly,
} from "../../lib/researcher-collections";
import { buildResearcherStatsById } from "../../lib/researchers-data";
import { buildResearcherCardView } from "../../lib/researcher-card-markup";

const researchers = researchersOnly as Researcher[];
const campusResearcherViews = buildCampusResearcherViews(researchers);
const researcherStats = buildResearcherStatsById(researchers);
const INITIAL_RESEARCHER_BATCH = 24;
const researcherCards = researchers.map((researcher) => {
    const campusIds = getResearcherCampusIds(researcher);

    return {
        researcher,
        stats: researcherStats[researcher.id],
        campusIds,
        campusNames: getCampusNamesFromIds(campusIds),
    };
});

const baseUrl = import.meta.env.BASE_URL;
const initialResearcherCards = researcherCards.slice(0, INITIAL_RESEARCHER_BATCH);
const researcherCardViews = researcherCards.map(
    ({ researcher, stats, campusIds, campusNames }) =>
        buildResearcherCardView({
            researcher,
            stats,
            baseUrl,
            campusIds,
            campusNames,
        }),
);
---

<Layout title="Pesquisadores">
    <div class="space-y-10 pb-12">
        <!-- Header -->
        <header class="flex flex-col gap-6">
            <div>
                <h1
                    class="text-4xl font-extrabold font-['Outfit'] tracking-tight text-text-main"
                >
                    Nossos <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple"
                        >Pesquisadores</span
                    >
                </h1>
                <p class="text-text-secondary mt-2 max-w-2xl">
                    Conheça os profissionais que impulsionam a ciência e
                    inovação.
                </p>
            </div>
        </header>

        <div id="researcher-dashboard-views">
            <div data-campus-view="">
                <ResearcherKpiCards researchers={researchers} />
                <ResearcherCharts researchers={researchers} instanceId="all" />
            </div>
            {
                Object.entries(campusResearcherViews).map(
                    ([campusId, campusResearchers]) => (
                        <div data-campus-view={campusId} class="hidden">
                            <ResearcherKpiCards researchers={campusResearchers} />
                            <ResearcherCharts
                                researchers={campusResearchers}
                                instanceId={`campus-${campusId}`}
                            />
                        </div>
                    ),
                )
            }
        </div>

        <!-- Search & Filters -->
        <ResearcherFilters />

        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <p
                id="researcherResultsSummary"
                class="text-sm text-text-secondary"
                aria-live="polite"
            >
                Mostrando os primeiros {initialResearcherCards.length} de {researcherCardViews
                    .length} pesquisadores.
            </p>
            <p
                id="researcherLoadProgress"
                class="text-[11px] font-bold uppercase tracking-[0.24em] text-text-secondary"
                aria-live="polite"
            >
                Role para carregar mais
            </p>
        </div>

        <!-- Researchers Grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
            id="researchersGrid"
            role="region"
            aria-label="Lista de pesquisadores"
        >
            {
                initialResearcherCards.map(({ researcher, stats, campusIds, campusNames }) => (
                    <ResearcherCard
                        researcher={researcher}
                        stats={stats}
                        baseUrl={baseUrl}
                        campusIds={campusIds}
                        campusNames={campusNames}
                    />
                ))
            }
        </div>

        <div
            id="researcherInfiniteStatus"
            class="flex flex-col items-center gap-3"
            aria-live="polite"
        >
            <div
                id="researchersLoadingSpinner"
                class="hidden animate-spin rounded-full h-8 w-8 border-4 border-premium-accent border-t-transparent"
            >
            </div>
            <p
                id="researchersAllLoaded"
                class="hidden text-sm text-text-secondary italic"
            >
                Todos os pesquisadores visíveis já foram carregados.
            </p>
            <div id="researchersLoadMoreSentinel" class="h-2 w-full"></div>
        </div>

        <!-- Empty State -->
        <div
            id="emptyState"
            class="hidden flex-col items-center justify-center py-24 text-center"
        >
            <div
                class="w-24 h-24 bg-slate-100 dark:bg-white/5 rounded-3xl flex items-center justify-center mb-6 text-text-secondary border border-outline border-dashed"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-12 h-12 opacity-50"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="11" cy="11" r="8"></circle><path
                        d="m21 21-4.3-4.3"></path><path d="M8 11h6"></path></svg
                >
            </div>
            <h3 class="text-2xl font-bold font-['Outfit'] text-text-main mb-2">
                Nenhum pesquisador encontrado
            </h3>
            <p class="text-text-secondary max-w-sm">
                Tente buscar por outro nome.
            </p>
        </div>
    </div>

    <!-- Articles/Profile Modal -->
    <ResearcherModal />

    <!-- Data for client-side -->
    <script define:vars={{ researchers }}>
        window.researchersData = researchers;
    </script>

    <script define:vars={{ researcherCardViews, initialBatchSize: INITIAL_RESEARCHER_BATCH }}>
        window.researcherCardViews = researcherCardViews;
        window.researcherInitialBatchSize = initialBatchSize;
    </script>

    <script>
        import { normalizeSearchText } from "../../lib/search";
        import {
            getCampusFilterValue,
            updateCampusViews,
        } from "../../lib/campus-ui";
        import {
            renderResearcherCardMarkup,
            type ResearcherCardView,
        } from "../../lib/researcher-card-markup";

        const searchInput = document.getElementById(
            "researcherSearch",
        ) as HTMLInputElement;
        const resetBtn = document.getElementById("resetFilters");
        const emptyState = document.getElementById("emptyState");
        const researchersGrid = document.getElementById("researchersGrid");
        const resultsSummary = document.getElementById("researcherResultsSummary");
        const loadProgress = document.getElementById("researcherLoadProgress");
        const loadSentinel = document.getElementById("researchersLoadMoreSentinel");
        const loadingSpinner = document.getElementById("researchersLoadingSpinner");
        const allLoadedMessage = document.getElementById("researchersAllLoaded");
        const infiniteStatus = document.getElementById("researcherInfiniteStatus");
        const allResearchers = ((window as any).researcherCardViews ||
            []) as ResearcherCardView[];
        const initialBatchSize =
            Number((window as any).researcherInitialBatchSize) || 24;
        let currentCampusId = localStorage.getItem("preferred-campus") || "";
        let filteredResearchers = allResearchers;
        let renderedCount = document.querySelectorAll(".researcher-card").length;
        let observer: IntersectionObserver | null = null;
        let isRendering = false;

        function updateResearcherViews(selectedCampus) {
            updateCampusViews(
                "#researcher-dashboard-views [data-campus-view]",
                selectedCampus,
            );
        }

        function disconnectObserver() {
            observer?.disconnect();
            observer = null;
        }

        function updateLoadState() {
            const totalFiltered = filteredResearchers.length;
            const hasResults = totalFiltered > 0;
            const hasMore = renderedCount < totalFiltered;

            infiniteStatus?.classList.toggle("hidden", !hasResults);
            loadSentinel?.classList.toggle("hidden", !hasResults || !hasMore);
            loadingSpinner?.classList.toggle(
                "hidden",
                !hasResults || !hasMore || !isRendering,
            );
            allLoadedMessage?.classList.toggle("hidden", !hasResults || hasMore);

            if (loadProgress) {
                if (!hasResults) {
                    loadProgress.textContent = "";
                } else if (hasMore) {
                    loadProgress.textContent = `${renderedCount} de ${totalFiltered} carregados`;
                } else {
                    loadProgress.textContent = `Lista completa: ${totalFiltered} carregados`;
                }
            }
        }

        function updateSummary(query: string) {
            const totalFiltered = filteredResearchers.length;
            const searchMessage = query
                ? ` para "${searchInput?.value?.trim() || query}"`
                : "";

            if (resultsSummary) {
                if (totalFiltered === 0) {
                    resultsSummary.textContent =
                        "Nenhum pesquisador corresponde aos filtros atuais.";
                } else {
                    resultsSummary.textContent = `${totalFiltered} pesquisador${totalFiltered === 1 ? "" : "es"} encontrado${totalFiltered === 1 ? "" : "s"}${searchMessage}.`;
                }
            }
        }

        function setupInfiniteScroll() {
            disconnectObserver();

            if (!loadSentinel || renderedCount >= filteredResearchers.length) {
                return;
            }

            observer = new IntersectionObserver(
                (entries) => {
                    if (entries.some((entry) => entry.isIntersecting)) {
                        renderNextBatch();
                    }
                },
                { rootMargin: "600px 0px" },
            );

            observer.observe(loadSentinel);
        }

        function renderNextBatch() {
            if (
                isRendering ||
                !researchersGrid ||
                renderedCount >= filteredResearchers.length
            ) {
                updateLoadState();
                return;
            }

            isRendering = true;
            updateLoadState();

            const nextBatch = filteredResearchers.slice(
                renderedCount,
                renderedCount + initialBatchSize,
            );

            researchersGrid.insertAdjacentHTML(
                "beforeend",
                nextBatch.map((researcher) => renderResearcherCardMarkup(researcher)).join(""),
            );

            renderedCount += nextBatch.length;
            isRendering = false;
            updateLoadState();
            setupInfiniteScroll();
        }

        function renderFilteredResearchers() {
            disconnectObserver();

            if (!researchersGrid) {
                return;
            }

            researchersGrid.innerHTML = "";
            renderedCount = 0;

            if (!filteredResearchers.length) {
                emptyState?.classList.remove("hidden");
                emptyState?.classList.add("flex");
                updateLoadState();
                return;
            }

            emptyState?.classList.add("hidden");
            emptyState?.classList.remove("flex");
            renderNextBatch();
        }

        function filterResearchers() {
            const query = normalizeSearchText(searchInput?.value || "");

            if (query) {
                resetBtn?.classList.remove("hidden");
            } else {
                resetBtn?.classList.add("hidden");
            }

            filteredResearchers = allResearchers.filter((researcher) => {
                const matchesCampus =
                    !currentCampusId ||
                    researcher.campusIds.includes(currentCampusId);
                const matchesSearch =
                    !query || researcher.searchIndex.includes(query);

                return matchesCampus && matchesSearch;
            });

            updateSummary(query);
            renderFilteredResearchers();
        }

        searchInput?.addEventListener("input", filterResearchers);
        window.addEventListener("campus-filter-change", (event) => {
            currentCampusId = getCampusFilterValue(event);
            updateResearcherViews(currentCampusId);
            if (searchInput) searchInput.value = "";
            filterResearchers();
        });
        resetBtn?.addEventListener("click", () => {
            searchInput.value = "";
            filterResearchers();
            searchInput.focus();
        });

        // Event listener for opening modal (from cards)
        document.addEventListener("click", (e) => {
            const btn = (e.target as HTMLElement).closest(
                ".view-articles-btn",
            ) as HTMLButtonElement;
            if (btn) {
                const id = btn.dataset.researcherId!;
                const name = btn.dataset.researcherName!;
                window.dispatchEvent(
                    new CustomEvent("open-researcher-modal", {
                        detail: { id, name },
                    }),
                );
            }
        });

        filterResearchers();
        updateResearcherViews(currentCampusId);
    </script>
</Layout>
