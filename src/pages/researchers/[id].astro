---
import Layout from "../../layouts/Layout.astro";
import researchersData from "../../data/researchers_canonical.json";
import initiativesData from "../../data/initiatives_canonical.json";
import researchersOnlyCollaborationGraphData from "../../data/researchers_only_collaboration_graph.json";
import researchersOnlyRelationshipGraphData from "../../data/researchers_only_relationship_graph.json";
import outsideIfesCollaborationGraphData from "../../data/outside_ifes_collaboration_graph.json";
import outsideIfesRelationshipGraphData from "../../data/outside_ifes_relationship_graph.json";
import nullResearchersCollaborationGraphData from "../../data/null_researchers_collaboration_graph.json";
import nullResearchersRelationshipGraphData from "../../data/null_researchers_relationship_graph.json";
import type { Researcher } from "../../types/researchers";
import type { StudentInteractionRawGraphFile } from "../../types/student-graphs";
import {
    getAcademicEducationSources,
    getAttributeSources,
    toInlineSourceItems,
} from "../../lib/provenance";
import { buildStudentInteractionViewModel } from "../../lib/student-interaction";

// Profile Components
import ResearcherProfileHeader from "../../components/researchers/ResearcherProfileHeader.astro";
import ResearcherProfileEducation from "../../components/researchers/ResearcherProfileEducation.astro";
import ResearcherProfileResume from "../../components/researchers/ResearcherProfileResume.astro";
import ResearcherProfileDashboard from "../../components/researchers/ResearcherProfileDashboard.astro";
import ResearcherProfileGroups from "../../components/researchers/ResearcherProfileGroups.astro";
import ResearcherProfileInitiatives from "../../components/researchers/ResearcherProfileInitiatives.astro";
import ResearcherProfileAdvisorships from "../../components/researchers/ResearcherProfileAdvisorships.astro";
import ResearcherProfileArticles from "../../components/researchers/ResearcherProfileArticles.astro";
import ResearcherProfileStats from "../../components/researchers/ResearcherProfileStats.astro";
import PersonInteractionGraph from "../../components/researchers/PersonInteractionGraph.astro";
import DetailPageJumpMenu from "../../components/navigation/DetailPageJumpMenu.astro";

export function getStaticPaths() {
    const researchers = researchersData as unknown as Researcher[];
    return researchers.map((researcher) => ({
        params: { id: researcher.id.toString() },
        props: { researcher },
    }));
}

interface Props {
    researcher: Researcher;
}

const { researcher } = Astro.props;

// Enrich initiatives with start_date from canonical source
const enrichedInitiatives = researcher.initiatives.map((init) => {
    const fullInit = (initiativesData as any[]).find((i) => i.id === init.id);
    return {
        ...init,
        start_date: fullInit?.start_date,
        end_date: fullInit?.end_date,
        initiative_type: fullInit?.initiative_type,
    };
});

// Update researcher object with enriched initiatives
const enrichedResearcher = {
    ...researcher,
    initiatives: enrichedInitiatives,
};

const profileHeaderSources = toInlineSourceItems([
    ...getAttributeSources("researcher", researcher.id, [
        "name",
        "identification_id",
        "cnpq_url",
        "google_scholar_url",
    ]),
    ...researcher.knowledge_areas.flatMap((area) =>
        getAttributeSources("knowledge_area", area.id, ["name"]),
    ),
]);

const resumeSources = toInlineSourceItems(
    getAttributeSources("researcher", researcher.id, ["resume"]),
);

const educationSources = researcher.academic_education.map((education) =>
    toInlineSourceItems(getAcademicEducationSources(education)),
);

const groupSourcesById = Object.fromEntries(
    researcher.research_groups.map((group) => [
        String(group.id),
        toInlineSourceItems(
            getAttributeSources("research_group", group.id, ["name"]),
        ),
    ]),
);

const initiativeSourcesById = Object.fromEntries(
    enrichedResearcher.initiatives.map((initiative) => [
        String(initiative.id),
        toInlineSourceItems(
            getAttributeSources("initiative", initiative.id, [
                "name",
                "status",
                "start_date",
                "end_date",
            ]),
        ),
    ]),
);

const advisorshipSourcesById = Object.fromEntries(
    (researcher.advisorships || []).map((advisorship) => [
        String(advisorship.id),
        toInlineSourceItems([
            ...getAttributeSources("advisorship", advisorship.id, [
                "name",
                "status",
                "start_date",
                "end_date",
                "coordinator_name",
                "student_names",
            ]),
        ]),
    ]),
);

const articleSourcesById = Object.fromEntries(
    researcher.articles.map((article) => [
        String(article.id),
        toInlineSourceItems(
            getAttributeSources("article", article.id, [
                "title",
                "year",
                "doi",
                "journal_conference",
            ]),
        ),
    ]),
);

const researcherGraphDataByClassification = {
    student: {
        collaboration: {
            data: null,
            source: "students_collaboration_graph",
        },
        relationship: {
            data: null,
            source: "students_relationship_graph",
        },
    },
    researcher: {
        collaboration: {
            data: researchersOnlyCollaborationGraphData as StudentInteractionRawGraphFile,
            source: "researchers_only_collaboration_graph",
        },
        relationship: {
            data: researchersOnlyRelationshipGraphData as StudentInteractionRawGraphFile,
            source: "researchers_only_relationship_graph",
        },
    },
    outside_ifes: {
        collaboration: {
            data: outsideIfesCollaborationGraphData as StudentInteractionRawGraphFile,
            source: "outside_ifes_collaboration_graph",
        },
        relationship: {
            data: outsideIfesRelationshipGraphData as StudentInteractionRawGraphFile,
            source: "outside_ifes_relationship_graph",
        },
    },
    null: {
        collaboration: {
            data: nullResearchersCollaborationGraphData as StudentInteractionRawGraphFile,
            source: "null_researchers_collaboration_graph",
        },
        relationship: {
            data: nullResearchersRelationshipGraphData as StudentInteractionRawGraphFile,
            source: "null_researchers_relationship_graph",
        },
    },
} as const;

const graphBucket =
    researcher.classification === "student"
        ? "student"
        : researcher.classification === "researcher"
          ? "researcher"
          : researcher.classification === "outside_ifes"
            ? "outside_ifes"
            : "null";

const collaborationGraphConfig =
    researcherGraphDataByClassification[graphBucket].collaboration;
const relationshipGraphConfig =
    researcherGraphDataByClassification[graphBucket].relationship;

const researcherCollaborationGraph = collaborationGraphConfig.data
    ? buildStudentInteractionViewModel(collaborationGraphConfig.data, {
          focusId: researcher.id,
          focusName: researcher.name,
          focusClassification: researcher.classification ?? null,
          graphDataSource: collaborationGraphConfig.source,
          graphKind: "collaboration",
          baseUrl: import.meta.env.BASE_URL,
      })
    : null;

const researcherRelationshipGraph = relationshipGraphConfig.data
    ? buildStudentInteractionViewModel(relationshipGraphConfig.data, {
          focusId: researcher.id,
          focusName: researcher.name,
          focusClassification: researcher.classification ?? null,
          graphDataSource: relationshipGraphConfig.source,
          graphKind: "relationship",
          baseUrl: import.meta.env.BASE_URL,
      })
    : null;

const researcherDetailSections = [
    { id: "researcher-profile", label: "Perfil" },
    { id: "researcher-resume", label: "Resumo" },
    { id: "researcher-stats", label: "Indicadores" },
    { id: "researcher-dashboard", label: "Painel" },
    { id: "researcher-education", label: "Formacao academica" },
    { id: "researcher-groups", label: "Grupos de pesquisa" },
    { id: "researcher-initiatives", label: "Iniciativas" },
    { id: "researcher-advisorships", label: "Orientacoes" },
    { id: "researcher-articles", label: "Publicacoes" },
    ...(researcherCollaborationGraph
        ? [{ id: "researcher-collaboration-graph", label: "Grafo de colaboracao" }]
        : []),
    ...(researcherRelationshipGraph
        ? [{ id: "researcher-relationship-graph", label: "Grafo de relacionamento" }]
        : []),
];
---

<Layout
    title={researcher.name}
    breadcrumbReplacements={{ [researcher.id]: researcher.name }}
>
    <nav class="mb-8" aria-label="Navegação secundária">
        <!-- Back button removed -->
    </nav>

    <div class="flex flex-col lg:flex-row gap-8 items-start">
        <div class="flex-1 space-y-8 w-full">
            <DetailPageJumpMenu
                items={researcherDetailSections}
                title="Atalhos da pagina do pesquisador"
                description="Permite saltar entre blocos do perfil, producao academica e grafos de rede."
            />

            <section id="researcher-profile" class="scroll-mt-28">
                <ResearcherProfileHeader
                    researcher={enrichedResearcher}
                    sources={profileHeaderSources}
                />
            </section>
            <section id="researcher-resume" class="scroll-mt-28">
                <ResearcherProfileResume
                    researcher={enrichedResearcher}
                    sources={resumeSources}
                />
            </section>

            <section id="researcher-stats" class="scroll-mt-28">
                <ResearcherProfileStats
                    totalArticles={enrichedResearcher.articles.length}
                    totalProjects={enrichedResearcher.initiatives.length}
                    totalAdvisorships={researcher.advisorships?.length || 0}
                />
            </section>

            <section id="researcher-dashboard" class="scroll-mt-28">
                <ResearcherProfileDashboard
                    researcher={enrichedResearcher}
                    advisorships={researcher.advisorships || []}
                />
            </section>

            <section id="researcher-education" class="scroll-mt-28">
                <ResearcherProfileEducation
                    researcher={enrichedResearcher}
                    educationSources={educationSources}
                />
            </section>
            <section id="researcher-groups" class="scroll-mt-28">
                <ResearcherProfileGroups
                    researcher={enrichedResearcher}
                    groupSourcesById={groupSourcesById}
                />
            </section>
            <section id="researcher-initiatives" class="scroll-mt-28">
                <ResearcherProfileInitiatives
                    researcher={enrichedResearcher}
                    initiativeSourcesById={initiativeSourcesById}
                />
            </section>
            <section id="researcher-advisorships" class="scroll-mt-28">
                <ResearcherProfileAdvisorships
                    advisorships={researcher.advisorships || []}
                    advisorshipSourcesById={advisorshipSourcesById}
                />
            </section>

            <section id="researcher-articles" class="scroll-mt-28">
                <ResearcherProfileArticles
                    researcher={enrichedResearcher}
                    articleSourcesById={articleSourcesById}
                />
            </section>

            {
                researcherCollaborationGraph && (
                    <section
                        id="researcher-collaboration-graph"
                        class="scroll-mt-28"
                    >
                        <PersonInteractionGraph graph={researcherCollaborationGraph} />
                    </section>
                )
            }

            {
                researcherRelationshipGraph && (
                    <section
                        id="researcher-relationship-graph"
                        class="scroll-mt-28"
                    >
                        <PersonInteractionGraph graph={researcherRelationshipGraph} />
                    </section>
                )
            }
        </div>
    </div>
</Layout>
