---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
const indexUrl = `${base}search-index.json`;
---

<Layout title="Buscar pesquisa">
    <div class="max-w-5xl mx-auto" data-base={base} data-index-url={indexUrl}>
        <!-- Hero -->
        <section class="text-center pt-6 pb-8">
            <h1
                class="text-3xl md:text-4xl font-bold font-['Outfit'] text-text-main text-balance"
            >
                O que você quer encontrar na pesquisa do Ifes?
            </h1>
            <p class="mt-3 text-text-secondary max-w-2xl mx-auto">
                Busque por tema, pessoa ou grupo. Escolha sua perspectiva — os
                resultados se adaptam a quem está procurando.
            </p>

            <!-- Persona -->
            <div
                class="mt-6 inline-flex bg-glass-bg border border-border-main rounded-xl p-1 gap-1"
                role="group"
                aria-label="Quem está buscando"
                id="personaSwitch"
            >
                <button
                    type="button"
                    data-persona="aluno"
                    aria-pressed="true"
                    class="persona-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all"
                    >Aluno</button
                >
                <button
                    type="button"
                    data-persona="professor"
                    aria-pressed="false"
                    class="persona-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all"
                    >Professor</button
                >
                <button
                    type="button"
                    data-persona="empresa"
                    aria-pressed="false"
                    class="persona-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all"
                    >Empresa</button
                >
            </div>

            <!-- Search box -->
            <div class="mt-5 relative max-w-2xl mx-auto">
                <svg
                    class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-secondary"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
                    ></path></svg
                >
                <input
                    type="search"
                    id="q"
                    autocomplete="off"
                    class="w-full bg-glass-bg border border-border-main rounded-2xl pl-12 pr-4 py-4 text-lg text-text-main focus:outline-none focus:ring-2 focus:ring-premium-purple/50 focus:border-premium-purple transition-all"
                />
            </div>
            <p id="lens" class="mt-3 text-sm text-text-secondary italic"></p>
            <div id="suggest" class="mt-4 flex flex-wrap gap-2 justify-center"></div>
            <p class="mt-5 text-sm">
                <a
                    href={`${base}painel`}
                    class="text-text-secondary hover:text-premium-purple transition-colors underline underline-offset-4 decoration-border-main"
                    >Ver painel de indicadores e gráficos →</a
                >
            </p>
        </section>

        <!-- Results area -->
        <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-8 pb-20">
            <aside class="space-y-6 lg:sticky lg:top-24 self-start">
                <div>
                    <h4
                        class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2"
                    >
                        Tipo
                    </h4>
                    <div id="facetType" class="flex flex-col gap-1"></div>
                </div>
                <div>
                    <h4
                        class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2"
                    >
                        Campus
                    </h4>
                    <div id="facetCampus" class="flex flex-col gap-1"></div>
                </div>
            </aside>

            <main>
                <div
                    class="flex items-baseline justify-between mb-4 pb-3 border-b border-border-main"
                >
                    <h2
                        id="resultsTitle"
                        class="text-lg font-semibold text-text-secondary"
                    >
                        Em destaque
                    </h2>
                    <span
                        id="resultsCount"
                        class="text-xs font-mono text-text-muted"></span>
                </div>
                <div id="results" class="space-y-3"></div>
                <div
                    id="loadingState"
                    class="text-center py-16 text-text-secondary"
                >
                    Carregando índice de busca…
                </div>
                <div
                    id="emptyState"
                    class="hidden text-center py-16 text-text-secondary"
                >
                    <p class="text-lg text-text-main mb-1">Nada encontrado</p>
                    <p class="text-sm">Tente outro termo ou explore uma área acima.</p>
                </div>
            </main>
        </div>
    </div>

    <script>
        import { normalizeSearchText } from "../lib/search";

        interface Entry {
            i: string;
            t: string;
            n: string;
            c?: string | null;
            a?: string[];
            g?: string[];
            l?: string[];
            team?: string[];
            na?: number;
            ni?: number;
            nm?: number;
            st?: string | null;
            v?: string | null;
            y?: number | null;
            pt?: string | null;
            f?: number;
            h?: number;
            _s?: string;
        }

        const root = document.querySelector("[data-index-url]") as HTMLElement;
        const base = root.dataset.base || "/";
        const indexUrl = root.dataset.indexUrl as string;

        const TYPE_LABEL: Record<string, string> = {
            pesquisador: "Pesquisador",
            aluno: "Aluno",
            grupo: "Grupo",
            projeto: "Projeto",
            publicacao: "Publicação",
        };
        const TYPE_URL: Record<string, (i: string) => string | null> = {
            pesquisador: (i) => `${base}researchers/${i}/`,
            aluno: (i) => `${base}students/${i}/`,
            grupo: (i) => `${base}groups/${i}/`,
            projeto: (i) => `${base}projects/${i}/`,
            publicacao: () => `${base}publications/`,
        };

        const PERSONAS: Record<
            string,
            {
                lens: string;
                placeholder: string;
                w: Record<string, number>;
            }
        > = {
            aluno: {
                lens: "Mostrando quem pode te orientar e grupos de pesquisa pra entrar.",
                placeholder:
                    "Busque um tema — ex.: robótica, educação inclusiva, energia solar…",
                w: {
                    pesquisador: 1,
                    aluno: 0.6,
                    grupo: 1.2,
                    projeto: 1.1,
                    publicacao: 0.5,
                },
            },
            professor: {
                lens: "Mostrando pares, produção científica e parcerias possíveis.",
                placeholder: "Busque uma área, pesquisador ou tema de colaboração…",
                w: {
                    pesquisador: 1.2,
                    aluno: 0.5,
                    grupo: 1.05,
                    projeto: 0.95,
                    publicacao: 1.05,
                },
            },
            empresa: {
                lens: "Mostrando quem domina o assunto e pode apoiar sua empresa.",
                placeholder:
                    "Descreva o problema ou tecnologia — ex.: visão computacional…",
                w: {
                    grupo: 1.25,
                    pesquisador: 1.1,
                    projeto: 1.2,
                    aluno: 0.4,
                    publicacao: 0.4,
                },
            },
        };

        let persona = "aluno";
        let query = "";
        let fType: string | null = null;
        let fCampus: string | null = null;
        let entries: Entry[] = [];

        const $ = (id: string) => document.getElementById(id)!;
        const esc = (s: unknown) =>
            String(s ?? "").replace(
                /[&<>"']/g,
                (c) =>
                    ({
                        "&": "&amp;",
                        "<": "&lt;",
                        ">": "&gt;",
                        '"': "&quot;",
                        "'": "&#39;",
                    })[c] as string,
            );

        function searchText(e: Entry): string {
            return [
                e.n,
                ...(e.a || []),
                ...(e.g || []),
                ...(e.l || []),
                ...(e.team || []),
                e.c,
                e.v,
            ]
                .filter(Boolean)
                .join(" ");
        }

        function score(e: Entry, tokens: string[]): number {
            const w = PERSONAS[persona].w[e.t] ?? 1;
            if (tokens.length === 0) {
                // featured: richer + higher-impact entries first.
                // FWCI (field-weighted citation impact) is the strongest
                // signal when present (only the ~93 docentes with OpenAlex).
                // sqrt dampens outliers (one freak FWCI shouldn't dominate).
                const base =
                    Math.sqrt(e.f || 0) * 18 +
                    (e.na || 0) * 2 +
                    (e.ni || 0) * 2 +
                    (e.nm || 0) +
                    (e.a?.length || 0) * 2 +
                    1;
                return base * w;
            }
            const name = normalizeSearchText(e.n);
            let s = 0;
            for (const t of tokens) {
                if (!t) continue;
                if (name.includes(t)) s += 12;
                if (e._s!.includes(t)) s += 5;
                for (const a of e.a || [])
                    if (normalizeSearchText(a).includes(t)) s += 6;
            }
            return s === 0 ? 0 : s * w;
        }

        function currentResults(): Entry[] {
            const tokens = normalizeSearchText(query)
                .split(" ")
                .filter(Boolean);
            let list = entries
                .map((e) => ({ e, s: score(e, tokens) }))
                .filter((x) => x.s > 0);
            if (fType) list = list.filter((x) => x.e.t === fType);
            if (fCampus) list = list.filter((x) => x.e.c === fCampus);
            list.sort((a, b) => b.s - a.s);
            return list.map((x) => x.e);
        }

        function roleLine(e: Entry): string {
            const area = (e.a && e.a[0]) || (e.g && e.g[0]) || "";
            if (e.t === "pesquisador" || e.t === "aluno") {
                if (persona === "empresa")
                    return area
                        ? `Especialista em <b class="text-premium-purple">${esc(area)}</b>`
                        : "";
                if (persona === "aluno")
                    return area
                        ? `Pode orientar em <b class="text-premium-purple">${esc(area)}</b>`
                        : "";
                return area
                    ? `Área: <b class="text-premium-purple">${esc(area)}</b>`
                    : "";
            }
            if (e.t === "grupo")
                return e.l && e.l[0]
                    ? `Liderado por <b class="text-premium-purple">${esc(e.l[0])}</b>`
                    : "";
            if (e.t === "projeto")
                return e.st ? `Situação: ${esc(e.st)}` : "";
            if (e.t === "publicacao")
                return [e.v, e.y].filter(Boolean).map(esc).join(" · ");
            return "";
        }

        function metaLine(e: Entry): string {
            const bits: string[] = [];
            if (e.t === "pesquisador" || e.t === "aluno") {
                if (e.f) bits.push(`FWCI ${e.f.toFixed(2)}`);
                if (e.h) bits.push(`índice h ${e.h}`);
                if (e.na) bits.push(`${e.na} publicações`);
                if (e.ni) bits.push(`${e.ni} projetos`);
            }
            if (e.t === "grupo" && e.nm) bits.push(`${e.nm} integrantes`);
            if (e.c) bits.push(esc(e.c));
            return bits.join(" · ");
        }

        function cardHtml(e: Entry): string {
            const url = TYPE_URL[e.t]?.(e.i) ?? null;
            const areas = (e.a || [])
                .slice(0, 4)
                .map(
                    (a) =>
                        `<span class="text-[11px] px-2 py-0.5 rounded-md bg-white/5 border border-border-main text-text-secondary">${esc(a)}</span>`,
                )
                .join("");
            const role = roleLine(e);
            const meta = metaLine(e);
            const inner = `
                <div class="flex items-start gap-3">
                    <span class="flex-shrink-0 mt-0.5 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md bg-premium-purple/10 text-premium-purple">${esc(TYPE_LABEL[e.t] || e.t)}</span>
                    <div class="min-w-0">
                        <h3 class="text-base font-bold text-text-main leading-snug">${esc(e.n)}</h3>
                        ${role ? `<p class="text-sm text-text-secondary mt-0.5">${role}</p>` : ""}
                        ${areas ? `<div class="flex flex-wrap gap-1.5 mt-2">${areas}</div>` : ""}
                        ${meta ? `<p class="text-xs text-text-muted mt-2">${meta}</p>` : ""}
                    </div>
                </div>`;
            const cls =
                "block glass-card p-4 border border-border-main hover:border-premium-purple/40 transition-all";
            return url
                ? `<a href="${esc(url)}" class="${cls}">${inner}</a>`
                : `<div class="${cls}">${inner}</div>`;
        }

        function render() {
            const cfg = PERSONAS[persona];
            ($("q") as HTMLInputElement).placeholder = cfg.placeholder;
            $("lens").textContent = cfg.lens;

            const res = currentResults();
            const tokens = normalizeSearchText(query).split(" ").filter(Boolean);

            // type facet counts (respect campus + query, ignore type)
            const forType = entries
                .filter((e) => score(e, tokens) > 0)
                .filter((e) => !fCampus || e.c === fCampus);
            const counts: Record<string, number> = {};
            for (const e of forType) counts[e.t] = (counts[e.t] || 0) + 1;
            $("facetType").innerHTML = Object.keys(TYPE_LABEL)
                .map((t) => {
                    const active = fType === t;
                    return `<button data-ftype="${t}" aria-pressed="${active}" class="facet-btn flex justify-between items-center px-2.5 py-1.5 rounded-lg text-sm ${active ? "bg-premium-purple/15 text-premium-purple font-semibold" : "text-text-secondary hover:bg-white/5"}"><span>${TYPE_LABEL[t]}</span><span class="font-mono text-xs">${counts[t] || 0}</span></button>`;
                })
                .join("");

            $("resultsTitle").textContent = query
                ? `Resultados para “${query}”`
                : fType || fCampus
                  ? "Filtrado"
                  : "Em destaque";
            $("resultsCount").textContent = `${res.length} ${res.length === 1 ? "resultado" : "resultados"}`;

            const box = $("results");
            $("loadingState").classList.add("hidden");
            if (res.length === 0) {
                box.innerHTML = "";
                $("emptyState").classList.remove("hidden");
            } else {
                $("emptyState").classList.add("hidden");
                box.innerHTML = res
                    .slice(0, 50)
                    .map(cardHtml)
                    .join("");
            }
        }

        function setQuery(v: string) {
            query = v;
            ($("q") as HTMLInputElement).value = v;
            fType = null;
            render();
            window.scrollTo({ top: 0, behavior: "smooth" });
        }

        function buildFacetsStatic() {
            // campus options
            const campusCount: Record<string, number> = {};
            for (const e of entries)
                if (e.c) campusCount[e.c] = (campusCount[e.c] || 0) + 1;
            const campuses = Object.entries(campusCount)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 8);
            $("facetCampus").innerHTML =
                `<button data-fcampus="" aria-pressed="true" class="facet-btn flex justify-between items-center px-2.5 py-1.5 rounded-lg text-sm text-text-secondary hover:bg-white/5"><span>Todos</span></button>` +
                campuses
                    .map(
                        ([c, n]) =>
                            `<button data-fcampus="${esc(c)}" aria-pressed="false" class="facet-btn flex justify-between items-center px-2.5 py-1.5 rounded-lg text-sm text-text-secondary hover:bg-white/5"><span>${esc(c)}</span><span class="font-mono text-xs">${n}</span></button>`,
                    )
                    .join("");

            // top-area suggestion chips
            const areaCount: Record<string, number> = {};
            for (const e of entries)
                for (const a of e.a || [])
                    areaCount[a] = (areaCount[a] || 0) + 1;
            const topAreas = Object.entries(areaCount)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 8);
            $("suggest").innerHTML = topAreas
                .map(
                    ([a]) =>
                        `<button data-suggest="${esc(a)}" class="text-sm px-3 py-1.5 rounded-full border border-border-main text-text-secondary hover:border-premium-purple hover:text-premium-purple transition-colors">${esc(a)}</button>`,
                )
                .join("");
        }

        // Events
        document.querySelectorAll(".persona-btn").forEach((b) =>
            b.addEventListener("click", () => {
                persona = (b as HTMLElement).dataset.persona!;
                document.querySelectorAll(".persona-btn").forEach((x) => {
                    const on = x === b;
                    x.setAttribute("aria-pressed", String(on));
                    x.classList.toggle("bg-glass-bg", on);
                    x.classList.toggle("text-text-main", on);
                    x.classList.toggle("shadow", on);
                    x.classList.toggle("text-text-secondary", !on);
                });
                render();
            }),
        );

        $("q").addEventListener("input", (ev) => {
            query = (ev.target as HTMLInputElement).value;
            render();
        });

        document.body.addEventListener("click", (ev) => {
            const el = ev.target as HTMLElement;
            const ft = el.closest("[data-ftype]") as HTMLElement | null;
            const fc = el.closest("[data-fcampus]") as HTMLElement | null;
            const sg = el.closest("[data-suggest]") as HTMLElement | null;
            if (sg) {
                setQuery(sg.dataset.suggest!);
            } else if (ft) {
                const t = ft.dataset.ftype!;
                fType = fType === t ? null : t;
                render();
            } else if (fc) {
                fCampus = fc.dataset.fcampus || null;
                document
                    .querySelectorAll("[data-fcampus]")
                    .forEach((x) =>
                        x.setAttribute(
                            "aria-pressed",
                            String(
                                (x as HTMLElement).dataset.fcampus ===
                                    (fCampus || ""),
                            ),
                        ),
                    );
                render();
            }
        });

        // Init persona button styling
        document
            .querySelector('.persona-btn[data-persona="aluno"]')
            ?.classList.add("bg-glass-bg", "text-text-main", "shadow");

        // Load index
        fetch(indexUrl)
            .then((r) => r.json())
            .then((data: Entry[]) => {
                entries = data;
                for (const e of entries)
                    e._s = normalizeSearchText(searchText(e));
                buildFacetsStatic();
                render();
            })
            .catch(() => {
                $("loadingState").textContent =
                    "Não foi possível carregar o índice de busca.";
            });
    </script>
</Layout>
