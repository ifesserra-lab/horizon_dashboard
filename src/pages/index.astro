---
import Layout from "../layouts/Layout.astro";
import KpiCard from "../components/KpiCard.astro";
import HomeCharts from "../components/home/HomeCharts.astro";
import PeopleNetworkOverview from "../components/home/PeopleNetworkOverview.astro";
import groupsData from "../data/research_groups_canonical.json";
import advisorshipsData from "../data/advisorships_canonical.json";
import peopleCollaborationGraphData from "../data/people_collaboration_graph.json";
import peopleRelationshipGraphData from "../data/people_relationship_graph.json";
import AdvisorshipCharts from "../components/advisorships/AdvisorshipCharts.astro";
import type { ResearchGroup } from "../types/groups";
import type { ProjectAdvisorship } from "../types/advisorships";
import {
	buildAdvisorshipDashboard,
	buildProjectMart,
	getAdvisorshipProjectsByCampusId,
	getGroupsByCampusId,
	getProjectsByCampusId,
	getRealCampuses,
} from "../lib/tenant-data";
import { researcherCollectionCounts } from "../lib/researcher-collections";
import {
	buildPeopleNetworkOverview,
	type PeopleGraphRawFile,
} from "../lib/people-network";

const groups = groupsData as ResearchGroup[];
const totalGroups = groups.length;
const totalMembers = groups.reduce(
	(acc, g) => acc + (g.members?.length || 0),
	0,
);
const totalCampus = new Set(groups.map((g) => g.campus.id)).size;
const totalKnowledgeAreas = new Set(
	groups.flatMap((g) => g.knowledge_areas.map((ka) => ka.id)),
).size;
const baseUrl = import.meta.env.BASE_URL;
const peopleNetworkOverview = buildPeopleNetworkOverview(
	peopleCollaborationGraphData as PeopleGraphRawFile,
	peopleRelationshipGraphData as PeopleGraphRawFile,
	{
		baseUrl,
	},
);

const allProjects = advisorshipsData as unknown as ProjectAdvisorship[];

// Flatten all advisorships with safeguards
const allAdvisorships = allProjects
	.flatMap((project) =>
		(project.advisorships || []).map((adv) => ({
			...adv,
			projectName: project.name,
		})),
	)
	.filter(Boolean);

// --- Chart Data Calculation (Logic Duplicated from advisorships/index.astro for Home Page reuse) ---
const minYearCalculated = Math.min(
	...allAdvisorships
		.map((a) => {
			const dateStr = a.start_date;
			if (!dateStr || dateStr === "None") return null;
			return new Date(dateStr.replace(" ", "T")).getFullYear();
		})
		.filter((y): y is number => y !== null),
);
const maxYearCalculated = Math.max(
	...allAdvisorships
		.map((a) => {
			const dateStr = a.end_date;
			if (!dateStr || dateStr === "None") return null;
			return new Date(dateStr.replace(" ", "T")).getFullYear();
		})
		.filter((y): y is number => y !== null),
);

// Limit range to last 10 years for better readability as requested
const maxYear = maxYearCalculated;
const minYear = Math.max(minYearCalculated, maxYear - 9);

const yearsRange =
	minYear <= maxYear
		? Array.from({ length: maxYear - minYear + 1 }, (_, i) => minYear + i)
		: [];

const uniqueFellowshipNames = [
	...new Set(
		allAdvisorships
			.map((a) => a.fellowship?.name)
			.filter(Boolean) as string[],
	),
].sort();

const fellowshipColorsMap: Record<string, string> = {
	PIBIC: "#38bdf8",
	PIBITI: "#fbbf24",
	"PIBIC-JR": "#a855f7",
	PIVIC: "#94a3b8",
	PROBIC: "#f472b6",
	Voluntário: "#cbd5e1",
};
const fallbackColors = [
	"#ef4444",
	"#22c55e",
	"#3b82f6",
	"#eab308",
	"#ec4899",
	"#8b5cf6",
];

const fellowshipEvolution = uniqueFellowshipNames
	.map((name, index) => {
		const data = yearsRange.map((year) => {
			const count = allAdvisorships.filter((a) => {
				if (a.fellowship?.name !== name) return false;
				const start = a.start_date
					? new Date(a.start_date.replace(" ", "T")).getFullYear()
					: 9999;
				const end = a.end_date
					? new Date(a.end_date.replace(" ", "T")).getFullYear()
					: 0;
				return start <= year && end >= year;
			}).length;
			return { year, value: count };
		});
		if (data.every((d) => d.value === 0)) return null;
		return {
			label: name,
			data: data,
			color:
				fellowshipColorsMap[name] ||
				fallbackColors[index % fallbackColors.length],
		};
	})
	.filter(Boolean) as {
	label: string;
	data: { year: number; value: number }[];
	color: string;
}[];

const uniqueSponsors = [
	...new Set(
		allAdvisorships
			.map((a) => a.fellowship?.sponsor_name)
			.filter(Boolean) as string[],
	),
].sort();
const sponsorColorsMap: Record<string, string> = {
	Fapes: "#10b981",
	CNPq: "#3b82f6",
	Capes: "#ef4444",
	Facitec: "#f59e0b",
	Ifes: "#8b5cf6",
	MEC: "#06b6d4",
};
const fallbackSponsorColors = ["#ec4899", "#6366f1", "#84cc16"];

const fellowshipFinancialEvolution = uniqueSponsors
	.map((sponsor, index) => {
		const data = yearsRange.map((year) => {
			const totalValue = allAdvisorships.reduce((acc, curr) => {
				if (!curr.fellowship || !curr.fellowship.value) return acc;
				if (curr.fellowship.sponsor_name !== sponsor) return acc;
				const start = curr.start_date
					? new Date(curr.start_date.replace(" ", "T"))
					: new Date(year, 0, 1);
				const end = curr.end_date
					? new Date(curr.end_date.replace(" ", "T"))
					: new Date(year, 11, 31);
				const yearStart = new Date(year, 0, 1);
				const yearEnd = new Date(year, 11, 31);
				const effectiveStart = start > yearStart ? start : yearStart;
				const effectiveEnd = end < yearEnd ? end : yearEnd;
				if (effectiveStart > effectiveEnd) return acc;
				const monthsActive = Math.max(
					0,
					effectiveEnd.getFullYear() * 12 +
						effectiveEnd.getMonth() -
						(effectiveStart.getFullYear() * 12 +
							effectiveStart.getMonth()) +
						1,
				);
				return (
					acc +
					parseFloat(String(curr.fellowship.value)) * monthsActive
				);
			}, 0);
			return { year, value: totalValue };
		});
		if (data.every((d) => d.value === 0)) return null;
		return {
			label: sponsor,
			color:
				sponsorColorsMap[sponsor] ||
				fallbackSponsorColors[index % fallbackSponsorColors.length],
			data,
		};
	})
	.filter(Boolean) as {
	label: string;
	data: { year: number; value: number }[];
	color: string;
}[];

// Mock other analytics to satisfy prop types (unused tabs)
const analytics = {
	status_distribution: [],
	fellowship_distribution: [],
	fellowship_evolution: fellowshipEvolution,
	fellowship_financial_evolution: fellowshipFinancialEvolution,
	top_supervisors: [],
};

const icons = {
	groups: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
	members:
		'<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
	campus: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
	areas: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>',
	student:
		'<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7 12 4l8 3-8 3-8-3Z"/><path d="M6 10.5v4.5c0 1.2 2.7 3 6 3s6-1.8 6-3v-4.5"/><path d="M12 13v5"/></svg>',
	external:
		'<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18"/><path d="M12 3a15 15 0 0 0 0 18"/></svg>',
	unrecognized:
		'<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.09 9a3 3 0 0 1 5.82 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>',
};

const quickAccessPeopleLinks = [
	{
		title: "Pesquisadores",
		description: "Visão completa dos perfis com vínculo institucional.",
		count: researcherCollectionCounts.researchers,
		href: `${baseUrl}researchers`,
		icon: icons.members,
		accentClass:
			"text-premium-accent border-premium-accent/20 bg-premium-accent/[0.06]",
	},
	{
		title: "Estudantes",
		description: "Recorte dedicado aos classificados como student.",
		count: researcherCollectionCounts.students,
		href: `${baseUrl}students`,
		icon: icons.student,
		accentClass:
			"text-premium-purple border-premium-purple/20 bg-premium-purple/[0.06]",
	},
	{
		title: "Externos ao Ifes",
		description: "Colaboradores sem sinais institucionais no Ifes.",
		count: researcherCollectionCounts.outsideIfes,
		href: `${baseUrl}outside-ifes`,
		icon: icons.external,
		accentClass:
			"text-emerald-400 border-emerald-400/20 bg-emerald-400/[0.08]",
	},
	{
		title: "Não reconhecidos",
		description: "Perfis sem evidência suficiente para classificação final.",
		count: researcherCollectionCounts.unrecognized,
		href: `${baseUrl}unrecognized`,
		icon: icons.unrecognized,
		accentClass:
			"text-amber-400 border-amber-400/20 bg-amber-400/[0.08]",
	},
];

const campusStats = Object.fromEntries(
	getRealCampuses().map((campus) => {
		const campusGroups = groups.filter((group) => group.campus.id === campus.id);
		return [
			campus.id,
			{
				totalGroups: campusGroups.length,
				totalMembers: campusGroups.reduce(
					(acc, group) => acc + (group.members?.length || 0),
					0,
				),
				totalCampus: 1,
				totalKnowledgeAreas: new Set(
					campusGroups.flatMap((group) =>
						group.knowledge_areas.map((area) => area.id),
					),
				).size,
			},
		];
	}),
);
const campusHomeViews = Object.fromEntries(
	getRealCampuses().map((campus) => [
		campus.id,
		{
			groups: getGroupsByCampusId(campus.id),
			projectMart: buildProjectMart(getProjectsByCampusId(campus.id)),
			advisorship: buildAdvisorshipDashboard(
				getAdvisorshipProjectsByCampusId(campus.id),
			),
		},
	]),
);
---

<Layout title="Dashboard Overview">
	<header class="mb-10">
		<h1
			class="text-4xl font-extrabold font-['Outfit'] tracking-tight text-text-main text-balance"
		>
			Bem-vindo ao <span
				class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple"
				>Horizon</span
			>
		</h1>
		<p class="text-text-secondary mt-2 max-w-2xl text-balance">
			Sua plataforma central para explorar o horizonte de <strong
				>pesquisa</strong
			>, <strong>extensão</strong> e <strong>pós-graduação</strong> da nossa
			instituição.
		</p>
	</header>

	<div
		class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12"
		role="region"
		aria-label="Métricas principais"
		id="home-kpis"
	>
		<KpiCard
			title="Total de Grupos"
			value={totalGroups}
			icon={icons.groups}
		/>
		<KpiCard
			title="Pesquisadores"
			value={totalMembers}
			icon={icons.members}
			color="premium-purple"
		/>
		<KpiCard
			title="Campus"
			value={totalCampus}
			icon={icons.campus}
			color="text-secondary"
		/>
		<KpiCard
			title="Áreas de Conhecimento"
			value={totalKnowledgeAreas}
			icon={icons.areas}
			color="premium-accent"
		/>
	</div>

	<section class="mb-12" aria-labelledby="quick-access-title">
		<div class="flex items-end justify-between gap-4 mb-6">
			<div>
				<h2
					id="quick-access-title"
					class="text-2xl font-bold font-['Outfit'] text-text-main"
				>
					Acesso rápido a pessoas
				</h2>
				<p class="text-text-secondary mt-1 max-w-2xl">
					Entre direto nos recortes principais de perfis já classificados no
					export canônico.
				</p>
			</div>
		</div>
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
			{
				quickAccessPeopleLinks.map((item) => (
					<a
						href={item.href}
						class="glass-card p-6 border border-border-main hover:border-premium-accent/40 transition-all duration-300 hover:-translate-y-1 group"
					>
						<div class="flex items-start justify-between gap-4">
							<div
								class={`w-12 h-12 rounded-2xl border flex items-center justify-center ${item.accentClass}`}
								aria-hidden="true"
							>
								<Fragment set:html={item.icon} />
							</div>
							<span
								class="text-3xl font-bold font-['Outfit'] text-text-main"
							>
								{item.count}
							</span>
						</div>
						<div class="mt-6">
							<h3
								class="text-lg font-bold text-text-main group-hover:text-premium-accent transition-colors"
							>
								{item.title}
							</h3>
							<p class="text-sm text-text-secondary mt-2">
								{item.description}
							</p>
						</div>
						<div
							class="mt-6 pt-4 border-t border-border-main text-sm font-bold text-premium-accent flex items-center gap-2"
						>
							Abrir listagem
							<svg
								aria-hidden="true"
								xmlns="http://www.w3.org/2000/svg"
								class="w-4 h-4 transition-transform group-hover:translate-x-1"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M5 12h14"></path>
								<path d="m12 5 7 7-7 7"></path>
							</svg>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<!-- Analytics Charts (US-035) -->
	<div id="home-charts-views">
		<div data-campus-view="">
			<HomeCharts />
		</div>
		{
			Object.entries(campusHomeViews).map(([campusId, view]) => (
				<div data-campus-view={campusId} class="hidden">
					<HomeCharts martData={view.projectMart} groupsData={view.groups} />
				</div>
			))
		}
	</div>

	<!-- Fellowship & Investment Charts (Home Integration) -->
	<div id="home-advisorship-views">
		<section class="mt-12 mb-12" data-campus-view="">
			<h2 class="text-2xl font-bold font-['Outfit'] text-text-main mb-6">
				Investimento e Bolsas
			</h2>
			<AdvisorshipCharts
				analytics={analytics}
				visibleTabs={["financial", "fellowships"]}
			/>
		</section>
		{
			Object.entries(campusHomeViews).map(([campusId, view]) => (
				<section class="mt-12 mb-12 hidden" data-campus-view={campusId}>
					<h2 class="text-2xl font-bold font-['Outfit'] text-text-main mb-6">
						Investimento e Bolsas
					</h2>
					<AdvisorshipCharts
						analytics={view.advisorship.analytics}
						visibleTabs={["financial", "fellowships"]}
					/>
				</section>
			))
		}
	</div>

	<PeopleNetworkOverview overview={peopleNetworkOverview} />

	<script define:vars={{ campusStats, defaultStats: { totalGroups, totalMembers, totalCampus, totalKnowledgeAreas } }}>
		window.__homeCampusStats = campusStats;
		window.__homeDefaultStats = defaultStats;
	</script>

	<script>
		import { getCampusFilterValue, updateCampusViews } from '../lib/campus-ui';

		function updateHomeKpis(selectedCampus) {
			const campusStats = (window as any).__homeCampusStats || {};
			const defaultStats = (window as any).__homeDefaultStats || {};
			const stats = selectedCampus && campusStats[selectedCampus]
				? campusStats[selectedCampus]
				: defaultStats;
			const cards = document.querySelectorAll('[data-kpi-card]');
			cards.forEach((card) => {
				const title = card.getAttribute('data-kpi-card');
				const valueNode = card.querySelector('[data-kpi-value]');
				if (!valueNode) return;
				if (title === 'Total de Grupos') valueNode.textContent = String(stats.totalGroups);
				if (title === 'Pesquisadores') valueNode.textContent = String(stats.totalMembers);
				if (title === 'Campus') valueNode.textContent = String(stats.totalCampus);
				if (title === 'Áreas de Conhecimento') valueNode.textContent = String(stats.totalKnowledgeAreas);
			});
		}

		function updateHomeViews(selectedCampus) {
			updateCampusViews(
				'#home-charts-views [data-campus-view], #home-advisorship-views [data-campus-view]',
				selectedCampus
			);
		}

		window.addEventListener('campus-filter-change', (event) => {
			const campusId = getCampusFilterValue(event);
			updateHomeKpis(campusId);
			updateHomeViews(campusId);
		});

		const initialCampus = localStorage.getItem('preferred-campus') || '';
		updateHomeKpis(initialCampus);
		updateHomeViews(initialCampus);
	</script>
</Layout>
