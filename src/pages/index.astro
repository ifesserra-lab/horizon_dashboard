---
import { statSync } from "node:fs";
import { fileURLToPath } from "node:url";
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import groupsData from "../data/research_groups_canonical.parquet";
import projectsData from "../data/initiatives_canonical.parquet";
import dataMeta from "../data/_meta.json";
import { researcherCollectionCounts } from "../lib/researcher-collections";
import {
    getAggregatedPublications,
    buildPublicationsMart,
    getCampusPublicationViews,
} from "../lib/publications-data";
import { getRealCampuses, getGroupsByCampusId } from "../lib/tenant-data";

const base = import.meta.env.BASE_URL;
const indexUrl = `${base}search-index.json`;

// Frescor do dado: data do último import ETL, gravada em src/data/_meta.json
// pelo pipeline (sync-etl-data.yml) só quando os dados mudam. Fallbacks: mtime
// do export de artigos e, por fim, a data do build.
let lastUpdate: Date;
const metaDate = new Date((dataMeta as { generated_at?: string }).generated_at ?? "");
if (!Number.isNaN(metaDate.getTime())) {
    lastUpdate = metaDate;
} else {
    try {
        lastUpdate = statSync(
            fileURLToPath(new URL("../data/articles_canonical.parquet", import.meta.url)),
        ).mtime;
    } catch {
        lastUpdate = new Date();
    }
}
const lastUpdateLabel = lastUpdate.toLocaleDateString("pt-BR", {
    day: "2-digit",
    month: "long",
    year: "numeric",
});

// Números do acervo (dado canônico) — coerentes com as páginas de seção.
const nf = (n: number) => n.toLocaleString("pt-BR");
const nGroups = (groupsData as any[]).length;
const nProjects = (projectsData as any[]).length;
const nResearchers = researcherCollectionCounts.researchers;
const nPublications = buildPublicationsMart(
    getAggregatedPublications(),
).summary.total_publications;
const nAreas = new Set(
    (groupsData as any[]).flatMap((g) =>
        (g.knowledge_areas || []).map((a: any) => a.id),
    ),
).size;

// type = tipo no índice de busca (para os números baterem com as facetas).
// "area" não existe no índice → usa o valor do servidor (data-areas).
const stats = [
    { type: "publicacao", n: nPublications, label: "publicações" },
    { type: "pesquisador", n: nResearchers, label: "pesquisadores" },
    { type: "projeto", n: nProjects, label: "projetos" },
    { type: "area", n: nAreas, label: "áreas de conhecimento" },
];

const ICON = {
    groups: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle>`,
    people: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>`,
    projects: `<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A5 5 0 0 0 8 8c0 1.3.5 2.6 1.5 3.5.8.8 1.3 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path>`,
    book: `<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>`,
    download: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line>`,
};

const tiles = [
    { label: "Grupos", href: `${base}groups`, type: "grupo", n: nGroups, word: "grupos", icon: ICON.groups },
    { label: "Pesquisadores", href: `${base}researchers`, type: "pesquisador", n: nResearchers, word: "perfis", icon: ICON.people },
    { label: "Projetos", href: `${base}projects`, type: "projeto", n: nProjects, word: "iniciativas", icon: ICON.projects },
    { label: "Publicações", href: `${base}publications`, type: "publicacao", n: nPublications, word: "trabalhos", icon: ICON.book },
    { label: "Áreas", href: `${base}knowledge-areas`, type: "area", n: nAreas, word: "áreas", icon: ICON.book },
    { label: "Dados abertos", href: `${base}download`, type: null, sub: "baixar bases", icon: ICON.download },
];

// Números por campus (para os atalhos reagirem ao filtro). Chaveado pelo nome
// do campus — igual ao campo `c` do índice e ao evento campus-filter-change.
// pesquisadores/projetos/grupos filtram no cliente pelo índice; publicações e
// áreas (sem campus no índice) vêm daqui, do dado canônico.
const campusPubViews = getCampusPublicationViews();
const campusExtra: Record<string, { publicacao: number; area: number }> = {};
for (const campus of getRealCampuses()) {
    const cg = getGroupsByCampusId(campus.id);
    campusExtra[campus.name] = {
        publicacao:
            (campusPubViews as any)[campus.id]?.summary?.total_publications ?? 0,
        area: new Set(
            cg.flatMap((g: any) =>
                (g.knowledge_areas || []).map((a: any) => a.id),
            ),
        ).size,
    };
}

// Fórmula do índice de destaque (mesma do score() da busca, query vazia).
const destaqueFormula =
    "√FWCI × 18 + publicações × 2 + projetos × 2 + participações × 1 + áreas × 2 + 1";
---

<Layout title="Buscar pesquisa">
    <div
        class="max-w-4xl mx-auto px-1"
        data-base={base}
        data-index-url={indexUrl}
        data-areas={nAreas}
        data-campus-extra={JSON.stringify(campusExtra)}
    >
        <!-- Hero — editorial, left-aligned -->
        <section class="pt-12 pb-8">
            <p
                class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted mb-4"
            >
                Pesquisa · Ifes
            </p>
            <h1
                class="font-display text-4xl md:text-6xl font-bold tracking-tight text-text-main leading-[1.02] text-balance"
            >
                Encontre pesquisas, pessoas e grupos.
            </h1>
            <p
                class="mt-5 font-display text-xl md:text-2xl font-medium text-text-main/85 max-w-2xl text-balance leading-snug"
            >
                Um horizonte para a pesquisa do <span
                    class="text-premium-accent">Ifes</span
                >.
            </p>

            <!-- Busca — ação principal, no topo -->
            <div class="home-search mt-8">
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    aria-hidden="true"
                    ><circle cx="11" cy="11" r="7"></circle><path
                        d="m21 21-4.3-4.3"></path></svg
                >
                <input
                    type="search"
                    id="q"
                    autocomplete="off"
                    aria-label="Buscar pesquisas, pessoas e grupos"
                />
            </div>

            <!-- Personas -->
            <div
                class="mt-4 flex items-center flex-wrap gap-2 text-sm"
                role="group"
                aria-label="Quem está buscando"
            >
                <span class="text-text-muted mr-1">Busco como</span>
                <button type="button" data-persona="aluno" class="persona-btn"
                    >aluno</button
                >
                <button type="button" data-persona="professor" class="persona-btn"
                    >professor</button
                >
                <button type="button" data-persona="empresa" class="persona-btn"
                    >empresa</button
                >
            </div>
            <p id="lens" class="mt-2 text-sm text-text-muted"></p>
            <p
                id="suggest"
                class="mt-4 text-sm text-text-muted flex flex-wrap gap-x-4 gap-y-1"
            >
            </p>

            <!-- Números do acervo -->
            <div class="home-stats mt-8" aria-label="Números do acervo">
                {
                    stats.map((s) => (
                        <div>
                            <div class="n" data-count={s.type}>
                                {nf(s.n)}
                            </div>
                            <div class="l">{s.label}</div>
                        </div>
                    ))
                }
            </div>
            <p class="mt-2 font-mono text-xs text-text-muted">
                Atualizado em {lastUpdateLabel}
            </p>

            <!-- Entradas por seção -->
            <div class="home-tiles mt-4">
                {
                    tiles.map((t) => (
                        <a class="home-tile" href={t.href}>
                            <span class="ic">
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                    set:html={t.icon}
                                />
                            </span>
                            <span class="tx">
                                <span class="t">{t.label}</span>
                                <span class="c">
                                    {t.type ? (
                                        <>
                                            <span data-count={t.type}>{nf(t.n)}</span> {t.word}
                                        </>
                                    ) : (
                                        t.sub
                                    )}
                                </span>
                            </span>
                            <span class="arw" aria-hidden="true">
                                →
                            </span>
                        </a>
                    ))
                }
            </div>

            <!-- Assinatura: publicações por ano (linha do horizonte) -->
            <HomeHero />
        </section>

        <!-- Results -->
        <section class="pb-24 pt-2">
            <div
                class="flex items-baseline justify-between border-t border-border-main pt-4 mb-1"
            >
                <div class="flex items-center gap-4">
                    <h2
                        id="resultsTitle"
                        class="text-sm font-bold text-text-main"
                    >
                        Em destaque
                    </h2>
                    <div
                        id="facetType"
                        class="hidden md:flex items-center gap-3 text-sm"
                    >
                    </div>
                </div>
                <span
                    id="resultsCount"
                    class="text-xs tabular-nums text-text-muted"></span>
            </div>

            <details id="destaqueNote" class="destaque-note">
                <summary>
                    <span class="font-mono">índice de destaque</span> — como é
                    calculado?
                </summary>
                <div class="destaque-body">
                    <p class="destaque-formula font-mono">{destaqueFormula}</p>
                    <ul>
                        <li>
                            <strong>√FWCI × 18</strong> — impacto de citação
                            normalizado por área (FWCI: 1,0 = média mundial para
                            a mesma área, ano e tipo), via OpenAlex. A raiz
                            quadrada suaviza a cauda longa das citações; é o sinal
                            de qualidade, por isso o peso maior.
                        </li>
                        <li>
                            <strong>publicações × 2</strong> — volume de artigos.
                        </li>
                        <li>
                            <strong>projetos × 2</strong> — iniciativas de
                            pesquisa e extensão.
                        </li>
                        <li>
                            <strong>participações × 1</strong> — vínculos em
                            grupos de pesquisa.
                        </li>
                        <li>
                            <strong>áreas × 2</strong> — amplitude temática.
                        </li>
                        <li><strong>+ 1</strong> — piso, para todo perfil pontuar.</li>
                    </ul>
                    <p>
                        O peso ponderado pela lente (aluno · professor · empresa)
                        ajusta a ordem ao que cada público procura. A
                        normalização de citações por campo segue a família de
                        indicadores <em>crown</em> (Waltman et al., 2011); o
                        índice h exibido em cada perfil segue Hirsch (2005). Os
                        pesos são uma calibração editorial do portal, não de um
                        artigo.
                    </p>
                    <p class="destaque-refs">
                        Referências: FWCI —
                        <a
                            href="https://help.openalex.org/hc/en-us/articles/24735753007895-Field-Weighted-Citation-Impact-FWCI"
                            target="_blank"
                            rel="noopener">OpenAlex</a
                        >; Waltman et al. (2011), <em>Scientometrics</em> 87(3):467–481
                        —
                        <a
                            href="https://arxiv.org/abs/1004.1632"
                            target="_blank"
                            rel="noopener">arXiv:1004.1632</a
                        >; Hirsch (2005), <em>PNAS</em> 102(46):16569–72 —
                        <a
                            href="https://doi.org/10.1073/pnas.0507655102"
                            target="_blank"
                            rel="noopener">doi:10.1073/pnas.0507655102</a
                        >.
                    </p>
                </div>
            </details>

            <div id="results" class="divide-y divide-border-main"></div>

            <div id="loadingState" class="py-16 text-text-muted text-sm">
                Carregando…
            </div>
            <div id="emptyState" class="hidden py-16 text-text-muted">
                <p class="text-text-main">Nada encontrado.</p>
                <p class="text-sm mt-1">Tente outro termo.</p>
            </div>

            <p class="mt-10 text-sm">
                <a
                    href={`${base}painel`}
                    class="text-text-muted hover:text-premium-accent transition-colors"
                    >Painel de indicadores e gráficos →</a
                >
            </p>
        </section>
    </div>

    <style>
        .persona-btn {
            border: 1px solid var(--border-primary);
            border-radius: 999px;
            padding: 5px 13px;
            line-height: 1.2;
            color: var(--text-secondary);
            background: var(--surface);
            transition: all 0.15s;
        }
        .persona-btn:hover {
            color: var(--color-premium-accent);
            border-color: var(--color-premium-accent);
        }
        .persona-btn[aria-pressed="true"] {
            background: var(--brand-green-dark);
            color: #fff;
            border-color: var(--brand-green-dark);
            font-weight: 500;
        }
        .facet-btn[aria-pressed="true"] {
            color: var(--text-primary);
            font-weight: 700;
        }

        /* Busca — ação principal, no topo */
        .home-search {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--surface);
            border: 1.5px solid var(--border-primary);
            border-radius: 14px;
            padding: 14px 18px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03), 0 6px 20px rgba(0, 0, 0, 0.04);
            transition: border-color 0.15s;
        }
        .home-search:focus-within {
            border-color: var(--brand-green);
        }
        .home-search svg {
            width: 22px;
            height: 22px;
            color: var(--text-secondary);
            flex: none;
        }
        .home-search input {
            border: 0;
            background: transparent;
            outline: none;
            width: 100%;
            font-size: 1.2rem;
            font-family: var(--font-sans);
            color: var(--text-primary);
        }
        .home-search input::placeholder {
            color: var(--text-tertiary);
        }

        /* Números do acervo */
        .home-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border: 1px solid var(--border-primary);
            border-radius: 14px;
            overflow: hidden;
            background: var(--surface);
        }
        .home-stats > div {
            padding: 16px 18px;
        }
        .home-stats > div + div {
            border-left: 1px solid var(--border-primary);
        }
        .home-stats .n {
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--color-premium-accent);
            font-variant-numeric: tabular-nums;
        }
        .home-stats .l {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 2px;
        }
        @media (max-width: 640px) {
            .home-stats {
                grid-template-columns: repeat(2, 1fr);
            }
            .home-stats > div:nth-child(3) {
                border-left: 0;
            }
            .home-stats > div:nth-child(3),
            .home-stats > div:nth-child(4) {
                border-top: 1px solid var(--border-primary);
            }
        }

        /* Entradas por seção */
        .home-tiles {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
        }
        @media (max-width: 640px) {
            .home-tiles {
                grid-template-columns: 1fr;
            }
        }
        .home-tile {
            display: flex;
            align-items: center;
            gap: 14px;
            background: var(--surface);
            border: 1px solid var(--border-primary);
            border-radius: 14px;
            padding: 14px 16px;
            text-decoration: none;
            color: var(--text-primary);
            transition: border-color 0.15s, transform 0.15s;
        }
        .home-tile:hover {
            border-color: var(--color-premium-accent);
            transform: translateY(-1px);
        }
        .home-tile .ic {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            flex: none;
            display: flex;
            align-items: center;
            justify-content: center;
            background: color-mix(in srgb, var(--brand-green) 12%, transparent);
            color: var(--brand-green-dark);
        }
        .home-tile .ic svg {
            width: 20px;
            height: 20px;
        }
        .home-tile .tx {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }
        .home-tile .t {
            font-weight: 700;
            line-height: 1.2;
        }
        .home-tile .c {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            color: var(--text-secondary);
        }
        .home-tile .arw {
            margin-left: auto;
            color: var(--text-tertiary);
        }

        /* Metodologia do índice de destaque */
        .destaque-note {
            margin-bottom: 1rem;
            max-width: 46rem;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .destaque-note > summary {
            cursor: pointer;
            list-style: none;
            color: var(--text-secondary);
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }
        .destaque-note > summary::-webkit-details-marker {
            display: none;
        }
        .destaque-note > summary::after {
            content: "▸";
            color: var(--text-tertiary);
            transition: transform 0.15s;
        }
        .destaque-note[open] > summary::after {
            transform: rotate(90deg);
        }
        .destaque-note > summary:hover {
            color: var(--color-premium-accent);
        }
        .destaque-body {
            margin-top: 0.6rem;
            padding-left: 0.9rem;
            border-left: 2px solid var(--border-primary);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .destaque-formula {
            color: var(--text-primary);
            font-size: 0.78rem;
            background: var(--tag-bg);
            border: 1px solid var(--border-primary);
            border-radius: 8px;
            padding: 6px 10px;
        }
        .destaque-body ul {
            margin: 0;
            padding-left: 1.1rem;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }
        .destaque-body strong {
            color: var(--text-primary);
        }
        .destaque-refs {
            color: var(--text-tertiary);
            font-size: 0.74rem;
        }
        .destaque-refs a {
            color: var(--color-premium-accent);
            text-decoration: underline;
            text-underline-offset: 2px;
        }
    </style>

    <script>
        import { normalizeSearchText } from "../lib/search";

        interface Entry {
            i: string;
            t: string;
            n: string;
            c?: string | null;
            a?: string[];
            g?: string[];
            l?: string[];
            team?: string[];
            na?: number;
            ni?: number;
            nm?: number;
            st?: string | null;
            v?: string | null;
            y?: number | null;
            pt?: string | null;
            f?: number;
            h?: number;
            _s?: string;
        }

        const root = document.querySelector("[data-index-url]") as HTMLElement;
        const base = root.dataset.base || "/";
        const indexUrl = root.dataset.indexUrl as string;
        const areasCount = Number(root.dataset.areas) || 0;
        const campusExtra: Record<
            string,
            { publicacao: number; area: number }
        > = JSON.parse(root.dataset.campusExtra || "{}");
        const activeCampusName = () =>
            document.documentElement.dataset.activeCampusName || "";

        // Preenche os números do acervo (stats + tiles). Sem campus: do índice
        // (batem com as facetas). Com campus: pesquisadores/projetos/grupos
        // filtram pelo campo `c` do índice; publicações e áreas (sem campus no
        // índice) vêm do mapa do servidor.
        function fillCounts(campusName: string) {
            const counts: Record<string, number> = {};
            if (campusName && campusExtra[campusName]) {
                for (const e of entries)
                    if (e.c === campusName)
                        counts[e.t] = (counts[e.t] || 0) + 1;
                counts.publicacao = campusExtra[campusName].publicacao;
                counts.area = campusExtra[campusName].area;
            } else {
                for (const e of entries) counts[e.t] = (counts[e.t] || 0) + 1;
                counts.area = areasCount;
            }
            document
                .querySelectorAll<HTMLElement>("[data-count]")
                .forEach((el) => {
                    const t = el.dataset.count as string;
                    el.textContent = (counts[t] || 0).toLocaleString("pt-BR");
                });
        }

        const TYPE_LABEL: Record<string, string> = {
            pesquisador: "Pesquisador",
            aluno: "Aluno",
            grupo: "Grupo",
            projeto: "Projeto",
            publicacao: "Publicação",
        };
        const TYPE_URL: Record<string, (i: string) => string | null> = {
            pesquisador: (i) => `${base}researchers/${i}/`,
            aluno: (i) => `${base}students/${i}/`,
            grupo: (i) => `${base}groups/${i}/`,
            projeto: (i) => `${base}projects/${i}/`,
            publicacao: (i) => `${base}publications/${i}`,
        };

        const PERSONAS: Record<
            string,
            { lens: string; placeholder: string; w: Record<string, number> }
        > = {
            aluno: {
                lens: "Priorizando orientadores e grupos para ingressar.",
                placeholder: "robótica, educação inclusiva, energia solar…",
                w: { pesquisador: 1, aluno: 0.6, grupo: 1.2, projeto: 1.1, publicacao: 0.5 },
            },
            professor: {
                lens: "Priorizando pares, produção e parcerias.",
                placeholder: "uma área, pesquisador ou tema de colaboração…",
                w: { pesquisador: 1.2, aluno: 0.5, grupo: 1.05, projeto: 0.95, publicacao: 1.05 },
            },
            empresa: {
                lens: "Priorizando especialistas e grupos que podem apoiar.",
                placeholder: "um problema ou tecnologia…",
                w: { grupo: 1.25, pesquisador: 1.1, projeto: 1.2, aluno: 0.4, publicacao: 0.4 },
            },
        };

        let persona = "aluno";
        let query = "";
        let fType: string | null = null;
        let entries: Entry[] = [];

        const $ = (id: string) => document.getElementById(id)!;
        const esc = (s: unknown) =>
            String(s ?? "").replace(
                /[&<>"']/g,
                (c) =>
                    ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[
                        c
                    ] as string,
            );

        function searchText(e: Entry): string {
            return [e.n, ...(e.a || []), ...(e.g || []), ...(e.l || []), ...(e.team || []), e.c, e.v]
                .filter(Boolean)
                .join(" ");
        }

        function score(e: Entry, tokens: string[]): number {
            const w = PERSONAS[persona].w[e.t] ?? 1;
            if (tokens.length === 0) {
                const base =
                    Math.sqrt(e.f || 0) * 18 +
                    (e.na || 0) * 2 +
                    (e.ni || 0) * 2 +
                    (e.nm || 0) +
                    (e.a?.length || 0) * 2 +
                    1;
                return base * w;
            }
            const name = normalizeSearchText(e.n);
            let s = 0;
            for (const t of tokens) {
                if (!t) continue;
                if (name.includes(t)) s += 12;
                if (e._s!.includes(t)) s += 5;
                for (const a of e.a || []) if (normalizeSearchText(a).includes(t)) s += 6;
            }
            return s === 0 ? 0 : s * w;
        }

        function currentResults(): Entry[] {
            const tokens = normalizeSearchText(query).split(" ").filter(Boolean);
            let list = entries.map((e) => ({ e, s: score(e, tokens) })).filter((x) => x.s > 0);
            if (fType) list = list.filter((x) => x.e.t === fType);
            list.sort((a, b) => b.s - a.s);
            const ranked = list.map((x) => x.e);
            // Destaques rotativos: sem busca e sem filtro, alterna tipos
            // (pesquisadores, grupos, projetos, publicações) e rotaciona a cada
            // visita para não mostrar sempre os mesmos.
            if (tokens.length === 0 && !fType) return diversify(ranked);
            return ranked;
        }

        function diversify(ranked: Entry[]): Entry[] {
            const byType: Record<string, Entry[]> = {};
            for (const e of ranked) (byType[e.t] ||= []).push(e);
            const order = ["pesquisador", "grupo", "projeto", "publicacao", "aluno"];
            const rot = Math.floor(Date.now() / 60000); // muda a cada minuto
            const pools: Record<string, Entry[]> = {};
            const idx: Record<string, number> = {};
            for (const t of order) {
                const p = (byType[t] || []).slice(0, 12); // rotaciona dentro do topo
                pools[t] = p;
                idx[t] = p.length ? rot % p.length : 0;
            }
            const out: Entry[] = [];
            const seen = new Set<Entry>();
            let added = true;
            while (added && out.length < 40) {
                added = false;
                for (const t of order) {
                    const p = pools[t];
                    if (!p.length) continue;
                    let e: Entry | null = null;
                    for (let tries = 0; tries < p.length; tries++) {
                        const cand = p[idx[t]++ % p.length];
                        if (!seen.has(cand)) {
                            e = cand;
                            break;
                        }
                    }
                    if (e) {
                        seen.add(e);
                        out.push(e);
                        added = true;
                    }
                }
            }
            return out;
        }

        function metaBits(e: Entry): string[] {
            const bits: string[] = [];
            // Áreas viram tags (chips) na linha — ver rowHtml.
            if (e.t === "pesquisador" || e.t === "aluno") {
                if (e.f) bits.push(`FWCI ${e.f.toFixed(2)}`);
                if (e.h) bits.push(`h ${e.h}`);
                if (e.na) bits.push(`${e.na} publicações`);
            } else if (e.t === "grupo") {
                if (e.l && e.l[0]) bits.push(`Líder ${esc(e.l[0])}`);
                if (e.nm) bits.push(`${e.nm} integrantes`);
            } else if (e.t === "projeto") {
                if (e.st) bits.push(esc(e.st));
            } else if (e.t === "publicacao") {
                if (e.v) bits.push(esc(e.v));
                if (e.y) bits.push(String(e.y));
            }
            if (e.c) bits.push(esc(e.c));
            return bits;
        }

        function rowHtml(e: Entry): string {
            const url = TYPE_URL[e.t]?.(e.i) ?? null;
            const meta = metaBits(e).join("  ·  ");
            const areas = Array.isArray(e.a) ? (e.a as string[]) : [];
            const areaLabel =
                e.t === "pesquisador" || e.t === "aluno"
                    ? persona === "empresa"
                        ? "Especialista em"
                        : persona === "aluno"
                          ? "Orienta em"
                          : "Atua em"
                    : e.t === "grupo" || e.t === "projeto"
                      ? "Áreas"
                      : "";
            const chips = areas.length
                ? `<div class="mt-1.5 flex flex-wrap items-center gap-1.5">
                        ${areaLabel ? `<span class="text-[10px] uppercase tracking-wider text-text-muted/70 mr-0.5">${areaLabel}</span>` : ""}
                        ${areas
                            .slice(0, 4)
                            .map(
                                (a) =>
                                    `<span class="px-2 py-0.5 rounded-md bg-tag-bg border border-border-main text-[10px] text-text-secondary">${esc(a)}</span>`,
                            )
                            .join("")}
                        ${areas.length > 4 ? `<span class="text-[10px] text-text-muted">+${areas.length - 4}</span>` : ""}
                    </div>`
                : "";
            const inner = `
                <div class="flex items-baseline gap-4 py-4 group">
                    <span class="w-24 flex-none text-[11px] uppercase tracking-wider text-text-muted pt-0.5">${esc(TYPE_LABEL[e.t] || e.t)}</span>
                    <div class="min-w-0 flex-1">
                        <span class="font-display text-lg text-text-main group-hover:text-premium-accent transition-colors">${esc(e.n)}</span>
                        ${meta ? `<div class="text-sm text-text-muted mt-0.5">${meta}</div>` : ""}
                        ${chips}
                    </div>
                    ${url ? `<span class="flex-none text-text-muted/50 group-hover:text-premium-accent group-hover:translate-x-0.5 transition-all pt-1">→</span>` : ""}
                </div>`;
            return url
                ? `<a href="${esc(url)}" class="block">${inner}</a>`
                : `<div>${inner}</div>`;
        }

        function render() {
            const cfg = PERSONAS[persona];
            ($("q") as HTMLInputElement).placeholder = cfg.placeholder;
            $("lens").textContent = cfg.lens;

            const res = currentResults();
            const tokens = normalizeSearchText(query).split(" ").filter(Boolean);

            const forType = entries.filter((e) => score(e, tokens) > 0);
            const counts: Record<string, number> = {};
            for (const e of forType) counts[e.t] = (counts[e.t] || 0) + 1;
            $("facetType").innerHTML =
                `<button data-ftype="" aria-pressed="${!fType}" class="facet-btn text-text-muted hover:text-text-main transition-colors">Tudo</button>` +
                Object.keys(TYPE_LABEL)
                    .filter((t) => counts[t])
                    .map(
                        (t) =>
                            `<button data-ftype="${t}" aria-pressed="${fType === t}" class="facet-btn text-text-muted hover:text-text-main transition-colors">${TYPE_LABEL[t]} <span class="tabular-nums text-text-muted/60">${counts[t]}</span></button>`,
                    )
                    .join("");

            $("resultsTitle").textContent = query ? "Resultados" : "Em destaque";
            $("resultsCount").textContent = `${res.length}`;
            // Fórmula do índice só no modo "Em destaque".
            $("destaqueNote").style.display = query || fType ? "none" : "block";

            const box = $("results");
            $("loadingState").classList.add("hidden");
            if (res.length === 0) {
                box.innerHTML = "";
                $("emptyState").classList.remove("hidden");
            } else {
                $("emptyState").classList.add("hidden");
                box.innerHTML = res.slice(0, 40).map(rowHtml).join("");
            }
        }

        function setQuery(v: string) {
            query = v;
            ($("q") as HTMLInputElement).value = v;
            fType = null;
            render();
            window.scrollTo({ top: 0, behavior: "smooth" });
        }

        function buildSuggest() {
            const areaCount: Record<string, number> = {};
            for (const e of entries)
                for (const a of e.a || []) areaCount[a] = (areaCount[a] || 0) + 1;
            const top = Object.entries(areaCount)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 7);
            $("suggest").innerHTML =
                `<span class="text-text-muted/70">Sugestões:</span>` +
                top
                    .map(
                        ([a]) =>
                            `<button data-suggest="${esc(a)}" class="text-text-main hover:text-premium-accent underline underline-offset-4 decoration-border-main hover:decoration-premium-accent transition-colors">${esc(a)}</button>`,
                    )
                    .join("");
        }

        function syncPersonaButtons() {
            document.querySelectorAll(".persona-btn").forEach((x) =>
                x.setAttribute(
                    "aria-pressed",
                    String((x as HTMLElement).dataset.persona === persona),
                ),
            );
        }

        document.querySelectorAll(".persona-btn").forEach((b) =>
            b.addEventListener("click", () => {
                persona = (b as HTMLElement).dataset.persona!;
                syncPersonaButtons();
                render();
            }),
        );
        $("q").addEventListener("input", (ev) => {
            query = (ev.target as HTMLInputElement).value;
            render();
        });
        document.body.addEventListener("click", (ev) => {
            const el = ev.target as HTMLElement;
            const ft = el.closest("[data-ftype]") as HTMLElement | null;
            const sg = el.closest("[data-suggest]") as HTMLElement | null;
            if (sg) setQuery(sg.dataset.suggest!);
            else if (ft) {
                fType = ft.dataset.ftype || null;
                render();
            }
        });

        syncPersonaButtons();

        // Atalhos e números reagem ao filtro de campus.
        window.addEventListener("campus-filter-change", (ev) => {
            const detail = (ev as CustomEvent).detail || {};
            fillCounts(detail.campusName || "");
        });

        fetch(indexUrl)
            .then((r) => r.json())
            .then((data: Entry[]) => {
                entries = data;
                for (const e of entries) e._s = normalizeSearchText(searchText(e));
                fillCounts(activeCampusName());
                buildSuggest();
                render();
            })
            .catch(() => {
                $("loadingState").textContent = "Não foi possível carregar o índice.";
            });
    </script>
</Layout>
