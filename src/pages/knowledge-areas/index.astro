---
import Layout from '../../layouts/Layout.astro';
import researchGroups from '../../data/research_groups_canonical.json';
import KnowledgeAreaView from '../../components/knowledge-areas/KnowledgeAreaView.astro';
import {
	getGroupsByCampusId,
	getKnowledgeAreasByCampusId,
	getKnowledgeAreasView,
	getRealCampuses,
} from '../../lib/tenant-data';

// Calculate KPI values from canonical data
const totalGroups = researchGroups.length;
const sortedAreas = getKnowledgeAreasView();

// Calculate Top 10 Areas directly from Mart data
const top10Areas = sortedAreas
	.slice(0, 10)
	.map((area) => ({
		name: area.area_name,
		count: area.groups_count,
		percentage: totalGroups > 0 ? (area.groups_count / totalGroups) * 100 : 0
	}));
const campusAreaViews = Object.fromEntries(
	getRealCampuses().map((campus) => {
		const campusAreas = getKnowledgeAreasByCampusId(campus.id);
		const campusGroupsCount = getGroupsByCampusId(campus.id).length;

		return [
			campus.id,
			{
				sortedAreas: campusAreas,
				top10Areas: campusAreas.slice(0, 10).map((area) => ({
					name: area.area_name,
					count: area.groups_count,
					percentage: campusGroupsCount > 0 ? (area.groups_count / campusGroupsCount) * 100 : 0,
				})),
			},
		];
	}),
);
const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Áreas de Conhecimento">
	<div class="space-y-8">
		<header class="mb-10">
			<div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
				<div>
					<h1 class="text-4xl font-extrabold font-['Outfit'] tracking-tight text-text-main">
						Áreas de <span class="text-transparent bg-clip-text bg-gradient-to-r from-premium-accent to-premium-purple">Conhecimento</span>
					</h1>
					<p class="text-text-secondary mt-2 max-w-2xl">Distribuição dos grupos de pesquisa por áreas acadêmicas.</p>
				</div>
				
				<div class="relative max-w-md w-full">
					<label for="areaSearch" class="sr-only">Buscar por área ou grupos</label>
					<input 
						type="text" 
						id="areaSearch"
						placeholder="Buscar por área, campus ou grupos..." 
						class="w-full bg-glass-bg border border-border-main rounded-2xl px-12 py-4 text-sm focus:outline-none focus:ring-2 focus:ring-premium-accent/50 focus:border-premium-accent transition-all text-text-main shadow-lg shadow-premium-accent/5"
					/>
					<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
					
					<button id="resetAreaSearch" class="absolute right-4 top-1/2 -translate-y-1/2 text-text-secondary hover:text-premium-accent transition-colors hidden" title="Limpar busca">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 9-6 6"/><path d="m9 9 6 6"/><circle cx="12" cy="12" r="10"/></svg>
					</button>
				</div>
			</div>
		</header>

		<div id="knowledge-areas-views" class="space-y-8">
			<div data-campus-view="" class="space-y-8">
				<KnowledgeAreaView
					sortedAreas={sortedAreas}
					top10Areas={top10Areas}
					baseUrl={baseUrl}
				/>
			</div>
			{
				Object.entries(campusAreaViews).map(([campusId, view]) => (
					<div data-campus-view={campusId} class="space-y-8 hidden">
						<KnowledgeAreaView
							sortedAreas={view.sortedAreas}
							top10Areas={view.top10Areas}
							baseUrl={baseUrl}
						/>
					</div>
				))
			}
		</div>

		<!-- Empty State -->
		<div id="emptyState" class="hidden flex-col items-center justify-center py-24 text-center">
			<div class="w-24 h-24 bg-slate-100 dark:bg-white/5 rounded-3xl flex items-center justify-center mb-6 text-text-secondary border border-border-main border-dashed">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></svg>
			</div>
			<h3 class="text-2xl font-bold font-['Outfit'] text-text-main mb-2">Nenhuma área encontrada</h3>
			<p class="text-text-secondary max-w-sm">
				Não encontramos nenhuma área de conhecimento ou grupo que corresponda à sua busca.
			</p>
		</div>
	</div>

	<script>
		const searchInput = document.getElementById('areaSearch') as HTMLInputElement;
		const resetBtn = document.getElementById('resetAreaSearch');
		const emptyState = document.getElementById('emptyState');
		function updateAreaViews(selectedCampus) {
			document
				.querySelectorAll('#knowledge-areas-views [data-campus-view]')
				.forEach((node) => {
					const viewCampus = node.getAttribute('data-campus-view') || '';
					node.classList.toggle('hidden', viewCampus !== selectedCampus);
				});
		}

		function filterAreas() {
			const query = searchInput.value.toLowerCase().trim();
			const preferredCampus = localStorage.getItem('preferred-campus') || '';
			const activeView = document.querySelector(
				`#knowledge-areas-views [data-campus-view="${preferredCampus}"]`
			) ||
				document.querySelector('#knowledge-areas-views [data-campus-view=""]');
			const areaCards = activeView?.querySelectorAll('.area-card') || [];
			let visibleCount = 0;

			// Show/hide reset button
			if (query) {
				resetBtn?.classList.remove('hidden');
			} else {
				resetBtn?.classList.add('hidden');
			}

			areaCards.forEach(card => {
				const element = card as HTMLElement;
				const name = element.dataset.name || '';
				const campuses = element.dataset.campuses || '';
				const groups = element.dataset.groups || '';
				
				const matchesSearch = !query || 
					name.includes(query) || 
					campuses.includes(query) ||
					groups.includes(query);

				if (matchesSearch) {
					element.style.display = 'flex';
					visibleCount++;
				} else {
					element.style.display = 'none';
				}
			});

			// Toggle empty state
			if (visibleCount === 0) {
				emptyState?.classList.remove('hidden');
				emptyState?.classList.add('flex');
			} else {
				emptyState?.classList.add('hidden');
				emptyState?.classList.remove('flex');
			}
		}

		searchInput?.addEventListener('input', filterAreas);
		window.addEventListener('campus-filter-change', (event) => {
			updateAreaViews(event.detail?.campusId || event.detail?.campus || '');
			filterAreas();
		});
		
		resetBtn?.addEventListener('click', () => {
			searchInput.value = '';
			filterAreas();
			searchInput.focus();
		});

		updateAreaViews(localStorage.getItem('preferred-campus') || '');
		filterAreas();
	</script>
</Layout>
